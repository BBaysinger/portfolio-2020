enum AnimationIds
{
	Head_Idle;

	Atom;
	Broken_Hearts;
	Computer_Chip;
	Eye_Look;
	Eye_Projector;
	Earring;
	Flex_Arm;
	Head_HotDog;
	Head_Pizza;
	Head_Soda;
	Hearts;
	Mohawk;
	Monocle;
	Music_Notes;
	Mustache_Blue;
	Mustache_Brown;
	Mustache_Purple;
	Nose_Stud;
	Skull_Crossbones;
	Speech_Balloon_Exclaim;
	Speech_Balloon_Question;
	Stink_Lines;
}

class Data
{

	public static function getHeadAnimationsIds():Array<AnimationIds>
	{
		return
		[
			Head_HotDog,
			Head_Pizza,
			Head_Soda,
		];
	}

	/* ---------------------------------------------------------------------------------------- */

	public static function getHubAnimationsIds():Array<AnimationIds>
	{
		return
		[
			//Under the brain.
			Mohawk,

			//Items that should be on bottom (but over the brain).
			Speech_Balloon_Exclaim,
			Speech_Balloon_Question,

			Broken_Hearts,
			Computer_Chip,
			Eye_Look,
			Eye_Projector,
			Earring,
			
			Hearts,
			Music_Notes,
			Mustache_Blue,
			Mustache_Brown,
			Mustache_Purple,
			Nose_Stud,
			Skull_Crossbones,

			Stink_Lines,

			//Items that have to be on top.
			Monocle,
			Atom,
			Flex_Arm,

		];
	}

	/* ---------------------------------------------------------------------------------------- */

	public static function getAnimationId(catId:CategoryId):AnimationIds
	{
		var anim:AnimationIds;

		switch (catId)
		{
			case EDUCATION, SPACE, LETTER_R, NUMBER_4, PR_MEGAFORCE, HENRY_DANGER:
				anim = Atom;

			case IMPOSSIBLE:
				anim = Broken_Hearts;

			case JOBS, GADGETS, TECHNOLOGY, PLACES, ICARLY, GAME_SHAKERS:
				anim = Computer_Chip;

			// case : 
			// 	Eye_Look; // TODO: SUPPOSED TO BE RANDOM.

			case TRANSPORTATION, CLOSE_UPS, FIRST_MEETINGS:
				anim = Eye_Projector;

			case FAMILY, CLOTHING, EVERY_WITCH_WAY:
				anim = Earring;

			case PR_DINO_CHARGE, SPORTS, ANATOMY, FIGHTING, BELLA_BULLDOGS:
				anim = Flex_Arm;

			case FOOD, RESTAURANTS, NRDD:
				anim = Head_HotDog;

			case DWELLINGS, EVENTS, TMNT:
				anim = Head_Pizza;

			case NUMBERS, BIG_THINGS, SHOWS_WITHIN_SHOWS:
				anim = Head_Soda;

			case LOVE, FRIENDS, VICTORIOUS:
				anim = Hearts;

			case TALENT, HAIR, GREEN, HARVEY_BEAKS:
				anim = Mohawk;

			case EDUCATION, NAMES, WITS_ACADEMY:
				anim = Monocle;

			case MUSIC, THEME_SONGS, DANCING:
				anim = Music_Notes;

			case ANIMALS, SECRETS, LOK_ATLA:
				anim = Mustache_Blue;

			case EYEBROWS, CATCHPHRASES, SAM_AND_CAT:
				anim = Mustache_Brown;

			case COLOR:
				anim = Mustache_Purple;

			case CHRONOLOGY, ARTS_CRAFTS, PERSONALITY:
				anim = Nose_Stud;

			case ENEMIES, FEARS, VACATIONS, ROUND_STUFF:
				anim = Skull_Crossbones;

			case QUOTES, NEIGHBORS, BABIES:
				anim = Speech_Balloon_Exclaim;

			case RATHER, N100_THINGS:
				anim = Speech_Balloon_Question;

			case JOKES, GROSS, SMELLS, SPONGEBOB:
				anim = Stink_Lines;

			case TEST1:
				anim = Speech_Balloon_Exclaim;
		}

		return anim;

	}

