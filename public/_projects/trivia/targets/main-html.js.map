package com.nick.ultimatetrivia.scenes;

import flambe.asset.AssetPack;
import flambe.display.FillSprite;
import flambe.display.Font;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.Disposer;
import flambe.Entity;
import flambe.input.PointerEvent;
import flambe.System;

import s2.display.AutoFillScreen;
import s2.display.ButtonMode;
import s2.display.MultiTextureSprite;
import s2.localization.Locale;
import s2.scene.AutoFillScene;
import s2.scene.Scenes;

import s2.ui.BasicButton;
import s2.ui.TextFluidButton;
import s2.ui.TextButton;

using s2.display.LayoutUtil;

/**
 * ...
 * @author Seven2
 */
class PauseScene extends AutoFillScene
{
	/** The frame for the menu and buttons. */
	private var _frame 		:Entity;
	/** The holder for the menu buttons */
	private var _buttons 	= new Entity();
	/** The confirmation dialog */
	private var _confirm 	:Entity;
	/**  */
	private	var _btnMute 	= new Entity();
	/**  */
	//private	var _btnHelp 	= new Entity();
	/**  */
	private	var _btnResume 	= new Entity();
	/**  */
	private	var _btnQuit 	= new Entity();

	/* ---------------------------------------------------------------------------------------- */

	@:keep public function new()
	{
		super();
		this.opaque = false;
		requiredPacks.push('pause_scene');
		//requiredPacks.push('instruction_scene');
		requiredPacks.push('global');
	}

	/* ---------------------------------------------------------------------------------------- */

	function updateMuteButton()
	{
		var pack :AssetPack = _assets.get('pause_scene');
		var id = System.volume._ == 0 ? "sound_off" : "sound_on";
		var texture = pack.getTexture(id);
		var sprite = new ImageSprite(texture);
		sprite.centerAnchor();
		_btnMute.get(BasicButton).overlay.add(sprite);
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function assetsReady():Void
	{
		var disposer = owner.get(Disposer);
		var pack :AssetPack = _assets.get('pause_scene');
		var globalPack :AssetPack = _assets.get('global');

		this.setBackground( new FillSprite(0x000000, 1366, 768).setAlpha(.4) );

		_frame = new Entity().add(new ImageSprite(pack.getTexture("panel", false)));

		var frameWidth :Float = _frame.get(Sprite).getNaturalWidth();
		var frameHeight :Float = _frame.get(Sprite).getNaturalHeight();

		// Setup the mute button.
		_btnMute.add(new BasicButton(pack, "btn"));
		updateMuteButton();

		//_btnHelp.add( new BasicButton(pack, "btn_help"));
		_btnResume.add( new BasicButton(pack, "btn_resume"));
		_btnQuit.add( new BasicButton(pack, "btn_home"));

		arrangeLayout();

		// Setup confirmation dialog.
		_confirm = new Entity()
			.add(new Sprite());
		
		var header :Entity = new Entity()
			.add(Locale.getField("pause.confirmQuit").centerAnchor());
		header.get(Sprite).setXY(206, Sprite.getBounds(header).height * 0.5 - 10);

		var yes :Entity = new Entity()
			.add(new TextButton(globalPack, "ui/confirm_button", "pause.yes").setXY(40, 20));

		var no :Entity = new Entity()
			.add(new TextButton(globalPack, "ui/confirm_button", "pause.no").setXY(280, 20));

		// Use a container to center the yes and no buttons.
		var yesno :Entity = new Entity()
			.add(new Sprite())
			.addChild(yes)
			.addChild(no);
		var yesNoBounds = Sprite.getBounds(yesno);
		yesno.get(Sprite).setXY(frameWidth / 2 - yesNoBounds.width / 2, header.get(Sprite).getNaturalHeight() * header.get(Sprite).scaleY._ + header.get(Sprite).y._);

		_confirm
			.addChild(header)
			.addChild(yesno);

		var confirmBounds = Sprite.getBounds(_confirm);
		_confirm.get(Sprite).setXY((frameWidth / 2 - confirmBounds.width / 2) - confirmBounds.x, frameHeight / 2 - confirmBounds.height / 2);

		_frame.addChild(_confirm);
		_frame.addChild(_buttons);
		_container.addChild(_frame);
	
		_confirm.get(Sprite).visible = false; // Hide the confirmation dialog.

		// Connect to signals
		disposer.connect1(_btnMute.get(BasicButton).engaged, onMuteClick);
		disposer.connect1(_btnQuit.get(BasicButton).engaged, onQuitClick);
		disposer.connect1(_btnResume.get(BasicButton).engaged, onResumeGame);
		disposer.connect1(no.get(BasicButton).engaged, onNoClick);
		disposer.connect1(yes.get(BasicButton).engaged, onYesClick);

		// Swapping of the mute button
		disposer.connect2( System.volume.changed, function(to :Float, _) {
			updateMuteButton();
		});

	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		super.onAdded();

		var pack :AssetPack = _assets.get('pause_scene');
		pack.getSound("sfx/pause").play();
	}

	/* ---------------------------------------------------------------------------------------- */

	private function arrangeLayout()
	{
		var buttonOrder :Array<Entity>;
		var frameWidth :Float = _frame.get(Sprite).getNaturalWidth();
		var frameHeight :Float = _frame.get(Sprite).getNaturalHeight();

		buttonOrder = [_btnResume, _btnMute, _btnQuit];

		var center = standardWidth/2;
		var spacing :Float = 150;

		for (i in 0...buttonOrder.length) {
			var button :Entity = buttonOrder[i];
			var image :Sprite = button.get(Sprite);
			image.x._ = spacing * i - spacing * (buttonOrder.length - 1) / 2;
			_buttons.addChild( button );
		}

		_buttons.add(new Sprite());
		var buttonBounds = Sprite.getBounds(_buttons);
		_buttons.get(Sprite).setXY( frameWidth * 0.5 - buttonBounds.centerX, frameHeight * 0.5 - buttonBounds.centerY);

	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	*
	*/
	override function onResize()
	{
		super.onResize();
		_frame.center();
	}

	/* ---------------------------------------------------------------------------------------- */
	
	private function onYesClick(e):Void
	{
		Scenes.goto(TitleScene);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	private function onNoClick(e):Void
	{
		_confirm.get(Sprite).visible = false;
		_buttons.get(Sprite).visible = true;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Handles the mute button being clicked.
	*/
	private function onMuteClick(e :PointerEvent):Void
	{
		System.volume._ = System.volume._ == 0 ? 1 : 0;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Handles the home button being clicked.
	*/
	private function onQuitClick(e :PointerEvent):Void
	{
		_confirm.get(Sprite).visible = true;
		_buttons.get(Sprite).visible = false;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Handles the home button being clicked.
	*/
	private function onResumeGame(e :PointerEvent):Void
	{
		while (Scenes.director.occludedScenes.length > 0)
		{
			Scenes.director.popScene();
		}

	}
	
}





















