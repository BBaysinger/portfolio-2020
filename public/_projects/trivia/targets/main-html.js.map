package s2.util;

import flambe.System;
import haxe.Http;

using StringTools;

/**
 * I claim no credit for this. Pulled from: http://haxe.org/doc/snip/uri_parser
 */
@:keep
class URLParser
{
    // Publics
    public var url : String;
    public var source : String;
    public var protocol : String;
    public var authority : String;
    public var userInfo : String;
    public var user : String;
    public var password : String;
    public var host : String;
    public var port : String;
    public var relative : String;
    public var path : String;
    public var directory : String;
    public var file : String;
    public var query : Map<String, String>;
    public var anchor : String;
 
    // Privates
    static private var _parts : Array<String>;
 
    public function new(url:String)
    {
    	init();
        // Save for 'ron
        this.url = url;
 		query = new Map();
        // The almighty regexp (courtesy of http://blog.stevenlevithan.com/archives/parseuri)
        var r : EReg = ~/^(?:(?![^:@]+:[^:@\/]*@)([^:\/?#.]+):)?(?:\/\/)?((?:(([^:@]*)(?::([^:@]*))?)?@)?([^:\/?#]*)(?::(\d*))?)(((\/(?:[^?#](?![^?#\/]*\.[^?#\/.]+(?:[?#]|$)))*\/?)?([^?#\/]*))(?:\?([^#]*))?(?:#(.*))?)/;
 
        // Match the regexp to the url
        r.match(url);
 
        // Use reflection to set each part
        for (i in 0..._parts.length)
        {
        	var val :String = r.matched(i);
        	if (val != null) {    		
	        	if (_parts[i] != "query") {
	            	Reflect.setField(this, _parts[i],  val);
	        	} else {
	        		var keyVal :Array<String> = val.split("&");
	        		for (i in 0...keyVal.length) {
	        			var kv :Array<String> = keyVal[i].split("=");
	        			query.set(kv[0], kv[1]);
	        		}

	        	}
        	}
        }
    }
 
    public function toString() : String
    {
    	init();
        var s : String = "For Url -> " + url + "\n";
        for (i in 0..._parts.length)
        {
            s += _parts[i] + ": " + Reflect.field(this, _parts[i]) + (i==_parts.length-1?"":"\n");
        }
        return s;
    }
 	
 	private static inline function init() :Array<String>
 	{
 		if (_parts == null) {
			_parts = ["source","protocol","authority","userInfo","user","password","host","port","relative","path","directory","file","query","anchor"];
 		}
 		return _parts;
 	}

    public static function parse(url:String) : URLParser
    {
    	init();
        return new URLParser(url);
    }

    public static function fromBrowser() :URLParser
    {
#if html
		return URLParser.parse(Std.string(js.Browser.location));
#elseif flash
		if (flash.external.ExternalInterface.available) {
			return URLParser.parse(flash.external.ExternalInterface.call("function(){ return window.location.href.toString() }"));
		}
		return new URLParser("");
#end
        return new URLParser("");
    }
}
