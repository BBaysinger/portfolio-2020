package s2.loading;

import flambe.asset.AssetPack;
import flambe.asset.File;
import flambe.asset.Manifest;
import flambe.asset.Manifest;
import flambe.Component;
import flambe.display.ImageSprite;
import flambe.display.Texture;
import flambe.display.Texture;
import flambe.Disposer;
import flambe.sound.Sound;
import flambe.System;
import flambe.util.Disposable;
import flambe.util.Promise;
import flambe.util.Signal0;
import flambe.util.Signal2;

using Lambda;

/**
 * A utility class to manage retrieval of multiple asset packs. This is meant as an easy way to deffer loading of different assets for scenes.
 * For instance, allow loading of the title scene's assets later.
 * 
 * @author Kipp Ashford
 */
class Assets extends Component
{	
	/** Relative base path to use with loading assets. */
	public static var relativeBase :String;
	/** External base path to use with loading assets. */
	public static var externalBase :String;
	/** The suffix to use for loading assets. Useful for mobile versions. */
	public static var suffix :String;

	/** Caches an asset pack. Make sure to release the memory by calling Assets.release(packName); */
	private static var _cache:Map<String, AssetPack>;

	/**  */
	private var _nLoaded:Int = 0;
	/**  */
	private var _nNeeded:Int = 0;

	/** The asset packs which are ready to go. */
	private var _packsReady	:Map<String, AssetPack>;
	/** */
	private var _manifests	:Map<String, Manifest>;
	/** */
	private var _packsLoading:Array<Promise<AssetPack>>;
	/**  */
	public var autoCacheResults:Bool;
	/**  */
	public var releaseCacheOnRemove:Bool = false;
	/** */
	private var _isLoading:Bool = false;
	/** added to the beginning of the directory for an asset pack to load. (e.g. "gameplay_desktop", "gameplay_mobile" would use a suffix of "desktop" or "mobile") */
	private var _suffix:String;
	private var _retryCount:Int =0;
	/** The queue of manifests to load. */
	private var _queue :Array<String>;
	private var _disposer :Disposer;
	private var _currentManifest :String;

	/** The ready signal when assets are prepped. */
	public var success(default, null):Signal0;
	/** The signal which dispatches progress. */
	public var progressed(default, null):Signal2<Float,Float>;
	/** Keeps track if the assets are ready to be use in this group. */
	public var ready(default, null):Bool = false;
	/** The number of bytes that have loaded. */
	public var loadedBytes(default,null):Float = 0;
	/** The total number of bytes to load. */
	public var totalBytes(default, null):Float = 0;

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * @param  neededPacks Array<String> =             null An array of packs to require.
	 * @param  cacheResults        [description]
	 * @param  suffix              [description]
	 * @return                      [description]
	 */
	public function new(?neededPacks :Array<String> = null, ?dynamicManifests:Map<String, Manifest>, ?append :String) 
	{	
		progressed = new Signal2();
		success = new Signal0();
		_disposer = new Disposer();
		_suffix = append != null ? append : Assets.suffix;
		_manifests = new Map();
		_packsReady = new Map();
		_packsLoading = [];
		_queue = [];

		// Quick hack.
		this.autoCacheResults = true;
		this.releaseCacheOnRemove = false;
		// this.autoCacheResults = autoCacheResults;
		// this.releaseCacheOnRemove = releaseCacheOnRemove;

		_nNeeded = 0;
		_nLoaded = 0;
		if (neededPacks != null) {
			for (i in 0...neededPacks.length) {
				require(neededPacks[i]);
			}
		}

		if (dynamicManifests != null) {
			for (key in dynamicManifests.keys()) {
				addManifest(dynamicManifests.get(key), key, true);
			}
			
		}

	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Requires an asset pack. Make sure to set this up before your component is added (for instance in the constructor)
	 */
	public function require(directory:String):Assets 
	{
		var suffix :String = _suffix == null ? "" : "_" + _suffix;

		if ( Manifest.exists(directory + suffix) ) {

			addManifest(Manifest.fromAssets(directory + suffix), directory);
		} else if ( Manifest.exists(directory)) {
			addManifest(Manifest.fromAssets(directory), directory);
		} else {
			var se:String = _suffix == null ? "" : " Also attempted path " + directory + suffix;
			throw "The directory " + directory + " does not exist in the manifest." + se;
		}

		return this;
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Adds an arbitrary manifest. Can be used to load a dynamic file (or group of files).
	 */
	public function addManifest(manifest:Manifest, key :String, replace:Bool = false):Assets 
	{
		if (!_manifests.exists(key) || replace) {
			_nNeeded++;
			if ( externalBase != null ) {
				manifest.remoteBase = externalBase;
			}
			else if ( relativeBase != null ) {
				manifest.localBase = relativeBase;
			}
			_manifests.set(key, manifest);
			_queue.push(key);
		} else {
			throw "Asset key for manifest " + key + " already exists.";
		}
		return this;
	}
		
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Starts loading up the assets in the queue.
	 * @return [description]
	 */
	public function load() 
	{
		totalBytes = 0;
		loadedBytes = 0;
		ready = false;

		for (manifest in _manifests) {
			for (entry in manifest) {
				totalBytes += entry.bytes; // Calculate the total number of bytes to load.
			}
		}

		loadManifest(_queue.shift());
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Unloads an asset pack and disposes the assets.
	 * @param  key :String       [description]
	 * @return     [description]
	 *
	 * For HTML platform, make sure all sounds are disposed BEFORE unloading assets,
	 * because WebAudioSound calls assertNotDisposed() every time get_duration is called,
	 * and that apparently continues to occur between onRemoved() and dispose().
	 */
	public function unload(key :String, bark:Bool = true)
	{
		if (_queue.has(key)) {
			_queue.remove(key);
		}

		var pack :AssetPack = get(key, bark);

		if (pack != null)
		{
			Assets.release(key);
			#if debug
				//trace("Unloading asset pack: " + key);
			#end
			_manifests.remove(key);
			pack.dispose();
		}

	}

	/* ---------------------------------------------------------------------------------------- */
	
	private function loadManifest(key :String)
	{
		var cachedPack :AssetPack = getCached(key);

		if(cachedPack != null) {
			_manifests.set(key, cachedPack.manifest); // Makes sure it uses the same instance of the manifest for lookup down the line.
			onSuccess(cachedPack); // Stored in the Asset cache
		} else {
			var promise :Promise<AssetPack> = System.loadAssetPack(_manifests.get(key));
			if (promise.hasResult) {
				onSuccess(promise.result); // Promise already available.
			} else {
				// We need to load up some assets!
				_isLoading = true;
				_packsLoading.push(promise);
				
				var s = promise.success.connect(onSuccess).once();
				var err = promise.error.connect(onError);
				var p = promise.progressChanged.connect(onProgress);
				_currentManifest = key;
				_disposer.add(s);
				_disposer.add(err);
				_disposer.add(p);
				// promise.get(onSuccess);
			}
		}
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	public function onProgress()
	{
		var nLoaded :Float = 0;

		// Loop through all the loading promises and determine how much we have loaded.
		for (i in 0..._packsLoading.length) {
			nLoaded += _packsLoading[i].progress;
		}

		for (pack in _packsReady) {
			for (entry in pack.manifest) {
				nLoaded += entry.bytes;
			}
		}
		
		progressed.emit(nLoaded, totalBytes);
		loadedBytes = nLoaded;
	}
	
	/* ---------------------------------------------------------------------------------------- */
			
	/**
	 * Reset everything in this component.
	 * @return
	 */
	override public function onRemoved():Void 
	{
		if(releaseCacheOnRemove) {
			var keys = _manifests.keys();
			for (key in keys) {
				release(key);
			}
		}

		_disposer.dispose();
		_isLoading = false;
		ready = false;
		_packsLoading = [];
		_packsReady = new Map();
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Sets the suffix applied to manifest directories loaded.
	 */
	public function setSuffix(suffix:String):Void {
		_suffix = suffix;
	}
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Gets the asset pack for a given area.
	 */
	public function get(directory :String, bark:Bool = true):AssetPack
	{
		if (ready) {
			var suffix:String = _suffix == null ? "" : "_" + _suffix;
			var pack:AssetPack = _packsReady.get(directory + suffix);
			
			if (pack != null) {
				return pack;
			} else {

				pack = _packsReady.get(directory);
				if (pack != null)
					return pack;
				else
				{
					if (bark)
						throw "Asset pack " + directory + " not part of this asset requirement.";
					else
						return null;
				}
				
			}
		} else {
			throw "Can't get an asset pack before all packs are loaded and ready.";
		}
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Utility to get a manifest with the added on suffix. Mostly used for the bootstrap loader.
	 * @param  directory :String       [description]
	 * @return           [description]
	 */
	public static function getManifest(directory :String ) :Manifest
	{
		var manifest :Manifest = null;
        if (Assets.suffix != null && Manifest.exists(directory + "_" + Assets.suffix)) {
        	manifest = Manifest.fromAssets(directory + "_" + Assets.suffix);
        }

        manifest = Manifest.fromAssets(directory);
        
        return setupManifest(manifest);
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Creates a new manifest with the appropriate base paths, or simply configures an existing one if none is specified.
	 * @param  ?manifest :Manifest     The manifest to setup. If none is specified, a new manifest is created.
	 * @return           [description]
	 */
	public static function setupManifest(?manifest :Manifest) :Manifest
	{
		manifest = manifest == null ? new Manifest() : manifest;

        // Add on relative paths if they exist.
        if ( Assets.externalBase != null ) {
            manifest.remoteBase = Assets.externalBase;
        }
        else if ( Assets.relativeBase != null ) {
            manifest.localBase = Assets.relativeBase;
        }

		return manifest;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Fired when an asset has been preloaded.
	 * @param	pack
	 */
	private function onSuccess(pack:AssetPack)
	{	
		_retryCount = 0;
		_disposer.dispose();
		_nLoaded++;

		var keys = _manifests.keys();

		for (directory in _manifests.keys()) {
			if (_manifests.get(directory) == pack.manifest)	{
				if(autoCacheResults) {
					cache(directory, pack);
				}
				_packsReady.set(directory, pack);
			}
		}
		
		if ( _nLoaded == _nNeeded ) {
			progressed.emit(totalBytes, totalBytes);
			_isLoading = false;
			ready = true;
			success.emit();
		} else {
			_packsLoading.shift();
			loadManifest(_queue.shift());
		}
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * If an error happens, retry loading the lats manifest.
	 * @param  err :String       [description]
	 * @return     [description]
	 */
	private function onError(err :String)
	{
		trace(err);
		trace("Error loading. Retrying pack " + _currentManifest);
#if html
		untyped console.log(err);
		if (_retryCount > 3) {
			untyped alert(err + "\nAttempted retries: " + _retryCount);
			return;
		}
#end
		_disposer.dispose();
		_retryCount++;
		loadManifest(_currentManifest);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Gets a cached asset.
	 * 
	 * @param  key The key name used to store the asset.
	 * @return     The cached AssetPack. Returns null if there is no asset which has been cached by that name.
	 */
	public static function getCached(key:String):AssetPack
	{
		if(_cache == null) {
			_cache = new Map<String, AssetPack>();
		}

		if(_cache.exists(key)) {
			return _cache.get(key);	
		}
		
		return null;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Caches an asset pack so it doesn't attempt to load from the browser memory.
	 * USE WITH CAUTION, and make sure to call release(packName) to allow it to be garbage collected.
	 * 
	 * @param  key  The name of the assetpack.
	 * @param  pack The asset pack to store.
	 */
	public static function cache(key:String, pack:AssetPack) 
	{
		if(_cache == null) {
			_cache = new Map<String, AssetPack>();
		}
#if debug
		if (!_cache.exists(key)) {
			trace("Caching asset pack: " + key + ". Please be sure to release it when done.");
		}
#end
		_cache.set(key,pack);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Releases an assetpack from memory.
	 * @param  key [description]
	 * @return     [description]
	 */
	public static function release(key:String):AssetPack
	{
		if (_cache != null && _cache.exists(key)) {
			var pack:AssetPack = _cache.get(key);
			_cache.remove(key);
			//#if debug trace("Removing cached asset pack: " + key + "."); #end
			return pack;
		}
		#if debug trace("WARNING: calling release on assetpack " + key + ". Does not exist."); #end

		return new NullAssetPack();
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 *
	 */
	override public function dispose() :Void
	{
		super.dispose();

		_cache = null;
		_packsReady = null;
		_manifests = null;
		_packsLoading = null;
		success = null;
		progressed = null;

	}

}

class NullAssetPack implements AssetPack
{

	public function new()
	{
		
	}

    public var manifest (get, null) :Manifest;

    /**
     * Gets a texture by name from the asset pack. The name must NOT contain a filename extension.
     * Textures are cached, so it's safe to get the same texture multiple times.
     * @param required If true and the asset was not found, an error is thrown.
     */ 
    public function getTexture (name :String, required :Bool = true) :Texture { return null; };

    /**
     * Gets a sound by name from the asset pack. The name must NOT contain a filename extension.
     * Sounds are cached, so it's safe to get the same sound multiple times.
     * @param required If true and the asset was not found, an error is thrown.
     */
    public function getSound (name :String, required :Bool = true) :Sound { return null; };

    /**
     * Gets a file by name from the asset pack, returning its raw content. Files are cached, so it's
     * safe to get the same file multiple times.
     * @param required If true and the asset was not found, an error is thrown.
     */
    public function getFile (name :String, required :Bool = true) :File { return null; };

    /**
     * Disposes all the assets in this AssetPack. After calling this, any calls to getTexture,
     * getSound, or getFile will assert.
     */
    public function dispose () :Void { #if debug trace("WARNING: Disposing a NullAssetPack."); #end };

    public function get_manifest() :Manifest { return null; }

}