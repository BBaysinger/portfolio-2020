package com.nick.ultimatetrivia.components.question;

import flambe.Entity;
import flambe.asset.AssetPack;
import flambe.Disposer;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.display.TextSprite;
import flambe.math.Point;
import flambe.animation.Ease;

import s2.animation.Draggable2;
import s2.scene.AutoFillScene;
import s2.localization.Locale;
import s2.util.Utils;
import s2.util.TimeUtil;

/**
 * Controls how the questions are displayed.
 * ...
 * @author Seven2
 */
class MatchingQuestionDisplay extends QuestionDisplay
{
	/**  */
	private static inline var SPREAD:Int = 900;
	/**  */
	private static inline var OPT_Y:Int = 422;
	/**  */
	private static inline var QUR_Y:Int = 578;
	/**  */
	private static inline var OFFSET_Y:Int = -49;

	//Composite data types.
	/**  */
	private var _queries = new Array<Entity>();
	/** By the order they occur in xml. */
	private var _optionIndexes = new Map<Entity, Int>();
	/** Where they have been placed. */
	private var _optionPositions:Array<Int> = [-1, -1, -1, -1];		

	/* ---------------------------------------------------------------------------------------- */

	public function new(gamePack:AssetPack, questionPack:AssetPack, globalPack:AssetPack, question:Question)
	{
		super(gamePack, questionPack, globalPack, question);
	}

	/* ---------------------------------------------------------------------------------------- */

	override private function build()
	{
		var disposer = owner.get(Disposer);
		var c_option:ImageSprite;
		var c_query:ImageSprite;
		var option:Entity;
		var oQuery:Query;
		var oOption:Option;
		var wye:Int = 96;
		var c_queryImage:ImageSprite;

		for (i in 0..._oQuestion.queries.length)
		{
			oQuery = _oQuestion.queries[i];
			c_query = new ImageSprite(_scenePack.getTexture("matching_query" + (i + 1)));
			c_query.centerAnchor();
			c_query.setXY(getQueryXPos(i), QUR_Y);
			owner.addChild(_queries[i] = new Entity().add(c_query));
			var query:Entity;

			c_queryImage = null;

			if (_oQuestion.type == MATCH_IMAGE)
			{
				if (oQuery.image == null)
				{
					c_queryImage = new ImageSprite(_scenePack.getTexture("missing_match_image_query"));
				}
				else
				{
					c_queryImage = new ImageSprite(_quizPack.getTexture(oQuery.image));
				}

				c_queryImage.setXY(6, 103);
				_queries[i].addChild(new Entity().add(c_queryImage));

			}
			
			var c_queryLabel:ImageSprite = null;

			if (oQuery.image == null)
			{
				var c_queryLabel:TextSprite = Locale.getField("question.matchingQuery", 170, Center);
				c_queryLabel.text = ((oQuery).text != null) ? oQuery.text : oQuery.image;
				c_queryLabel.centerAnchor();
				query = new Entity().add(c_queryLabel);
				_queries[i].addChild(query);
				c_queryLabel.setXY(wye, 152);
			}

		}

		for (i in 0..._oQuestion.queries.length)
		{
			oOption = _oQuestion.options[i];
			c_option = new ImageSprite(_scenePack.getTexture("matching_option"));
			c_option.centerAnchor();
			c_option.anchorY._ += 1;
			c_option.anchorX._ -= 2;
			c_option.setXY(getOptionXPos(i), OPT_Y);
			owner.addChild(_options[i] = new Entity().add(c_option));
			_optionIndexes.set(_options[i], i);
			_options[i].add(new Draggable2());
			disposer.connect1(_options[i].get(Draggable2).drop, onDragDrop);
			disposer.connect1(_options[i].get(Draggable2).pick, onDragPick);

			var optionText:Entity;
			var c_label:Sprite;

			var c_image:ImageSprite = null;

			if (_oQuestion.type == MATCH_IMAGE)
			{
				if (oOption.image == null)
				{
					c_image = new ImageSprite(_scenePack.getTexture("missing_match_image_option"));
				}
				else
				{
					c_image = new ImageSprite(_quizPack.getTexture(oOption.image));
				}

				c_image.setXY(6, 6);
				_options[i].addChild(new Entity().add(c_image));

			}
			
			if (oOption.image == null)
			{
				var c_optionLabel:TextSprite = Locale.getField("question.matchingOption", 170, Center);
				c_optionLabel.text = ((oOption).text != null) ? oOption.text : oOption.image;
				c_optionLabel.centerAnchor();
				optionText = new Entity().add(c_optionLabel);
				_options[i].addChild(optionText);
				c_optionLabel.setXY(wye, 58);
			}

			_options[i].add(_oQuestion.options[i]);

		}

	}

	/* ---------------------------------------------------------------------------------------- */

	private function onDragPick(dragged:Draggable2)
	{
		_scenePack.getSound("sfx/drag_drop_pick_up_piece").play();
		owner.addChild(dragged.owner);
	}

	/* ---------------------------------------------------------------------------------------- */

	private function onDragDrop(dragged:Draggable2)
	{
		var c_closest:Sprite = null;
		var xy = new Point(dragged.owner.get(Sprite).x._, dragged.owner.get(Sprite).y._);
		var c_queryDisplay:Sprite = null;
		var shortest:Float = 999999;
		var index:Int = -1;

		for (i in 0..._oQuestion.queries.length)
		{
			c_queryDisplay = _queries[i].get(Sprite);
			var dist = xy.distanceTo(c_queryDisplay.x._, c_queryDisplay.y._ + OFFSET_Y);

			if (shortest > dist) 
			{
				c_closest = c_queryDisplay;
				index = i;
			}

			shortest = Math.min(shortest, dist);

		}

		var c_spriteDragged = dragged.owner.get(Sprite);

		if (shortest < 100)
		{
			_scenePack.getSound("sfx/drag_drop_into_place").play();

			if (_optionPositions[index] != -1 && _optionPositions[index] != _optionIndexes.get(dragged.owner))
			{
				var sprite = _options[_optionPositions[index]].get(Sprite);
				sprite.x.animateTo(getOptionXPos(_optionIndexes.get(_options[_optionPositions[index]])), 0.4, Ease.linear);
				sprite.y.animateTo(OPT_Y, 0.4, Ease.sineOut);
			}

		}

		if (_optionPositions.indexOf(_optionIndexes.get(dragged.owner)) != -1)
		{
			_optionPositions[_optionPositions.indexOf(_optionIndexes.get(dragged.owner))] = -1;
		}

		if (shortest < 100)
		{
			_optionPositions[index] = _optionIndexes.get(dragged.owner);
			c_spriteDragged.x.animateTo(c_closest.x._, 0.2, Ease.linear);
			c_spriteDragged.y.animateTo(c_closest.y._ + OFFSET_Y, 0.2, Ease.sineOut);
		}
		else
		{
			c_spriteDragged.x.animateTo(getOptionXPos(_optionIndexes.get(dragged.owner)), 0.4, Ease.linear);
			c_spriteDragged.y.animateTo(OPT_Y, 0.4, Ease.sineOut);
		}

		for (i in 0..._oQuestion.queries.length)
		{
			if (_optionPositions[i] != -1)
			{
				_oQuestion.queries[i].setSelected(_oQuestion.options[_optionPositions[i]]);
			}
			else
			{
				_oQuestion.queries[i].setSelected(null);
			}
			
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	private function getPos(index:Int):Float
	{
		var spacing = SPREAD / _oQuestion.queries.length;
		var nMid = (_oQuestion.queries.length - 1) / 2;
		var nPos = nMid - index;
		var ex = spacing * nPos;

		return ex + AutoFillScene.STANDARD_WIDTH/2;
	}

	/* ---------------------------------------------------------------------------------------- */

	private function getQueryXPos(index:Int):Float
	{
		return getPos(index);
	}

	/* ---------------------------------------------------------------------------------------- */

	private function getOptionXPos(index:Int):Float
	{
		return getPos(_order[index]);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function animateOut()
	{
		var timeUtil = owner.get(TimeUtil);

		if (_oQuestion.allCorrect())
		{
			timeUtil.timeout(finishAnimateOut, 1.0);
		}
		else
		{
			function delayed1()
			{
				var num1:Int = 0;

				for (i in 0..._oQuestion.queries.length)
				{
					if (i != _optionPositions[i])
					{
						timeUtil.timeout(function()
						{
							_options[_optionPositions[i]].get(Sprite).y.animateTo(OPT_Y, .6, Ease.expoOut);
						}, num1 * 0.1);

						num1++;

					}

				}

				function delayed2()
				{
					var num2:Int = 0;

					for (i in 0..._oQuestion.queries.length)
					{
						if (i != _optionPositions[i])
						{
							var option:Entity = _options[_optionPositions[i]];
							
							timeUtil.timeout(function()
							{
								owner.addChild(option);
								option.get(Sprite).x.animateTo(getQueryXPos(option.get(Option).index), .6, Ease.sineIn);
								option.get(Sprite).y.animateTo(QUR_Y + OFFSET_Y, .6, Ease.sineOut);

							}, num2 * 0.2);

							num2++;
						}

					}

				}

				timeUtil.timeout(delayed2, .5);

			}

			timeUtil.timeout(delayed1, .1);
			timeUtil.timeout(finishAnimateOut, 2.0);
		}

	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function dispose()
	{
		super.dispose();
		
		_queries = null;
	}

}























