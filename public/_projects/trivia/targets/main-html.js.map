package s2.display;

import flambe.display.Sprite;

/**
 * ...
 * @author Seven2
 */
class SizeSprite extends Sprite
{
	/** The width and height. */
	public var	width				:Float;
	public var	height			:Float;
	
	/* ---------------------------------------------------------------------------------------- */

	/*
	* Constructs a new hero component.
	* 
	* @param	heroFormat	The hero format.
	* @param	texture		The texture representing the visual representation of the platform.
	*/
	public function new(nWidth:Float, nHeight:Float)
	{
		super();
		
		width = nWidth;
		height = nHeight;
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
     * The "natural" width of this sprite, without any transformations being applied. Used for hit
     * testing. This does not consider child sprites, use Sprite.getBounds for that.
     */
    override public function getNaturalWidth () :Float
    {
		return width;
    }
	
	/* ---------------------------------------------------------------------------------------- */
	
    /**
     * The "natural" height of this sprite, without any transformations being applied. Used for hit
     * testing. This does not consider child sprites, use Sprite.getBounds for that.
     */
    override public function getNaturalHeight () :Float
    {
		return height;
    }
	
	/* ---------------------------------------------------------------------------------------- */
	
}
