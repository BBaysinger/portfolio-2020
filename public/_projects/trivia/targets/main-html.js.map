package com.nick.ultimatetrivia.scenes;

import flambe.asset.AssetPack;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.Disposer;
import flambe.Entity;
import flambe.input.PointerEvent;
import flambe.scene.Scene;
import flambe.System;
import flambe.display.TextSprite;

import s2.client.Config;
import s2.display.MultiTextureSprite;
import s2.ui.BasicButton;
import s2.ui.TextFluidButton;
import s2.ui.TextButton;
import s2.localization.Locale;
import s2.scene.AutoFillScene;
import s2.scene.Scenes;
import s2.util.StringUtil;
import s2.util.Utils;
import s2.sound.MusicManager;
import s2.util.TimeUtil;

import com.nick.ultimatetrivia.components.Heading;
import com.nick.ultimatetrivia.components.GameTracker;
import com.nick.ultimatetrivia.Data.CategoryId;

using s2.display.LayoutUtil;
using Lambda;

/**
 * 
 * @author Seven2
 */
class ResultsScene extends InGameScene
{	
	/**  */
	private var _btnHub:Entity;
	/** */
	private var _btnReplay:Entity;
	/** */
	private var _btnRandom:Entity;
	/**  */
	private var _banner(default, null) = new Entity();
	/**  */
	private var _wedgeWings(default, null) = new Entity();
	/**  */
	private var _numberBlocks(default, null) = new Entity();
	/**  */
	private var _msgHead = new Entity();
	/**  */
	private var _msgDesc = new Entity();

	/* ---------------------------------------------------------------------------------------- */

	@:keep public function new()
	{
		super();
		
		var gt = System.root.get(GameTracker);

		_headLocale = "categoryNames." + Std.string(gt.category).toLowerCase();

		requiredPacks.push('results_scene');
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function assetsReady():Void
	{
		super.assetsReady();

		var disposer = owner.get(Disposer);
		var pack :AssetPack = _assets.get('results_scene');
		var globalPack :AssetPack = _assets.get('global');

		var gt = System.root.get(GameTracker);

		var timeUtil = new TimeUtil();
		owner.add(timeUtil);

		timeUtil.timeout(function()
		{
			MusicManager.loopSoundStandard(pack, "snd/utg_splash_menuscreens__endscreen_musicloopv1", 1);
		}, 0.0);

		_btnHub = new Entity();
		var c_btnHub = new TextButton(globalPack, "ui/btn_pink", "results.btnHub");
		_btnHub.add(c_btnHub);
		_container.addChild(_btnHub);

		_btnRandom = new Entity();
		_btnRandom.add(new TextButton(globalPack, "ui/btn_blue", "results.btnRandom"));
		_container.addChild(_btnRandom);

		_btnReplay = new Entity();
		_btnReplay.add(new TextButton(globalPack, "ui/btn_orange", "results.btnReplay"));
		_container.addChild(_btnReplay);

		var c_banner = new ImageSprite(pack.getTexture("results_banner"));
		c_banner.setXY(260, 253);
		_banner.add(c_banner);
		_container.addChild(_banner);

		if (!gt.isPersonalityQuiz())
		//if (gt.category != RATHER && gt.category != PERSONALITY)
		{
			var c_wedgeWings = new ImageSprite(pack.getTexture("wedge_wings"));
			c_wedgeWings.setXY(130, 76);
			_wedgeWings.add(c_wedgeWings);
			_banner.addChild(_wedgeWings);

			var c_numberBlocks = new ImageSprite(pack.getTexture("number_blocks"));
			c_numberBlocks.setXY(325, 85);
			_numberBlocks.add(c_numberBlocks);
			_banner.addChild(_numberBlocks);

			var c_howMany = Locale.getField("results.numCorrect", 0, Center);
			c_howMany.setXY(432, 208);
			_banner.addChild(new Entity().add(c_howMany));

			var msgLoc = (gt.failed) ? "results.failMsg" : "results.successMsg";
			var c_msg = Locale.getField(msgLoc, 0, Center);
			c_msg.setXY(432, 36);
			_banner.addChild(new Entity().add(c_msg));

			var numCorrect = StringUtil.zeroPad(gt.numCorrect, 2);

			var digit0 = Locale.getField("results.digit", 0, Center);
			digit0.setXY(377, 92);
			digit0.text = numCorrect.charAt(0);
			_banner.addChild(new Entity().add(digit0));

			var digit1 = Locale.getField("results.digit", 0, Center);
			digit1.setXY(478, 92);
			digit1.text = numCorrect.charAt(1);
			_banner.addChild(new Entity().add(digit1));

		}
		else
		{
			var rand:Int = -1;
			var id:String = "";
			var descY:Int = -1;
			var c_msgHead:TextSprite;
			var c_msgDesc:TextSprite;
			var ex:Int = 132;
			var width:Int = 590;

			if (gt.category == RATHER)
			{
				rand = Utils.randomInt(6) + 1;
				descY = 139;
				id = "results.rather";
			}
			else if (gt.category == PERSONALITY)
			{
				rand = Utils.randomInt(9) + 1;
				id = "results.personality";
				descY = 178;

				c_msgHead = Locale.getField(id + "Head" + rand, width, Center);
				c_msgHead.lineSpacing._ = -6; 
				_msgHead.add(c_msgHead);
				c_msgHead.setXY(ex, 80 - Sprite.getBounds(_msgHead).height/2);
				_banner.addChild(_msgHead);
			}

			c_msgDesc = Locale.getField(id + "Desc" + rand, width, Center);
			c_msgDesc.lineSpacing._ = -3;
			_msgDesc.add(c_msgDesc);
			c_msgDesc.setXY(ex, descY - Sprite.getBounds(_msgDesc).height/2);
			_banner.addChild(_msgDesc);
		}

		disposer.connect1(_btnHub.get(BasicButton).engaged, onNextButtonClick);
		disposer.connect1(_btnRandom.get(BasicButton).engaged, onRandomButtonClick);
		disposer.connect1(_btnReplay.get(BasicButton).engaged, onReplayButtonClick);


		var btnY = 600;

		if (gt.randomQuizMode)
		{
			_btnHub.get(Sprite).setXY(357, btnY);
			_btnRandom.get(Sprite).setXY(678, btnY);
			_btnReplay.get(Sprite).setXY(1005, btnY);
		}
		else
		{
			_btnHub.get(Sprite).setXY(460, btnY);
			_btnRandom.get(Sprite).visible = false;
			_btnReplay.get(Sprite).setXY(900, btnY);
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * All positioning code goes here. It will be triggered each time the screen is rotated or the dimensions change.
	 */
	override function onResize()
	{
		super.onResize();

		//_banner.centerX(20).centerY(0);

		// if (_btnHub != null) _btnHub.right(160).bottom(40);
		// if (_btnReplay != null) _btnReplay.left(160).bottom(40);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function onNextButtonClick(e :PointerEvent) :Void
	{
		Scenes.goto(BrainHubScene);
	}
	
	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function onRandomButtonClick(e :PointerEvent) :Void
	{
		var gt = System.root.get(GameTracker);

		var categories = Type.allEnums(CategoryId);
		var category = categories[Math.round(Math.random() * categories.length)];
		gt.setQuizType(Data.getCategoryType(category), true);
		gt.generateQuestions(category);
		Scenes.goto(QuestionScene);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function onReplayButtonClick(e :PointerEvent) :Void
	{
		// Canada Tracking. Can be turned on and off through config.xml. Will not break if tracking javascript does not exist.
		//Config.track(['replay']);
		var gt = System.root.get(GameTracker);

		gt.generateQuestions(gt.category);
		Scenes.goto(QuestionScene);
	}
	
	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	override public function onRemoved():Void
	{
		MusicManager.stop();

		_assets.unload("results_scene");

		super.onRemoved();
	}
	
}





















