package s2.display;

import flambe.animation.AnimatedFloat;
import flambe.display.Sprite;
import flambe.Component;

/**
 * Automates the instantiation and adding of a sprite, and gives easy access to its properties.
 * Since extending Sprite isn't recommend in most cases, but Sprite functionality is often required
 * for positioning, etc., of your components, this is a nice way to stay consistent with classes that
 * use a Sprite instance by composition (design pattern). It optionally allows you to manually add your
 * own Sprite instance instead, and swap them out on-the-fly. You can also override the function that
 * instances the default Sprite, so you can instance whatever flavor of Sprite you need.
 * 
 * @author Bradley Baysinger / Seven2
 */
class SpriteUser extends Component
{
	/**  */
	private var _sprite:Sprite;
	/**  */
	public var sprite(get_sprite, null):Sprite;
	/**  */
	public var x(get_x, null):AnimatedFloat;
	/**  */
	public var y(get_y, null):AnimatedFloat;
	/** Determines if the sprite will be created, added, and removed by this instance, internally. */
	public var manageSprite(default, null):Bool;

	/* ---------------------------------------------------------------------------------------- */

	public function new (manageSprite:Bool = true)
	{
		this.manageSprite = manageSprite;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function ensureSprite():Sprite
	{
		if (owner != null)
		{
			if (owner.get(Sprite) != null)
			{
				if (manageSprite && _sprite != null && _sprite != owner.get(Sprite))
				{
					//Keeps things from getting confusing so you don't unknowingly create a default Sprite when you
					//may have intended to use a different one.
					//If you ever want to swap out your sprite on the fly, start by adding one manually instead of the default.
					throw("If sprite is managed internally, it must not be overwritten.");
				}

				_sprite = owner.get(Sprite);

			}

		}

		if (_sprite == null)
		{
			if (manageSprite)
			{
				_sprite = createSprite();
			}
			else
			{
				throw ("If the sprite is not managed internally, it must be added to the owner already.");
			}

		}

		if (owner != null)
		{
			if (owner.get(Sprite) == null)
			{
				owner.add(_sprite);
			}
		}

		return _sprite;
	}

	/* ---------------------------------------------------------------------------------------- */

    /**
     * So you can override with the Sprite flavor of your choice; however, you can add the sprite any way
     * you choose as long is it is added by the time it is accessed.
     */
	private function createSprite():Sprite
	{
		var sprite = new Sprite();
		return sprite;
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		if (manageSprite && owner.get(Sprite) != null)
		{
			throw ("If the sprite is managed internally, it cannot already exist on this entity because it would be overwritten.");
		}

		ensureSprite();

		super.onAdded();

	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onRemoved()
	{
		super.onRemoved();

		if (manageSprite)
		{			
			if (_sprite != null && _sprite.owner != null) _sprite.owner.remove(_sprite);
		}
	}

	/* ---------------------------------------------------------------------------------------- */

	public function setXY(x:Float, y:Float):SpriteUser
	{
		ensureSprite().setXY(x, y);

		return this;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function get_x():AnimatedFloat
	{
		return ensureSprite().x;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function get_y():AnimatedFloat
	{
		return ensureSprite().y;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function get_sprite():Sprite
	{
		return ensureSprite();
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function dispose()
	{
		super.dispose();

		_sprite = null;
	}

}



















