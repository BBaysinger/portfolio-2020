package com.nick.ultimatetrivia.scenes;

import flambe.asset.AssetPack;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.display.FillSprite;
import flambe.Disposer;
import flambe.Entity;
import flambe.input.PointerEvent;
import flambe.scene.Scene;
import flambe.System;
import flambe.display.Texture;
import flambe.scene.FadeTransition;
import flambe.asset.Manifest;
import flambe.math.Point;
import flambesdk.BaseUtils;

import nicksdk.jsembed.JSEmbedProxy;

import s2.loading.Assets;
import s2.client.Config;
import s2.display.MultiTextureSprite;
import s2.ui.BasicButton;
import s2.ui.TextFluidButton;
import s2.localization.Locale;
import s2.scene.AutoFillScene;
import s2.scene.Scenes;
import s2.ui.TextFluidButtonStaticWidth;
import s2.util.TimeUtil;
import s2.util.URLParser;
import s2.util.Utils;
import s2.display.SizeSprite;
import s2.sound.MusicManager;

import com.nick.ultimatetrivia.Data;
import com.nick.ultimatetrivia.components.BrainChunkCallout;
import com.nick.ultimatetrivia.components.GameTracker;
import com.nick.ultimatetrivia.components.ConfettiLayer;
import com.nick.ultimatetrivia.components.Brain;
import com.nick.ultimatetrivia.components.Head;

using s2.display.LayoutUtil;
using Lambda;

/**
 * Stub scene for the final game screen.
 * @author Seven2
 */
class BrainHubScene extends AutoFillScene
{	
	/**  */
	private var _arrow 							= new Entity();
	/**  */
	private var _propertyQuizTypeBtn 			= new Entity();
	/**  */
	private var _categoryQuizTypeBtn 			= new Entity();
	/**  */
	private var _randomQuizBtn 					= new Entity();
	/**  */
	private var _chunkContainer					= new Entity();
	/**  */
	private var _confetti						= new Entity();
	/**  */
	private var _head							= new Entity();
	/** Button to pause the game. */
	private var _btnPause 						= new Entity();
	/** Button to pause the game. */
	private var _selectCTA						= new Entity();
	/**  */
	private var _brainChunckCallout				= new Entity();
	/**  */
	private var _messageOverlay 				= new Entity();

	/* ---------------------------------------------------------------------------------------- */

	@:keep public function new()
	{
		super();

		Brain.generateAssetIds();
		var dynamicManifest = new Manifest();

		for (listId in Brain.assetIds.keys())
		{
			var list:Array<String> = Brain.assetIds.get(listId);
			var ext:String;
			var id:String;
			//var brainPack = JSEmbedProxy.base + "assets/brain_parts/";
			#if js
			var brainPack = "/brain_parts/";
			#elseif flash
			var brainPack = "assets/brain_parts/";
			#end

			for (i in 0...list.length)
			{
				ext = (listId != "fills") ? ".png" : ".jpg";
				id = list[i];

				dynamicManifest.add(id, brainPack + id + ext);
			}

		}
		// #if js
		// BaseUtils.setupManifest(dynamicManifest);
		// #end

		#if js
		Utils.setupManifest(dynamicManifest);
		#end
		
		dynamicManifests.set("brain_parts", dynamicManifest);

		requiredPacks.push('pause_scene');
		requiredPacks.push('brain_hub_scene');
		requiredPacks.push('global');

		var gt = System.root.get(GameTracker);

		gt.reset();

		if (gt.testAssets)
		{
			var categories = gt.getCategories();

			for (catId in categories.keys())
			{
				var str = 'assets_';
				str += (Data.getCategoryType(catId) == PROPERTY) ? "p_" : "t_";
				str += Std.string(catId).toLowerCase();
				requiredPacks.push(str);
			}

		}

	}

	/* ---------------------------------------------------------------------------------------- */

	override public function assetsReady():Void
	{
		var disposer = owner.get(Disposer);
		var scenePack :AssetPack = _assets.get('brain_hub_scene');
		var brainPack :AssetPack = _assets.get('brain_parts');
		var globalPack :AssetPack = _assets.get('global');
		var gt = System.root.get(GameTracker);

		MusicManager.loopSoundStandard(globalPack, "sfx/utg_gameplay_quiz_musicloopv1", 1);

		if (gt.testAssets)
		{
			var categories = gt.getCategories();

			for (catId in categories.keys())
			{
				var str = 'assets_';
				str += (Data.getCategoryType(catId) == PROPERTY) ? "p_" : "t_";
				str += Std.string(catId).toLowerCase();
				var testPack = _assets.get(str);

				for (question in categories.get(catId))
				{
					if (question.image != null)
					{
						if (testPack.getTexture(question.image, false) == null)
						{
							trace("question.image: '" + question.image + "' missing.");
						}
					}
					if (question.sound != null)
					{
						if (testPack.getSound(question.sound, false) == null)
						{
							trace("question.sound: '" + question.sound + "' missing.");
						}
					}

					for (query in question.queries)
					{
						if (query.image != null)
						{
							if (testPack.getTexture(query.image, false) == null)
							{
								trace("query.image: '" + query.image + "' missing.");
							}
						}
						
					}

					for (option in question.options)
					{
						if (option.image != null)
						{
							if (testPack.getTexture(option.image, false) == null)
							{
								trace("option.image: '" + option.image + "' missing.");
							}

						}
						
					}

				}

			}

		}

		setBackground(new SizeSprite(1366, 768));

		var textures:Array<Texture> = [];

		for (i in 0...12)
		{
			textures.push(globalPack.getTexture("fill_bg"));
		}

		var c_fill = new MultiTextureSprite(textures, 6);
		_backing.addChild(new Entity().add(c_fill));

		var c_vignette = new MultiTextureSprite([globalPack.getTexture("vignette_01"), globalPack.getTexture("vignette_02")]);
		_backing.addChild(new Entity().add(c_vignette));

		var e_confettiLayer = new Entity();
		var c_confettiLayer = new ConfettiLayer(globalPack);
		e_confettiLayer.add(c_confettiLayer);
		_backing.addChild(e_confettiLayer);

		var c_confetti = new ImageSprite(scenePack.getTexture("confetti"));
		c_confetti.setXY(374, 232);
		_confetti.add(c_confetti);
		_container.addChild(_confetti);

		var scores = gt.getTopPsychTraits();

		var width = 300;

		var c_arrow = new ImageSprite(scenePack.getTexture("arrow"));
		c_arrow.setXY(202, 106);
		_arrow.add(c_arrow);
		_container.addChild(_arrow);

		var c_selectCTA = Locale.getField("brainHub.selectCTA", 270, Center);
		c_selectCTA.setXY(5, 14);
		_selectCTA.add(c_selectCTA);
		_arrow.addChild(_selectCTA);

		var btnPause = new BasicButton(globalPack, "ui/pause_btn");
		btnPause.buttonMode.playSound = false;
		_btnPause.add(btnPause);
		_container.addChild(_btnPause);
		disposer.connect1(_btnPause.get(BasicButton).engaged, onPauseButtonClick);

		var c_propertyQuizTypeBtn = new BasicButton(scenePack, "btn_know_the_show");
		_propertyQuizTypeBtn.add(c_propertyQuizTypeBtn);

		var c_categoryQuizTypeBtn = new BasicButton(scenePack, "btn_nick_iq");
		_categoryQuizTypeBtn.add(c_categoryQuizTypeBtn);

		var c_randomQuizBtn = new BasicButton(scenePack, "btn_random");
		_randomQuizBtn.add(c_randomQuizBtn);

		var btns = [c_propertyQuizTypeBtn, c_categoryQuizTypeBtn, c_randomQuizBtn];

		for (i in 0...3)
		{
			btns[i].setXY(274, i*153 + 247);
			btns[i].buttonMode.playSound = false;
			_container.addChild(btns[i].owner);

			if (i%2 == 1) btns[i].x._ += 18;

			function()
			{
				var id = i;

				disposer.connect1(btns[i].engaged, function (_)
				{
					globalPack.getSound("sfx/select_quiz_button").play();

					switch (id)
					{
						case 0:
							gt.setQuizType(PROPERTY, false);
							Scenes.goto(QuizSelectScene);
						case 1:
							gt.setQuizType(TOPIC, false);
							Scenes.goto(QuizSelectScene);
						case 2:
							var categories = Type.allEnums(CategoryId);
							var category = categories[Math.round(Math.random() * categories.length)];
							gt.setQuizType(Data.getCategoryType(category), true);
							gt.generateQuestions(category);
							Scenes.goto(QuestionScene);

					}

				});

			}();

		}

		var c_messageOverlay = new FillSprite(0x000000, AutoFillScene.STANDARD_WIDTH, AutoFillScene.STANDARD_HEIGHT);
		c_messageOverlay.disablePointer();
		c_messageOverlay.alpha._ = 0.0;
		_messageOverlay.add(c_messageOverlay);
		_container.addChild(_messageOverlay);

		var c_head = new Head(scenePack, brainPack);
		_head.add(c_head);
		_container.addChild(_head);
		disposer.connect2(c_head.brain.message, onBrainMessage);

		var c_brainChunckCallout = new BrainChunkCallout(scenePack);
		disposer.connect0(c_brainChunckCallout.hide, onBrainCalloutHide);
		_brainChunckCallout.add(c_brainChunckCallout);
		_container.addChild(_brainChunckCallout);

		_container.addChild(_btnPause);

	}

	/* ---------------------------------------------------------------------------------------- */

	private function onBrainCalloutHide()
	{
		_messageOverlay.get(Sprite).alpha.animateTo(0.0, 0.0);
	}

	/* ---------------------------------------------------------------------------------------- */

	private function onBrainMessage(messageLoc:String, p:Point)
	{
		_brainChunckCallout.get(BrainChunkCallout).show(messageLoc, p);

		_messageOverlay.get(Sprite).alpha.animateTo(0.5, 0.3);
	}

	/* ---------------------------------------------------------------------------------------- */

	private function onPauseButtonClick(e :PointerEvent) :Void
	{
		_head.get(Head).onPause();
		Scenes.push(PauseScene, new FadeTransition(0.2));
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * All positioning code goes here. It will be triggered each time the screen is rotated or the dimensions change.
	 */
	override public function onResize()
	{
		super.onResize();

		_btnPause.right(25).top(25);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	override public function onRemoved()
	{
		//For HTML platform, make sure all sounds are disposed BEFORE unloading assets,
		//because WebAudioSound calls assertNotDisposed() every time get_duration is called,
		//and that apparently continues to occur between onRemoved() and dispose().
		_head.get(Head).disposeSoundsBeforeUnloadingAssets();

		_assets.unload("brain_parts");
		_assets.unload("brain_hub_scene");

		super.onRemoved();
	}
	
}





















