
package s2.client;

import nicksdk.jsembed.JSEmbedProxy;

import flambe.asset.AssetPack;
import flambe.asset.File;
import flambe.asset.Manifest;
import flambe.System;
import flambe.util.Assert;

import s2.client.CommonBootstrap;
import s2.client.Config;
import s2.loading.Assets;
import s2.localization.DParser;
import s2.localization.Locale;
import s2.util.PathUtil;
import s2.util.Utils;

#if flash
import flash.display.LoaderInfo;
#end

import Xml.XmlType;

import nicksdk.AntiPiracy;

using StringTools;

class NickBootstrap extends CommonBootstrap
{
    /** If the external tracking system is supported or not. */
    private var _externalSupported :Bool;
    /** The region to load localization data about. */
    private var _localizationRegion :String;
    /** comment */
    private var _gameName :String = "";
    /** Mostly used for NickJR games. */
    private var _gameProperty :String = "";
    /** The config file. */
    private var _config :Xml;
    /** comment */
    private var _parser :Dynamic->Void;
    /** comment */
    private var _optionsSet :Bool;
    /** comment */
    private var _embedTargetBase:String = null;

    /* ---------------------------------------------------------------------------------------- */

    public function new():Void
    {
        super();

        if (System.external.supported)
        {
            //The following commented out lines will cause base path to be pulled from swf parameters
            //(flashVars/loaderInfo) in Flash, instead of from JSEmbed — which does NOT embed Flash.

            #if js
                _embedTargetBase = JSEmbedProxy.base;
            #end

            #if flash
                //_embedTargetBase = flash.Lib.current.loaderInfo.parameters.base;
                _embedTargetBase = "";
            #end
        }

        _embedTargetBase = (_embedTargetBase != null) ? _embedTargetBase : "";

        setupBasePaths();
    }

    /* ---------------------------------------------------------------------------------------- */
    
    override public function start() :Void
    {
        // Begin loading XML.
        var manifest :Manifest = new Manifest();
        // var manifest :Manifest = Assets.setupManifest();
        var xmlPath :String = "xml/config.xml";

        // if (System.external.supported)
        // {
        //     //#if js
        //     _embedTargetBase = JSEmbedProxy.base;
        //     // #end

        //     // #if flash
        //     // _embedTargetBase = flash.Lib.current.loaderInfo.parameters.base;
        //     // #end
        // }

        //var targetBase = (_embedTargetBase != null) ? _embedTargetBase : "";

        //var sPath :String = targetBase + xmlPath;
        var sPath :String = _embedTargetBase + xmlPath;
        manifest.add(xmlPath, sPath);
        
        // if (Locale.externalBase != null) {
        //     trace("Setting remote..." + Locale.externalBase);
        //     manifest.remoteBase = Locale.externalBase;
        // } else if (Locale.relativeBase != null) {
        //     trace("Setting local" + Locale.relativeBase);
        //     manifest.localBase = Locale.relativeBase;
        // }

        var loader = System.loadAssetPack(manifest);
        loader.get(onConfigLoaded);

        setupBasePaths();
    }

    /* ---------------------------------------------------------------------------------------- */
    
    /**
     * Fired when configuration has finished loading.
     * 
     * @param  pack :AssetPack    The pack with the configuration file.
     * @return      [description]
     */
    private function onConfigLoaded(pack :AssetPack) :Void
    {
        var rawFile :File = pack.getFile( "xml/config.xml" );
        _config = Xml.parse( rawFile.toString() );
        
        if (_parser != null) {
            _parser(_config);
            _parser = null;
        }

        rawFile.dispose();

        var trackingInfo :Xml = _config.elementsNamed("config").next().elementsNamed("tracking").next();
        var trackingEnabled :Bool =  trackingInfo != null && trackingInfo.get("enabled").toString().toLowerCase() == "true";
        _gameName = trackingInfo.elementsNamed("gameName").next().firstChild().toString();
        _gameProperty = trackingInfo.elementsNamed("gameProperty").next() != null ? trackingInfo.elementsNamed("gameProperty").next().firstChild().toString() : "";

        setupTracking(trackingEnabled);

        var locale :Xml = trackingInfo.elementsNamed("locale").next();
        _localizationRegion = locale != null ? locale.firstChild().toString() : null;


        var appendRegion :String = _localizationRegion == null || _localizationRegion == "" ? "" : "_" + _localizationRegion;
        Locale.init( onLocalizationLoaded, new DParser(), "strings/strings" + appendRegion +".xml" );

        #if !debug
        AntiPiracy.checkPiracy(); // Check for piracy.
        #end
    }

    /* ---------------------------------------------------------------------------------------- */
    
    private function setupTracking(trackingEnabled :Bool):Void
    {
        var hasTrackFlashEvent :Bool = false;

        if (trackingEnabled && System.external.supported) {
            
            #if html
                hasTrackFlashEvent = untyped js.Browser.window.trackFlashEvent != null;
            #end
            #if flash
                hasTrackFlashEvent = untyped flash.external.ExternalInterface.call("function(){ return window.trackFlashEvent != null || window.trackFlashEvent != undefined;}");
            #end
        }

        _externalSupported = hasTrackFlashEvent;
    }

    /* ---------------------------------------------------------------------------------------- */
    
    override public function getOptions() :Map<String, Dynamic>
    {
        if (_optionsSet) {
            return _options;
        }

        // Continue to parse the options.
        var options :Xml = _config.elementsNamed("config").next().elementsNamed("options").next();
        var children = options.elements();

        for (child in children) {
            var name :String = child.nodeName;

            if (child.elements().hasNext()) {
                var structure :Dynamic = buildNested(child, {});
                _options.set(child.nodeName, structure);
            } else {
                _options.set(child.nodeName, guessType(child.firstChild().nodeValue));
            }
        }

        _optionsSet = true;
        return _options;
    }

    /* ---------------------------------------------------------------------------------------- */
    
    private function buildNested(node :Xml, parent :Dynamic) :Dynamic
    {
        // Count up the number of names.
        var names :Dynamic = {};
        for (child in node.elements()) {
            if (!Reflect.hasField(names, child.nodeName)) {
                Reflect.setField(names, child.nodeName, 1);
            } else {
                Reflect.setField(names, child.nodeName, Reflect.getProperty(names, child.nodeName) + 1);
            }
        }

        var fields :Array<String> = Reflect.fields(names);
        for (ii in 0...fields.length) {
            var length :Int = Reflect.getProperty(names, fields[ii]);
            var children = node.elementsNamed(fields[ii]);

            // Should be an array..
            if (length > 1) {
                // We'll go through and parse the list.
                var array :Array<Dynamic> = [];
                Reflect.setField(parent, fields[ii], array);
                for (child in children) {
                    if (child.elements().hasNext()) {
                        array.push( buildNested(child, {}) );
                    } else {
                        array.push(guessType(child.firstChild().nodeValue));
                    }
                }
            } else {
                for (child in children) {
                    if (child.elements().hasNext()) {
                        var structure :Dynamic = buildNested(child, {});
                        Reflect.setField(parent, child.nodeName, structure);
                    } else {
                        Reflect.setField(parent, child.nodeName, guessType(child.firstChild().nodeValue));
                    }
                }

            }

        }

        return parent;
    }
    
    /* ---------------------------------------------------------------------------------------- */
    
    private function buildNode(child :Xml, parent :Dynamic) :Void
    {
        if (child.elements().hasNext()) {
            // TODO: Determine if nodes should be in an array or not.
            var structure :Dynamic = buildNested(child, {});
            Reflect.setField(parent, child.nodeName, structure);
        } else {
            Reflect.setField(parent, child.nodeName, guessType(child.firstChild().nodeValue));
        }
    }

    /* ---------------------------------------------------------------------------------------- */
    
    /**
     * Trys to automatically determine the type of value a string is. This is a slow operation.
     * @param  value :String       [description]
     * @return       [description]
     */
    private function guessType(value :String) :Dynamic
    {
        switch (value.toLowerCase()) {
            case "true":
                return true;
            case "false":
                return false;
        }

        var num :Float = Std.parseFloat(value);
        if (!Math.isNaN(num)) {
            return num;
        }
        return value;
    }

    /* ---------------------------------------------------------------------------------------- */
    
    private function onLocalizationLoaded():Void
    {
        complete.emit();
    }

    /* ---------------------------------------------------------------------------------------- */
    
    override public function track(?params :Array<Dynamic>) :Void
    {
        Assert.that(params != null && params.length > 0, "You must pass in the event name as the first parameter.");
        if (_externalSupported) {
            System.external.call('trackFlashEvent', [_gameName, params[0], 'true']);
        }
    }

    /* ---------------------------------------------------------------------------------------- */
    
    private function setupBasePaths():Void
    {        
//#if html

        var httpPattern = ~/^http(s)?:\/\//i;
        if ( _embedTargetBase != null && _embedTargetBase.length > 0)
        {
            if ( httpPattern.match(_embedTargetBase) )
            {
                //var url :String = js.Browser.window.location.href;
                var url:String = Utils.runJSStatement("window.location.href");
                var parts:Array<String> = url.split("/");

                // Remove trailing slashes and files from the URL
                if (parts[parts.length-1] == null || parts[parts.length-1].indexOf(".") > -1) {
                    parts.pop();
                }
                
                //url = parts.join("/");
                url = parts.join("/").split("?")[0];
                var relativePath :String = PathUtil.absoluteToRelative(url, _embedTargetBase);
                if (relativePath != null) {
                    Assets.relativeBase = relativePath + "assets/";
                    Locale.relativeBase = relativePath;
                } else {
                    Assets.externalBase = _embedTargetBase + "assets/";
                    Locale.externalBase = _embedTargetBase;
                }
            }
            else
            {
                Assets.relativeBase = _embedTargetBase + "assets/";
                Locale.relativeBase = _embedTargetBase;
            }

        }
//#end

    }

}