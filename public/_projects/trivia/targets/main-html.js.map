package s2.sound;

import flambe.asset.AssetPack;
import flambe.sound.Playback;
import flambe.sound.Sound;
import flambe.System;
import flambe.util.Value;

class MusicManager 
{
	public static var muted (get, null) :Value<Bool>;
	/** The muted value */
	private static var _muted :Value<Bool>;
	/** The volume for the un-muted state. */
	public static var volume (get, set) :Float;
	private static var _volume :Float = 0;

	/** The currently playing background loop for standard playback modes. */
	private static var bgLoop(default, null) :Playback;
	/** Shortcut for the loop sound method to use. */
	private static var loopSound :AssetPack->String->Float->Void;
	/** If we have already detected if we are using audio hacks or not. */
	private static var _init :Bool = false;
#if js
	/** The reference to an audio tag we are using for sound playback. */
	private static var _audioTag :js.html.AudioElement;
#end

	/* ---------------------------------------------------------------------------------------- */

	public static function loop(pack :AssetPack, path :String, volume :Float = 1) :Void
	{
		var sound :Sound = pack.getSound(path);
		init(sound);
		loopSound(pack, path, volume);
	}

	public static function stop() :Void
	{
		if (bgLoop != null) {
			bgLoop.dispose();
			bgLoop = null;
		}
#if js
		if (_audioTag != null) {
			_audioTag.pause();
		}
#end

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * Checks to make sure the sounds isn't already playing before it starts a new one.
	 */
	public static function loopSoundStandard(pack :AssetPack, path :String, volume :Float) :Void
	{
		_volume = volume;

		if (bgLoop == null || (bgLoop.sound != pack.getSound(path))) {
			if (bgLoop != null) {
				bgLoop.dispose();
			}
			bgLoop = pack.getSound(path).loop(muted._ ? 0 : _volume);

		} else if (bgLoop != null) {
			
			bgLoop.volume.animateTo(muted._ ? 0 : _volume, 0.2);
		}
	}

	/* ---------------------------------------------------------------------------------------- */
	
	private static function get_volume() :Float
	{
		return _volume;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	private static function set_volume(value :Float) :Float
	{
		_volume = value;
#if js
		if (_audioTag != null && !muted._) {
			_audioTag.volume = _volume * System.volume._;
		} else
#end

		if (bgLoop != null && !muted._) {
			bgLoop.volume.animateTo( _volume, 0.2);
		}
		return _volume;
	}

	/* ---------------------------------------------------------------------------------------- */

	private static function get_muted() :Value<Bool>
	{
		if (_muted == null) {
			_muted = new Value<Bool>(false, onMuteChange);
		}

		return _muted;
	}

	/**
	 * Handler for when mute changes.
	 * @param  isMuted :Bool         [description]
	 * @param  _       [description]
	 * @return         [description]
	 */
	private static function onMuteChange(isMuted :Bool, _) :Void
	{
		trace("Mute change " + isMuted);
#if js
		if (_audioTag != null) {
			_audioTag.muted = isMuted;
			_audioTag.volume = isMuted ? 0 : _volume * System.volume._;
		} else
#end
		if (bgLoop != null) {
			bgLoop.volume._ = isMuted ? 0 : _volume;
		}
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * Detects browsers that have audio disabled.
	 * @return [description]
	 */
	private static function init(sound :Sound):Void
	{
		if (!_init) {
			loopSound = loopSoundStandard;
#if js
			if (Std.is(sound, flambe.platform.DummySound)) {
				// No sound support, so we're going to create our own HTML audio player.
				loopSound = loopSoundHack;
				var doc = js.Browser.document;
				_audioTag = doc.createAudioElement();
				_audioTag.id = "flambe_audioTag_hack";
				
				System.hidden.changed.connect(function(isHidden :Bool,_) {
					_audioTag.muted = isHidden;
					_audioTag.volume = isHidden ? 0 : _volume * System.volume._;
				});
				System.volume.changed.connect(function(volume :Float, _){
					_audioTag.volume = _volume * volume;
				});
				doc.body.appendChild(_audioTag);
			}
#end
			_init = true;
		}
	}


#if js

	/* ---------------------------------------------------------------------------------------- */

	private static function loopSoundHack(pack :AssetPack, path :String, volume :Float) :Void
	{	
		_volume = volume;
		_audioTag.volume = muted._ ? 0 : volume * System.volume._;
		_audioTag.autoplay = true;
		_audioTag.loop = true;
		_audioTag.preload = "auto";
		_audioTag.src = findFullSoundURL(pack, path);
		_audioTag.muted = muted._;

		// Play the audio on a pointer event.
		// System.pointer.down.connect(function(event) {
		// 	_audioTag.play();
		// }).once();
	}

	/* ---------------------------------------------------------------------------------------- */

	private static function findFullSoundURL(pack :AssetPack, path :String) :String
	{
		for (entry in pack.manifest) {
			if (entry.name == path) {
				return pack.manifest.getFullURL(entry);
			}
		}
		return null;
	}
#end
}





























