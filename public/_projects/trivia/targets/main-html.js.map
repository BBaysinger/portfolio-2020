
package s2.client;

import flambe.scene.Scene;
import flambe.util.Signal0;
import flambe.util.Value;
import s2.util.Utils;

class Config 
{
	/** If the initialization has happened yet or not. */
	public static var initialized (default, null) :Value<Bool>;
	/** Contains all the logic for tracking and configuration.  */
	private static var _bootstrap :ClientBootstrap;
	/** Options passed in through a config file. */
	public static var options (get, null) :Map<String, Dynamic>;

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Should start the bootstrap process and setup for all client specific tasks, such as localization, configuration loading, and tracking.
	 * 
	 * @param  bootstrap  :ClientBootstrap [description]
	 * @param  ?completed :Void->Void      [description]
	 * @return            [description]
	 */
	public static function init(bootstrap :ClientBootstrap, ?completed :Void->Void) :Void
	{
		if (initialized == null) {
			initialized = new Value<Bool>(false);
		}

		if (!initialized._) {
			bootstrap.complete.connect(function() {
				initialized._ = true;
				if (completed != null) {
					completed();
				}
			}).once();
			_bootstrap = bootstrap;
			bootstrap.start();
		}
	}

	/* ---------------------------------------------------------------------------------------- */
	
	private static function get_options() :Map<String, Dynamic>
	{
		return _bootstrap.getOptions();
	}

	/* ---------------------------------------------------------------------------------------- */
	
	public static function track( ?params :Array<Dynamic> ) :Void
	{
		_bootstrap.track(params);
	}
}

interface ClientBootstrap
{
	/** Called when completed. */
	var complete :Signal0;
	/** Starts the bootstrapping process */
  	function start() :Void;
  	/** Tracking call. Can always be called, and will never throw errors. Turn functionality on and off with XML. */
  	function track( ?params :Array<Dynamic> ) :Void;
  	/** Gets options from our configuration file. */
  	function getOptions() :Map<String, Dynamic>;
}