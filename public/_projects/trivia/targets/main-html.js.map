package s2.util;

import flambe.Entity;
import flambe.System;
import flambe.display.Sprite;
import flambe.math.Point;

/**
 * Class to provide local to global and global to local positioning.
 */
class Positioning {

	/* ---------------------------------------------------------------------------------------- */
	
	public static inline function localToGlobal(entity:Entity, x:Float, y:Float, ?reuse:Point = null):Point
	{
		var s :Sprite = entity.get(Sprite);
		if (s != null) {
			return s.getViewMatrix().transform(x + s.anchorX._, y + s.anchorY._, reuse);
		}
		return null;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	public static inline function globalToLocal(entity:Entity, x:Float, y:Float, ?reuse:Point = null):Point
	{
		var s:Sprite = entity.get(Sprite);
		reuse = reuse == null ? new Point(x, y) : reuse;
		if (s != null) {
			s.getViewMatrix().inverseTransform(x, y, reuse);
			reuse.x -= s.anchorX._;
			reuse.y -= s.anchorY._;
		}
		return reuse;
	}

}