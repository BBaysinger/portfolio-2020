package com.nick.ultimatetrivia.components.question;

import flambe.Entity;
import flambe.Disposer;
import flambe.asset.AssetPack;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.display.Texture;

import s2.scene.AutoFillScene;
import s2.ui.BasicButton;

import com.nick.ultimatetrivia.Question;

/**
 * Controls how the questions are displayed.
 * ...
 * @author Seven2
 */
class ImageOptionQuestionDisplay extends QuestionDisplay
{

	/* ---------------------------------------------------------------------------------------- */

	public function new(scenePack:AssetPack, quizPack:AssetPack, globalPack:AssetPack, question:Question)
	{
		super(scenePack, quizPack, globalPack, question);
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		super.onAdded();
	}

	/* ---------------------------------------------------------------------------------------- */

	override private function build()
	{
		var disposer = owner.get(Disposer);

		var c_option:BasicButton;
		var option:Entity;
		//var i:Int = 0;

		var centerX:Float = AutoFillScene.STANDARD_WIDTH/2;
		var spacing = 243;


		for (i in 0..._oQuestion.options.length)
		{
			if (_oQuestion.options[i].image == null)
			{
				c_option = new BasicButton(_scenePack, "missing_image_option");
			}
			else
			{
				c_option = new BasicButton(_quizPack, _oQuestion.options[i].image);
			}

			c_option.maxScale = 1.06;
			c_option.setXY(centerX + spacing * _order[i] - ((_oQuestion.options.length-1)/2) * spacing, 495);

			function ()
			{
				var num = i;
				var opt = c_option;
				disposer.connect1(c_option.engaged, function (_) {selectOption(num);});
			}();

			option = new Entity();
			option.add(c_option);
			_options.push(option);

			owner.addChild(option);

			var c_frame:ImageSprite = new ImageSprite(_scenePack.getTexture("frame_" + _order[i]));

			c_frame.x._ = -6;
			c_frame.y._ = 4;

			c_frame.centerAnchor();
			option.firstChild.addChild(new Entity().add(c_frame));
			
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	override private function selectOption(optionIndex:Int, queryIndex:Int = 0)
	{
		_oQuestion.queries[queryIndex].setSelected(_oQuestion.options[optionIndex]);
	}

}























