package com.nick.ultimatetrivia.components;

import flambe.Component;
import flambe.Disposer;
import flambe.Entity;
import flambe.System;
import flambe.display.Sprite;
import flambe.display.ImageSprite;
import flambe.display.Texture;
import flambe.asset.AssetPack;
import flambe.swf.MovieSprite;
import flambe.swf.Library;
import flambe.swf.MoviePlayer;
import flambe.display.BlendMode;
import flambe.animation.Sine;
import flambe.sound.Playback;
import flambe.animation.AnimatedFloat;

import s2.scene.AutoFillScene;
import s2.util.TimeUtil;
import s2.util.Utils;

import com.nick.ultimatetrivia.components.Brain;
import com.nick.ultimatetrivia.Data;

class Head extends Component
{
	/**  */
	private var _scenePack 				:AssetPack;
	/**  */
	private var _brainPack 				:AssetPack;
	/**  */
	private var _animations 			= new Map<AnimationIds, Entity>();
	/**  */
	private var _head 					= new Entity();
	/**  */
	private var _brain 					= new Entity();
	/**  */
	private var _currAnimation 			:AnimationIds;
	/**  */
	private var _animationUnder 		= new Entity();
	/**  */
	private var _animationOver  		= new Entity();
	/**  */
	private var _animationTiming 		:AnimatedFloat;
	/**  */
	private var _headPlaying	 		:Bool;
	/**  */
	private var _snd					:Playback;
	/**  */
	public var brain(get_brain, null) 	:Brain;
	/**  */
	private var soundDisposer			:Disposer = new Disposer();
	/**  */
	private var _animationIndex 		:Int = -1;
	/**  */
	private var _animationIds 			:Array<AnimationIds>;

	/* ---------------------------------------------------------------------------------------- */

	public function new(scenePack:AssetPack, brainPack:AssetPack)
	{
		_scenePack = scenePack;
		_brainPack = brainPack;
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		super.onAdded();

		var disposer = owner.get(Disposer);
        if (disposer == null) owner.add(disposer = new Disposer());

		var timeUtil = owner.get(TimeUtil);
        if (timeUtil == null) owner.add(timeUtil = new TimeUtil());

        var hubAnimationIds = Data.getHubAnimationsIds();
		var lib = new Library(_scenePack, "lib");
		var gt = System.root.get(GameTracker);
		var catIds = Type.allEnums(CategoryId);

		var testAnimationsIds = Type.allEnums(AnimationIds);
		testAnimationsIds.splice(testAnimationsIds.indexOf(Head_Idle), 1);

		//Make sure they all exist, as defined.
		if (gt.testAssets)
		{
			for (i in 0...testAnimationsIds.length)
			{
				_scenePack.getSound("sfx/animations/animation_" + Std.string(testAnimationsIds[i]).toLowerCase());
			}
		}

		owner.addChild(_animationUnder);

		var c_headAnimations = new MoviePlayer(lib);
		c_headAnimations.loop(Std.string(Head_Idle));
		_head.add(c_headAnimations);
		owner.addChild(_head);

		var brain = new Brain(_scenePack, _brainPack);
		_brain.add(brain);
		owner.addChild(_brain);

		owner.addChild(_animationOver);

		var e_anim:Entity;
		var c_anim:MovieSprite;

		for (hubAnimationId in hubAnimationIds)
		{
			e_anim = new Entity();
			var c_anim = lib.createMovie(Std.string(hubAnimationId));
			c_anim.paused = true;
			c_anim.visible = false;
			c_anim.disablePointer();
			e_anim.add(c_anim);
			_animations.set(hubAnimationId, e_anim);

			if (hubAnimationId == Mohawk)
			{
				_animationUnder.addChild(e_anim);
			}
			else
			{
				_animationOver.addChild(e_anim);
			}
			
		}

		_animationIds = gt.getAvailableAnimations();
		_animationIds.sort(Utils.sortArrayRandom);
		_animationIds.push(Eye_Look);

		var numAnims = Type.allEnums(AnimationIds).length;

		_animationIndex = 0;
		var adj = (numAnims - _animationIds.length) * 0.2;
		_animationTiming = new AnimatedFloat(6 + adj);

		timeUtil.timeout(nextAnimation, 1);

	}

	/* ---------------------------------------------------------------------------------------- */

	private function nextAnimation()
	{
		var gt = System.root.get(GameTracker);
		var disposer = owner.get(Disposer);

		_animationIndex = (_animationIndex == _animationIds.length - 1) ? 0 : _animationIndex + 1;

		_currAnimation = _animationIds[_animationIndex];

		var sSoundId:String = "sfx/animations/animation_" + Std.string(_currAnimation).toLowerCase();

		//Keep for testing, run through all the animations, and make sure they all work.
		// if (_currAnimation != null)
		// {
		// 	var index = animationIds.indexOf(_currAnimation);

		// 	if (index == animationIds.length - 1)
		// 	{
		// 		index = -1;
		// 	}

		// 	_currAnimation = animationIds[index + 1];

		// }
		// else
		// {
		// 	_currAnimation = animationIds[0];
		// }

		if (Data.getHubAnimationsIds().indexOf(_currAnimation) != -1)
		{
			var animation = _animations.get(_currAnimation);
			var c_animation = animation.get(MovieSprite);
			c_animation.paused = false;
			c_animation.visible = true;

			var animationTime = 3;

			if (_currAnimation == Atom || _currAnimation == Flex_Arm)
			{
				if (Math.random() < .5)//Left/Right
				{
					if (Math.random() < .5)
					{
						c_animation.x._ = 0;
						c_animation.x.animateTo(AutoFillScene.STANDARD_WIDTH, animationTime);
					}
					else
					{
						c_animation.x._ = AutoFillScene.STANDARD_WIDTH;
						c_animation.x.animateTo(0, animationTime);
					}

					c_animation.y._ = Math.random() * AutoFillScene.STANDARD_HEIGHT;
					c_animation.y.animateTo(Math.random() * AutoFillScene.STANDARD_HEIGHT, animationTime);

				}
				else//Top/Bottom
				{
					if (Math.random() < .5)
					{
						c_animation.y._ = 0;
						c_animation.y.animateTo(AutoFillScene.STANDARD_HEIGHT, animationTime);
					}
					else
					{
						c_animation.y._ = AutoFillScene.STANDARD_HEIGHT;
						c_animation.y.animateTo(0, animationTime);
					}

					c_animation.x._ = Math.random() * AutoFillScene.STANDARD_WIDTH;
					c_animation.x.animateTo(Math.random() * AutoFillScene.STANDARD_WIDTH, animationTime);

				}

				var snd = _snd = _scenePack.getSound(sSoundId).loop();
				soundDisposer.add(_snd);

				owner.get(TimeUtil).timeout(function ()
				{
					snd.dispose();

					c_animation.paused = true;
					c_animation.position = 0;
					c_animation.visible = false;
				}, animationTime);
				
			}
			else
			{
				_snd = _scenePack.getSound(sSoundId).play();
				soundDisposer.add(_snd);

				switch(_currAnimation)
				{
					case Mohawk, Hearts:
						_snd.volume._ = 0.6;
					default:
				}

				disposer.connect0(c_animation.looped, function ()
				{
					c_animation.paused = true;
					c_animation.position = 0;
					c_animation.visible = false;
				});
			}

			owner.get(TimeUtil).timeout(nextAnimation, _animationTiming._);
		}
		else
		{
			 if (!_headPlaying)
			 {
			 	_snd = _scenePack.getSound(sSoundId).play();
			 	soundDisposer.add(_snd);

				_headPlaying = true;
				_head.get(MoviePlayer).play(Std.string(_currAnimation));
				_head.get(MoviePlayer).movie._.disablePointer();
				disposer.connect0(_head.get(MoviePlayer).movie._.looped, function ()
				{
					_headPlaying = false;
				});

				owner.get(TimeUtil).timeout(nextAnimation, _animationTiming._);
			}
			else
			{
				//If there's a head animation already playing, rerun the function to
				//so a different animations will be selected.
				nextAnimation();
			}

		}

	}

	/* ---------------------------------------------------------------------------------------- */

	public function get_brain():Brain
	{
		return _brain.get(Brain);
	}

	/* ---------------------------------------------------------------------------------------- */

	public static function getMaskedTexture(image:Texture, mask:Texture, destX:Float = 0, destY:Float = 0):Texture
	{
	    var texture:Texture = System.renderer.createTexture(image.width, image.height); 
	    var graphics = texture.graphics;
	    graphics.save();
	    graphics.drawTexture(image, 0, 0);
	    graphics.setBlendMode(BlendMode.Mask);
	    graphics.drawTexture(mask, destX, destY);
	    graphics.restore();
	    return texture;
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onUpdate(dt:Float)
	{
		super.onUpdate(dt);

		_animationTiming.update(dt);
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* For HTML platform, make sure all sounds are disposed BEFORE unloading assets,
	* because WebAudioSound calls assertNotDisposed() every time get_duration is called,
	* and that apparently continues to occur between onRemoved() and dispose().
	*/
	public function disposeSoundsBeforeUnloadingAssets()
	{
		soundDisposer.dispose();
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onRemoved()
	{
		owner.get(TimeUtil).clearAll();

		super.onRemoved();
	}

	/* ---------------------------------------------------------------------------------------- */

	public function onPause()
	{
		soundDisposer.dispose();
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function dispose()
	{
		super.dispose();

		_scenePack = null;
		_brainPack = null;
	}

}






























