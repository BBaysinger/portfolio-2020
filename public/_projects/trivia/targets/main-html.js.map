package;

import com.nick.ultimatetrivia.components.GameTracker;
import com.nick.ultimatetrivia.scenes.*;
import flambesdk.BaseUtils;

import flambe.asset.AssetPack;
import flambe.asset.Manifest;
import flambe.display.FillSprite;
import flambe.display.ImageSprite;
import flambe.Entity;
import flambe.scene.FadeTransition;
import flambe.scene.Scene;
import flambe.SpeedAdjuster;
import flambe.System;

import s2.client.Config;
import s2.client.NickBootstrap;
import s2.display.SwapSprite;
import s2.loading.Assets;
import s2.scene.BoxTransition;
import s2.scene.DropTransition;
import s2.scene.MovieTransition;
import s2.scene.PreloadScene;
import s2.scene.Scenes;
import s2.scene.SwapPreloadScene;
import s2.scene.CustomPreloadScene;
import s2.util.URLParser;
import s2.util.Utils;
import s2.util.Sniffer;
import s2.ui.TextButton;

using s2.display.LayoutUtil;

/**
 * 
 * Seven2 game template.
 * 
 * @author Seven2 Interactive (http://www.seven2.net)
 */
class Main
{
    /** Holds the turn template when activated.  */
    public static var resizeScreen :Entity;
    /** Holds the standard asset pack */
    public static var bootstrapPack :AssetPack;

    private static function onSuccess (pack :AssetPack)
    {
        bootstrapPack = pack;

        //#if html
        if (System.touch.supported)
        {
            System.touch.down.connect(function(e){
                bootstrapPack.getSound('empty').play().dispose();
            }).once();
            System.touch.up.connect(function(e){
                bootstrapPack.getSound('empty').play().dispose();
            }).once();
        }
        else
        {
            bootstrapPack.getSound('empty').dispose(); // Unload it immediately.
        }
        //#end

        System.stage.resize.connect(onResize);
        System.root.add(new GameTracker());

        Scenes.defaultTransition(new FadeTransition(0.2));
        //Scenes.init(new PreloadScene(pack));
        Scenes.init(new CustomPreloadScene(pack));

        #if !debug
            Scenes.goto(TitleScene); // Go to the title scene for release builds no matter what.
        #else
            setupDebugInfo(); // Scrape query strings for debugging information.
        #end
        onResize();
    }

    
#if debug
    /* ---------------------------------------------------------------------------------------- */

    /**
     * Sets up some environment variables only on development versions of the game.
     */
    public static function setupDebugInfo()
    {
        var url = s2.util.URLParser.fromBrowser();

        if (url.query.exists("wipedata")) {
            System.storage.clear();
            System.root.add(new GameTracker());
        }
        // Remember if we muted the volume or not.
        System.volume._ = System.storage.get("muted", false) ? 0 : 1;

        System.volume.changed.connect(function(value, prev) {
            if (value != prev) {            
                if (value == 0) {
                    System.storage.set("muted", true);
                } else if (value == 1) {
                    System.storage.set("muted", false);
                }
            }
        });

        if (url.query.exists("scene")) {
            var scenes :Dynamic = {
                "game" :QuestionScene,
                "title" :TitleScene,
                "select" :QuizSelectScene,
                "results" :ResultsScene,
                "brain" :BrainHubScene,
                //"instructions" :InstructionScene,
            }

            var path :String = url.query.get("scene");
            var scenePath :Class<Scene> = Reflect.getProperty(scenes, path);

            Scenes.goto(scenePath);
        } else {
            Scenes.goto(TitleScene);
        }

    }

#end

    /* ---------------------------------------------------------------------------------------- */

    /**
     * Winds up all platform-specifit stuff.
     */
    private static function main ()
    {
        System.init();
		
		BaseUtils.setupBaseURL();

        Config.init(new NickBootstrap(), localizationLoaded);

        TextButton.OFFSET_XY.x = 10;
    }

    /* ---------------------------------------------------------------------------------------- */

    /**
     * Handler for when the localization for the game has finished loading.
     * @return [description]
     */
    private static function localizationLoaded():Void
    {
        var loader = System.loadAssetPack(Assets.getManifest("bootstrap"));
        loader.get(onSuccess);
    }


    /* ---------------------------------------------------------------------------------------- */

    /**
     * Handles screen resize events, and loads the turn template if needed.
     */
    private static function onResize():Void
    {
        if (Scenes.director == null || Scenes.director.owner == null)
            return;

        if (resizeScreen != null)
        {
            resizeScreen.dispose();
            resizeScreen = null;
        }   
        
        if (System.stage.height > System.stage.width)
        {
            var sImageName:String = (System.stage.width > 640) ? 'orientation_ipad' : 'orientation_iphone';
            System.root.add(new SpeedAdjuster(0)); // Pause the execution of everything.
            
            resizeScreen = new Entity()
                .add(new FillSprite(0x000000, System.stage.width, System.stage.height))
                    .addChild(new Entity()
                        .add(new ImageSprite(bootstrapPack.getTexture(sImageName))).center());
            
            System.root.addChild(resizeScreen);
        }
        else
        {
            var adjuster :SpeedAdjuster = System.root.get(SpeedAdjuster);
            if (adjuster != null)
                adjuster.dispose();
        }

    }
    
}
















