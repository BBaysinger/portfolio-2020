package s2.display;

import flambe.display.PatternSprite;
import flambe.display.Sprite;
import flambe.Entity;
import flambe.math.Matrix;
import flambe.math.Point;
import flambe.math.Rectangle;
import flambe.System;
import flambe.math.FMath;
import s2.util.MatrixUtil;
import s2.util.Utils;
import s2.scene.AutoFillScene;

using s2.util.Positioning;

/**
 * Utility to align sprites
 * @author Kipp Ashford
 */
class LayoutUtil 
{
	/**
	 * Aligns a sprite to the left.
	 * 
	 * @param  entity  [description]
	 * @param  ?offset [description]
	 * @return         [description]
	 */
	public static function left(entity :Entity, ?offset:Float = 0, ?units :Units):Entity
	{
		units = units == null ? px : percent;
		var s :Sprite = getSprite(entity);
		s.x._ = 0;
		var b :Rectangle = Sprite.getBounds(entity);
		var localScaleX :Float = MatrixUtil.getScaleX(s.getLocalMatrix());
		var edge :Float = units == px ? offset : System.stage.width * offset;
		var pt :Point = entity.globalToLocal( edge, 0 );
		s.x._ = pt.x * localScaleX - b.x;
		
		return entity;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Aligns a sprite to the right edge of the screen.
	 * 
	 * @param  entity  The entity to pin to an edge.
	 * @param  ?offset The units from the right edge to offset (in either pixels or percentage)
	 * @param  ?units  Accepts either px (default) or percentage.
	 * @return         [description]
	 */
	public static function right(entity:Entity, ?offset:Float = 0, ?units :Units):Entity
	{
		units = units == null ? px : percent;
		var s :Sprite = getSprite(entity);
		s.x._ = 0;
		var b :Rectangle = Sprite.getBounds(entity);
		var localScaleX :Float = MatrixUtil.getScaleX(s.getLocalMatrix());

		var edge :Float = units == px ? System.stage.width - offset : System.stage.width - (System.stage.width * offset);
		var pt :Point = entity.globalToLocal( edge, 0 );
		s.x._ = pt.x * localScaleX - b.x - b.width;

		return entity;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Aligns an entity to the top of the screen.
	 * 
	 * @param  entity  [description]
	 * @param  ?offset [description]
	 * @param  ?units  :Units        [description]
	 * @return         [description]
	 */
	public static function top(entity:Entity, ?offset:Float = 0, ?units :Units):Entity
	{
		units = units == null ? px : percent;

		var s :Sprite = getSprite(entity);
		s.y._ = 0;
		var b :Rectangle = Sprite.getBounds(entity);
		var localScaleY :Float = MatrixUtil.getScaleY(s.getLocalMatrix());
		var edge :Float = units == px ? offset : System.stage.height * offset;
		var pt :Point = entity.globalToLocal( 0, edge );
		s.y._ = pt.y * localScaleY - b.y;

		return entity;
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Sticks a sprite to the bottom of the screen.
	 * 
	 * @param  entity  :Entity       The entity to stick to the bottom edge.
	 * @param  ?offset :Float        The amount of padding in either px (default) from the bottom, or a percentage.
	 * @param  ?units  :Units        Units to use (either pixels or a percentage).
	 * @return         [description]
	 */
	public static function bottom(entity :Entity, ?offset :Float = 0, ?units :Units):Entity
	{
		units = units == null ? px : percent;
		var s :Sprite = getSprite(entity);
		s.y._ = 0;
		var localScaleY :Float = MatrixUtil.getScaleY(s.getLocalMatrix());
		var b :Rectangle = Sprite.getBounds(entity);
		var edge :Float = units == px ? System.stage.height - offset : System.stage.height - (System.stage.height * offset);
		var pt :Point = entity.globalToLocal( 0, edge );

		s.y._ = (pt.y * localScaleY) - b.y - b.height;
		return entity;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Centers an entity in the center of the screen along the X axis.
	 * 
	 * @param  entity  [description]
	 * @param  ?offset [description]
	 * @param  ?units  :Units        [description]
	 * @return         [description]
	 */
	public static function centerX(entity:Entity, ?offset:Float = 0, ?units :Units):Entity
	{
		units = units == null ? px : percent;
		var s :Sprite = getSprite(entity);
		s.x._ = 0;
		var localScaleX :Float = MatrixUtil.getScaleX(s.getLocalMatrix());
		var b :Rectangle = Sprite.getBounds(entity);
		var edge :Float = units == px ? (System.stage.width * .5) + offset :
			System.stage.width * .5 + (System.stage.width * offset * .5);
		var pt :Point = entity.globalToLocal( edge, 0 );
		s.x._ = Math.round( pt.x * localScaleX - (b.width * .5) - b.x );

		return entity;
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Centers an entity in the middle of the screen along the Y axis.
	 * 
	 * @param  entity  [description]
	 * @param  ?offset [description]
	 * @param  ?units  :Units        [description]
	 * @return         [description]
	 */
	public static function centerY(entity:Entity, ?offset:Float = 0, ?units :Units):Entity
	{
		units = units == null ? px : percent;
		var s :Sprite = getSprite(entity);
		s.y._ = 0;
		var b :Rectangle = Sprite.getBounds(entity);
		var localScaleY :Float = MatrixUtil.getScaleY(s.getLocalMatrix());
		var edge :Float = units == px ? (System.stage.height * .5) + offset :
			System.stage.height * .5 + (System.stage.height * offset * .5);
		var pt :Point = entity.globalToLocal( 0, edge );
		s.y._ = Math.round( pt.y * localScaleY - (b.height * .5) - b.y );
		
		return entity;
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Centers the entity on stage.
	 * @param	entity
	 * @param	?offsetX
	 * @param	?offsetY
	 * @return
	 */
	public static function center(entity:Entity, ?offsetX:Float = 0, ?offsetY:Float = 0, ?units :Units):Entity
	{
		centerX(entity, offsetX);
		return centerY(entity, offsetY);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Puts an entity below another entity.
	 * 
	 * @param	entity	The entity to position.
	 * @param	other	The other entity
	 * @param	offset	The amount of space to offset.
	 * 
	 * @return
	 */
	public static function below(entity:Entity, other:Entity, ?offset:Float = 0):Entity
	{
		var s:Sprite = entity.get(Sprite);
		var o:Sprite = other.get(Sprite);
		if (s != null && o != null) {
			s.y._ = o.y._ + spriteBottom(o) + spriteAnchorY(o) + offset + spriteAnchorY(s);
			//s.y._ = o.y._ + spriteBottom(o) + spriteAnchorY(o) + spriteBottom(s) + offset - spriteAnchorY(s);
		}
		return entity;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Puts an entity below another entity.
	 * 
	 * @param	entity	The entity to position.
	 * @param	other	The other entity
	 * @param	offset	The amount of space to offset.
	 * 
	 * @return
	 */
	public static function above(entity:Entity, other:Entity, ?offset:Float = 0):Entity
	{
		var s:Sprite = entity.get(Sprite);
		var o:Sprite = other.get(Sprite);
		if (s != null && o != null)
		{
			s.y._ = o.y._ - spriteAnchorY(o) - offset - spriteAnchorY(s);
		}
		return entity;
	}

	/* ---------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	public static function leftOf(entity:Entity, other:Entity, ?offset:Float = 0 ):Entity 
	{
		var s:Sprite = entity.get(Sprite);
		var o:Sprite = other.get(Sprite);

		if (s != null && o != null)
			s.x._ = o.x._ + spriteAnchorX(o) - offset - spriteAnchorX(s) - spriteRight(s);
		
		return entity;
	}
	
	/* ---------------------------------------------------------------------------- */
	
	/**
	 * Aligns an object to the right of another. 
	 */
	public static function rightOf(entity:Entity, other:Entity, ?offset:Float = 0 ):Entity 
	{
		var s:Sprite = entity.get(Sprite), o:Sprite = other.get(Sprite);

		if (s != null && o != null) {
			var b2:Rectangle = Sprite.getBounds(other);
			s.x._ = b2.x + b2.width + spriteAnchorX(s) + offset;
		}
		
		return entity;
	}
	/* ---------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	public static function matchPosition(entity:Entity, other:Entity, ?offsetX:Float = 0, ?offsetY:Float = 0 ):Entity 
	{
		var s:Sprite = entity.get(Sprite);
		var o:Sprite = other.get(Sprite);

		if (s != null && o != null)
		{
			s.x._ = o.x._ - spriteAnchorX(o) + spriteAnchorX(s) + offsetX;
			s.y._ = o.y._ - spriteAnchorY(o) + spriteAnchorY(s) + offsetY;
		}
		return entity;
	}
	
	/**
	 * Changes the size of one entity using the size of another entity.
	 * 
	 * @param  entity :Entity       [description]
	 * @param  other  :Entity       [description]
	 * @return        [description]
	 */
	public static function matchSize(entity :Entity, other :Entity, ?useBounds :Bool = false) :Entity
	{
		var s :Sprite = getSprite(entity);
		var o :Sprite = getSprite(other);

		if (!useBounds) {
			s.setScaleXY( o.getNaturalWidth() / s.getNaturalWidth(), o.getNaturalHeight() / s.getNaturalHeight() );
		}
		return entity;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Centers the entity in it's parent along the X axis.
	 * 
	 * @param	entity
	 * @param	?offset
	 * @return
	 */
	public static function centerParentX(entity:Entity, ?offset:Float = 0):Entity
	{
		var s:Sprite = entity.get(Sprite);
		var ps:Sprite = entity.parent != null ? entity.parent.get(Sprite) : null;		
		if (s != null && ps != null) {
			var pv:Bool = s.visible;
			s.visible = false;
			var pb:Rectangle = Sprite.getBounds(ps.owner);
			s.visible = pv;
			s.x._ = Math.round((pb.width * .5) - (spriteRight(s) * .5) + spriteAnchorX(s) - offset);
		}
			
		return entity;
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Centers the entity in its parent along the Y axis.
	 * 
	 * @param	entity
	 * @param	?offset
	 * @return
	 */
	public static function centerParentY(entity:Entity, ?offset:Float = 0):Entity
	{
		var s:Sprite = entity.get(Sprite);
		var ps:Sprite = entity.parent != null ? entity.parent.get(Sprite) : null;
		
		if (s != null && ps != null)
			s.y._ = Math.round((ps.getNaturalHeight() * .5) - (spriteBottom(s) * .5) + spriteAnchorY(s) - offset);
		
		return entity;
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Centers the entity inside its parent entity.
	 * 
	 * @param	entity
	 * @param	?offsetX
	 * @param	?offsetY
	 * @return
	 */
	public static function centerParent(entity:Entity, ?offsetX:Float = 0, ?offsetY:Float = 0):Entity
	{
		centerParentX(entity, offsetX);
		return centerParentY(entity, offsetY);
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * @param	entity	The entity to scale
	 * @param	resizeAtPercentW	The threshold percentage of the stage width to start resizing at.
	 * @param	resizeAtPercentH	The threshold percentage of the stage height to start resizing at.
	 * @param	?minScale	The minimum scale to reach.
	 * @param	?width	The width to use instead of getNaturalWidth()
	 * @param	?height	The height to use instead of getNaturalHeight()
	 */
	public static function scale(entity:Entity, resizeAtPercentW:Float, resizeAtPercentH:Float, ?minScale:Float = 0, ?width:Float = 0, ?height:Float = 0):Entity
	{
		var s :Sprite = getSprite(entity);
		// var mat :Matrix = s.getViewMatrix();
		// var scaleX :Float = MatrixUtil.getScaleX(mat);
		// var scaleY :Float = MatrixUtil.getScaleY(mat);
		s.setScale(1);

		var bounds :Rectangle = Sprite.getBounds(entity);
		var w: Float = width != 0 ? width : bounds.width; // The width of the sprite or its override
		var h :Float = height != 0 ? height : bounds.height; // The height of the sprite or its override
		var sw :Float = System.stage.width;
		var sh :Float = System.stage.height;
		var pW :Float = w / sw; // The percentage of the stage width.
		var pH :Float = h / sh; // The percentage of the stage height.
		
		var scale:Float = FMath.min(pW < resizeAtPercentW ? 1 : (sw * resizeAtPercentW) / w, pH < resizeAtPercentH ? 1 : (sh * resizeAtPercentH) / h);
		s.setScale( scale >= minScale ? scale : minScale );
		// if (spriteAdded) {
		// 	entity.remove(s);
		// }
		return entity;
	}
	
	/* ---------------------------------------------------------------------------------------- */

	/**
	 * Utility to make sure that the entity we get always has a sprite.
	 * @param  entity :Entity       [description]
	 * @return        [description]
	 */
	@:noUsing public inline static function getSprite(entity :Entity) :Sprite
	{
		var s :Sprite = entity.get(Sprite);

		if (s == null) {
			entity.add( s = new Sprite() );
		}

		return s;
	}		

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Returns the right edge of a sprite accounting for scale, but not accounting for x coordinate or anchor point.
	 * @param	s
	 * @return
	 */
	public static function spriteRight(s:Sprite):Float
	{
		var b:Rectangle = Sprite.getBounds(s.owner);
		return b.x + b.width;
	}
	
	public static function spriteBottom(s:Sprite):Float
	{
		var b:Rectangle = Sprite.getBounds(s.owner);
		return b.y + b.height;
	}
	
	public static function spriteAnchorX(s:Sprite):Float
	{
		// return Sprite.getBounds(s.owner).x;
		return s.anchorX._ * s.scaleX._;
	}
	
	public static function spriteAnchorY(s:Sprite):Float
	{
		// return Sprite.getBounds(s.owner).y;
		return s.anchorY._ * s.scaleY._;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Makes the sprite in the given Entity fill the entire screen.
	 * @param  entity Use this sprite to fill the screen.
	 * @param  bFitScreen Makes letterboxing (bars on left/right) for screen ratios that are wider than the base size. Defaults to true. Setting to false will fill screen by width when stage gets too wide.
	 * @return        [description]
	 */
	public static function fillScreen(entity:Entity, ?bFitScreen:Bool = true):Entity
	{
		var s:Sprite = getSprite(entity);
		var sW:Float = System.stage.width;
		var sH:Float = System.stage.height;

		//var baseSizeWidest = System.stage.height * (Utils.baseWidth/Utils.baseHeight);
		var baseSizeWidest = System.stage.height * (AutoFillScene.STANDARD_WIDTH/AutoFillScene.STANDARD_HEIGHT);
		var useWidth = (bFitScreen) ? Math.min(baseSizeWidest, sW) : sW;
		//This didn't work.
		//var nScale:Float = FMath.max(sW / Sprite.getBounds(s.owner).width, sH / Sprite.getBounds(s.owner).height);
		var nScale:Float = FMath.max(useWidth / s.getNaturalWidth(), sH / s.getNaturalHeight());
		s.setScale(nScale);
		// s.setXY(sW * 0.5, sH * 0.5);

		return entity;
	}

	/* ---------------------------------------------------------------------------------------- */

}

enum Units
{
	px; percent;
}