import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.Disposer;
import flambe.Entity;
import flambe.input.PointerEvent;
import flambe.scene.Scene;
import flambe.System;
import flambe.math.FMath;
import flambe.animation.Ease;
import flambe.math.Point;
import flambe.scene.FadeTransition;
import flambe.display.Texture;
import flambe.animation.AnimatedFloat;

import s2.behavior.Damping;
import s2.loading.Assets;
import s2.display.MultiTextureSprite;
import s2.ui.TextButton;
import s2.ui.BasicButton;
import s2.ui.TextFluidButton;
import s2.localization.Locale;
import s2.scene.AutoFillScene;
import s2.scene.Scenes;
import s2.util.Utils;
import s2.display.SizeSprite;

import com.nick.ultimatetrivia.Question;
import com.nick.ultimatetrivia.Data;
import com.nick.ultimatetrivia.components.Fling2;
import com.nick.ultimatetrivia.scenes.QuestionScene;
import com.nick.ultimatetrivia.scenes.PauseScene;
import com.nick.ultimatetrivia.components.GameTracker;
import com.nick.ultimatetrivia.components.Heading;
import com.nick.ultimatetrivia.components.Scrolldum;

using s2.display.LayoutUtil;
using Lambda;

/**
 * ...
 * @author Seven2
 */
class QuizSelectScene extends InGameScene
{	
	/**  */
	private static inline var H_SPACING 		:Int = 310;
	/**  */
	private static inline var GROUP_SIZE 		:Int = 5;
	/**  */
	private var _btns 							= new Array<Entity>();
	/**  */
	private var _navBtns						= new Array<Entity>();
	/**  */
	private var _btnHolder						= new Entity();
	/**  */
	private var _currentPage					:Int = 0;
	/**  */
	private var _categories 					:Array<CategoryId>;

	/* ---------------------------------------------------------------------------------------- */

	@:keep public function new()
	{
		super();

		var gt = System.root.get(GameTracker);

		_headLocale = "global.quizType_" + Std.string(gt.quizType).toLowerCase();

		requiredPacks.push('quiz_select_scene');
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function assetsReady():Void
	{	
		super.assetsReady();

		var disposer :Disposer = owner.get(Disposer);
		var pack :AssetPack = _assets.get('quiz_select_scene');
		var globalPack :AssetPack = _assets.get('global');

		var c_btnHolder:Sprite = new Sprite();
		c_btnHolder.x._ = -800;
		c_btnHolder.x.animateTo(370, 1.5, Ease.backOut);
		_btnHolder.add(c_btnHolder);
		_backing.addChild(_btnHolder);

		var gt = System.root.get(GameTracker);
		var btn:Entity;
		var c_btn:TextButton;
		var pos:Int;
		var coin:Entity;
		var icon:Entity;
		var wrapWidth:Int = 400;

		_categories = gt.getCategoryIds();

		for (i in 0..._categories.length)
		{
			pos = i%GROUP_SIZE;

			//Quick fix by JMELT to check if last button is the same color as the first.
			//If it is then set the position +2;
			if(i == _categories.length - 1) {
				if(i%GROUP_SIZE == 0)
					pos = 2;
			} 

			_btns[i] = btn = new Entity();

			c_btn = new TextButton(pack, "ui/btn" + pos, "quizSelect.btn");
			c_btn.buttonMode.playSound = false;
			c_btn.setText(Locale.getFormat("categoryNames." + Std.string(_categories[i]).toLowerCase()).text);
			c_btn.textSprite.wrapWidth._ = wrapWidth;
			c_btn.textSprite.align = Center;
			c_btn.setXY(i * H_SPACING, 460);
			c_btn.textSprite.centerAnchor();
			btn.add(c_btn);

			c_btn.textSprite.x._ = 7;
			c_btn.textSprite.y._ = 43;
			
			while (Sprite.getBounds(c_btn.textSprite.owner).height > 120)
			{
				c_btn.textSprite.setScale(c_btn.textSprite.scaleX._ - 0.01);
				c_btn.textSprite.centerAnchor();
			}

			coin = new Entity();
			var c_coin:Sprite;

			var c_icon:ImageSprite;
			if (gt.quizType == PROPERTY)
			{
				c_coin = new Sprite();
				c_icon = new ImageSprite(globalPack.getTexture("icons/" + Std.string(_categories[i]).toLowerCase()));
			}
			else
			{
				c_coin = new Sprite();
				c_icon = new ImageSprite(globalPack.getTexture("icons_50_quizzes/icon" + i % GROUP_SIZE));
			}	

			c_coin.setXY(-90, -196);
			coin.add(c_coin);
			_btns[i].firstChild.addChild(coin);
			
			icon = new Entity().add(c_icon);
			coin.addChild(icon);

			_btnHolder.addChild(btn);

			disposer.connect1(c_btn.engaged, function (_) {onButtonClick(i);});

		}

		var c_navBtn:BasicButton;
		var btnIds = ["lt", "rt"];

		for (i in 0...2)
		{
			c_navBtn = new BasicButton(pack, "ui/btn_" + btnIds[i]);
			c_navBtn.setXY(i * 828 + 268, 400);
			_navBtns[i] = new Entity().add(c_navBtn);

			function()
			{
				var id = i;

				disposer.connect1(c_navBtn.engaged, function (_) {

					switch (id)
					{
						case 0:
							navToPos(-1);
						case 1:
							navToPos(1);
					}

				});

			}();

		}

		var fling = new Fling2(_btnHolder);
		_container.add(fling);

  		disposer.connect2(_btnHolder.get(Sprite).x.changed, onHolderXChanged);

	}

	/* ---------------------------------------------------------------------------------------- */

	private function onHolderXChanged(curr:Float, prev:Float)
	{
		//To account for amount buttons can go offscreen before wrapping.
		var wrapExtra = 400;
		var btn:Sprite;
		var offsetX = Math.ceil((curr + wrapExtra) / (_btns.length * H_SPACING));

		if (curr < prev)
		{
			for (i in 0..._btns.length)
			{
				btn = _btns[i].get(Sprite);

				if (btn.x._ + curr < -wrapExtra)
				{
					btn.x._ = (-offsetX + 1) * _btns.length * H_SPACING + i * H_SPACING;
				}

			}

		}
		else if (curr >= prev)
		{
			for (i in 0..._btns.length)
			{
				btn = _btns[i].get(Sprite);
				
				if (btn.x._ + curr > wrapExtra + AutoFillScene.STANDARD_WIDTH)
				{
					btn.x._ = -offsetX * _btns.length * H_SPACING + i * H_SPACING;
				}

			}

		}

	}

	/* ---------------------------------------------------------------------------------------- */

	private function navToPos(step:Int)
	{
		_currentPage += step;
		_currentPage = Math.round(FMath.clamp(_currentPage, 0, Math.round(_categories.length / GROUP_SIZE)));

		var theX:AnimatedFloat = _btnHolder.get(Sprite).x;
		var pos = Math.round(theX._ / H_SPACING);

		cast(_btnHolder.get(Sprite).x.behavior, Damping).target = pos * H_SPACING + step * H_SPACING;

		//buttonVisibility();

	}

	/* ---------------------------------------------------------------------------------------- */

	// private function buttonVisibility()
	// {
	// 	_navBtns[0].get(Sprite).visible = _currentPage != 0;
	// 	_navBtns[1].get(Sprite).visible = _currentPage != Math.ceil(_categories.length / GROUP_SIZE) - 1;
	// }

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private function onButtonClick(id:Int)
	{
		if (_container.get(Fling2).dist < 20)
		{
			var gt = System.root.get(GameTracker);
			//var categories = gt.getCategoryIds();

			gt.generateQuestions(_categories[id]);

			var globalPack :AssetPack = _assets.get('global');
			globalPack.getSound("sfx/select_quiz_button").play();

			Scenes.goto(QuestionScene);
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	override public function onRemoved()
	{
		requiredPacks.push('quiz_select_scene');

		super.onRemoved();
	}

}






















