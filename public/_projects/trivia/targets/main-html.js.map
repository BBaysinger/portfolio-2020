package s2.util;

import flambe.math.Matrix;
import haxe.macro.Expr.ExprOf;

class MatrixUtil
{
    macro static public function getX(matrix:ExprOf<Matrix>):ExprOf<Float> 
    {
        return macro $matrix.m02;
    }   

    macro static public function getY(matrix:ExprOf<Matrix>):ExprOf<Float> 
    {
        return macro $matrix.m12;
    }   

    macro static public function getScaleX(matrix:ExprOf<Matrix>):ExprOf<Float> 
    {
        return macro Math.sqrt($matrix.m00 * $matrix.m00 + $matrix.m01 * $matrix.m01);
    }   

    macro static public function getScaleY(matrix:ExprOf<Matrix>):ExprOf<Float> 
    {
        return macro Math.sqrt($matrix.m10 * $matrix.m10 + $matrix.m11 * $matrix.m11);
    }   

    macro static public function getRotation(matrix:ExprOf<Matrix>):ExprOf<Float> 
    {
        return macro Math.atan(-$matrix.m01  / $matrix.m00);
    }   
}