	/* ---------------------------------------------------------------------------------------- */

	/*
	* Do this at site start, so we can make sure we have what we need in the XML.
	*/
	public static function testCategoryNames()
	{
		var all = Type.allEnums(CategoryId);

		for (cat in all)
		{
			if (Locale.getFormat("categoryNames." + Std.string(cat).toLowerCase()) == null)
			{
				throw("Missing: " + Std.string(cat));
			}

		}

	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	public static function getCategoryName(categoryId:CategoryId):String
	{
		return Locale.getFormat("categoryNames." + Std.string(categoryId).toLowerCase()).text;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	public static function getCategoryId(categoryId:CategoryId):String
	{
		return Std.string(categoryId).toLowerCase();
	}
	
	/* ---------------------------------------------------------------------------------------- */

	public static function getCategoryType(categoryId:CategoryId):QuizType
	{
		if (getTopicCategoryIds().indexOf(categoryId) == -1)
		{
			return QuizType.PROPERTY;
		}
		else
		{
			return QuizType.TOPIC;
		}

	}
	
	/* ---------------------------------------------------------------------------------------- */

	public static function getCategoryIds(quizType:QuizType):Array<CategoryId>
	{
		if (quizType == null)
		{
			return [];
		}
		else if (quizType == QuizType.TOPIC)
		{
			return getTopicCategoryIds();
		}
		else
		{
			return getPropertyCategoryIds();
		}

	}

}





















