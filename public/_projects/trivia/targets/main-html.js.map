package com.nick.ultimatetrivia;

import flambe.util.Signal0;
import s2.util.IndexedItem;
import com.nick.ultimatetrivia.Question;

/**
 * Refers to specific parts (one or more) of each questions. Every question has at least on query that corresponds to
 * one option (answer).
 * ...
 * @author Seven2
 */
class Query extends IndexedItem
{
	/**  */
	public var solution(default, null):Option; 
	/**  */
	public var selectedOption(default, null):Option; 
	/**  */
	public var hasSelectedOption(get_hasSelectedOption, null):Bool;
	/**  */
	public var text(default, null):String;
	/**  */
	public var image(default, null):String;
	/**  */
	public var isCorrect(get_isCorrect, null):Bool;
	/**  */
	public var optionChanged(default, null) = new Signal0();
	/**  */
	private var type:QuestionType;

    /* ---------------------------------------------------------------------------------------- */

	public function new(xNode:Xml, solution:Option, type:QuestionType, index:Int)
	{
		super(index);

		text = xNode.firstChild() + "";
		if (text == "") text = null;
		image = xNode.get("image");
		if (image == "") image = null;
		this.type = type;
		this.solution = solution;
	}

    /* ---------------------------------------------------------------------------------------- */

	public function reset()
	{
		selectedOption = null;
	}

    /* ---------------------------------------------------------------------------------------- */

	public function setSelected(option:Option)
	{
		if (option != selectedOption)
		{
			selectedOption = option;
			optionChanged.emit();
		}
	
	}

    /* ---------------------------------------------------------------------------------------- */

	public function get_isCorrect():Bool
	{
		var retVal:Bool;

		switch (type)
		{
			case RATHER, /*PERSONALITY_IMAGE,*/ PERSONALITY_CHOICE:
				retVal = selectedOption != null;
			default:
				retVal = solution == selectedOption;
		}

		return retVal;
		
	}

    /* ---------------------------------------------------------------------------------------- */

	public function get_hasSelectedOption():Bool
	{
		return selectedOption != null;
	}

}
























