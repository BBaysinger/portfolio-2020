package com.nick.ultimatetrivia.components;

import flambe.asset.AssetPack;
import flambe.display.TextSprite;

import s2.ui.TextButton;
import s2.localization.Locale;

/**
 * 
 */
class QuizButton extends TextButton
{
	public function new(pack:AssetPack, id:String, loc:String)
	{
		super(pack, id, loc);
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function createField():TextSprite
	{
		//Wreaks havoc on LayoutUtil.
		return Locale.getField(_loc, 0, Center);
	}

}
























