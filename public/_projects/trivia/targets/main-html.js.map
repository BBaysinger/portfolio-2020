package s2.scene;

import flambe.animation.AnimatedFloat;
import flambe.animation.Sine;
import flambe.asset.AssetPack;
import flambe.display.FillSprite;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.Entity;
import flambe.math.Rectangle;
import flambe.System;
import flambe.util.Disposable;

import s2.display.MultiTextureSprite;
import s2.display.SwapSprite;
import s2.loading.Assets;
import s2.localization.Locale;

using s2.display.LayoutUtil;

/**
 * The main preloader scene for our game. Can be reusesd across projects with minor modification.
 * @author Seven2
 */
class SwapPreloadScene extends SceneLoader
{
	/** The asset pack used to setup the preloader. */
	private var _pack 				:AssetPack;
	/**  */
	private var _progress			:Entity;
	/** Used to keep track of screen resizing. */
	private var _resizeHandle  		:Disposable;
	/**  */
	private var _text : Entity;
	/** The 'on' state for our preloader. */
	private var _onName :String;
	/** The 'off' state for our preloader. */
	private var _offName :String;
	/** comment */
	private var _dir :SwapDirection;

	/* ---------------------------------------------------------------------------------------- */
	
	public function new(pack :AssetPack, ?onName :String = "loading_on", offName :String = "loading_off", ?direction :SwapDirection) 
	{
		super(false);
		_pack = pack;
		_onName = onName;
		_offName = offName;
		_dir = direction == null ? SwapDirection.Left : direction;
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	override public function assetsReady():Void 
	{
		super.assetsReady();

		//_backing = new Entity()
			//.add(new FillSprite(0x000000, 1366, 768).setAlpha(0.8));
		
		// The progress sprite to use.
		var ps :SwapSprite = new SwapSprite(_pack.getTexture(_onName), _pack.getTexture(_offName), _dir);
		_progress = new Entity()
			.add(ps.setXY(47,42));

		ps.alpha.behavior = new Sine(1, 0.8, 0.4);

		_text = new Entity()
			.add(Locale.getField("loading.loading").centerAnchor());

		// Add all our objects to the container.
		_container
			.addChild(_text)
			.addChild(_progress);
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	override public function onResize()
	{
		super.onResize();
		
		_progress.centerX().centerY();
		_text.centerX().centerY(-50);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override private function onProgress(bytesLoaded:Float, bytesTotal:Float) :Void {
		cast(_progress.get(Sprite), SwapSprite).progress.animateTo(bytesLoaded / bytesTotal, 0.1);
	}

	override private function onLoadSuccess():Void
	{
		cast(_progress.get(Sprite), SwapSprite).progress._ = 1;
		super.onLoadSuccess();
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function onRemoved()
	{
		super.onRemoved();
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function dispose()
	{
		super.dispose();
	}

}
































