
package s2.scene;

import flambe.display.Sprite;
import flambe.Entity;
import flambe.scene.Director;
import flambe.scene.Transition;
import flambe.swf.MovieSprite;
import flambe.System;

class MovieTransition extends Transition {


	/**
	 * @param  movie        The movie to use as a transition.
	 * @param  obscuredTime The time in seconds when the screen is completely obscured.
	 */
	@:keep public function new(movie:MovieSprite, obscuredTime:Float = -1)
	{
		_obscured = obscuredTime < 0 ? movie.symbol.duration / 2 : obscuredTime;
		_movie = movie;
        _holder = new Entity();
	}
    

    override public function init (director :Director, from :Entity, to :Entity)
    {
        super.init(director, from, to);

        var scale:Float = Math.max(System.stage.height / 768, System.stage.width / 1024);
        _holder.add(_movie);
        _movie.setScale(scale);

        _movie.paused = false;
        _movie.position = 0;
        _movie.paused = true;
        
        var sprite = _to.get(Sprite);
        if (sprite == null) {
            _to.add(sprite = new Sprite());
        }
        sprite.alpha._ = 0;

        director.owner.addChild(_holder);
    }

    override public function update (dt :Float) :Bool
    {
        _movie.paused = false;
        _movie.position += dt;
        _movie.paused = true;

    	if(_movie.position >= _obscured) {
            _to.get(Sprite).alpha._ = 1;
            var from :Sprite = _from.get(Sprite);
            if (from == null) {
                _from.add(from = new Sprite());
            }
    		from.alpha._ = 0;
    	}

        return _movie.position >= _movie.symbol.duration;
    }

    override public function complete ()
    {
        _movie.paused = false;
        _movie.position = _movie.symbol.duration;
        _movie.paused = true;
        _to.get(Sprite).alpha._ = 1;
        _holder.dispose();
    }

	/**  */
	private var _movie :MovieSprite;
	/**  */
	private var _obscured :Float;
	/** Holds the transition clip. */
	private var _holder :Entity;

}