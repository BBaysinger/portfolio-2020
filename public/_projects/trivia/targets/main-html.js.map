package com.nick.ultimatetrivia.components;

import flambe.Component;
import flambe.Log;
import flambe.System;
import flambe.util.Signal1;
import flambe.asset.File;
import flambe.asset.Manifest;
import flambe.util.Signal0;

import s2.util.URLParser;
import s2.util.Utils;

import com.nick.ultimatetrivia.Data;
import com.nick.ultimatetrivia.Question;
import com.nick.ultimatetrivia.Data.CategoryId;

using flambe.util.Arrays;
using StringTools;

enum QuizType
{
	PROPERTY;
	TOPIC;
}

typedef TraitScore = {
	var categoryId :CategoryId;
	var percent :Float;
	var adjPct:Float;
}

/**
 * Variables and controls that must be persistent across all gameplay scenes.
 * 
 * @author Seven2
 */
class GameTracker extends Component
{
	/** The length of the history of quiz scores retained for factoring into averages. */
	private static var tallyDepth 						:Int = 4;

	//Primitive(ish) data types;
	/**  */
	public var numQuestions(get_numQuestions, null)		:Int;
	/**  */
	public var questionIndex(default, null)				:Int;
	/**  */
	public var quizType(default, null) 					:QuizType;
	/**  */
	public var category(default, null)					:CategoryId;
	/**  */
	public var numCorrect(get_numCorrect, null) 		:Int;
	/**  */
	public var numStrikes(get_numStrikes, null) 		:Int;
	/**  */
	public var randomQuizMode(default, null)			:Bool = false;
	/**  */
	public var failed(get_failed, null)					:Bool;
	/**  */
	public var inited(default, null)					:Bool = false;

	//Composite data types.
	/**  */
	public var questions(get_questions, null)			:Array<Question>;
	/**  */
	public var manifests(get_manifests, null)			:Map<CategoryId, Manifest>;
	/**  */
	public var optionChanged(default, null)				= new Signal0();
	/**  */
	public var progressed(default, null)				= new Signal0();
	/**  */
	private var _manifests(default, null)				= new Map<CategoryId, Manifest>();
	/**  */
	private var _categories 							:Map<CategoryId, Array<Question>>;
	/**  */
	private var _questions 								:Array<Question>;
	/*  */
	private var _log 									= System.createLogger("GameTracker");
	/*  */
	private var _sessionScoreRecordAdjusted				:Array<TraitScore>;
	/*  */
	private var _sessionScoreRecord						= new Array<TraitScore>();
	/**  */
	private var _xDoc 									:Xml;
	/**  */
	public var testAssets(default, null)				:Bool = false;

	/* ---------------------------------------------------------------------------------------- */

	public function new()
	{

	}

	/* ---------------------------------------------------------------------------------------- */

	public function getCategoryIds():Array<CategoryId>
	{
		var retVal = Data.getCategoryIds(quizType);
		var index = retVal.length;
		var catId:CategoryId;

		for (i in 0...retVal.length)
		{
			index--;

			catId = retVal[index];

			if (!_categories.exists(catId))
			{
				trace("Removing: " + catId);
				retVal.splice(index, 1);
			}
			
		}

		return retVal;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function getSelectedCategoryType(category:CategoryId):QuizType
	{
		return Data.getCategoryType(category);
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	public function init(xml:File)
	{
		inited = true;

		_xDoc = Xml.parse( xml.toString() );

		var url = URLParser.fromBrowser();
		testAssets = url.query.exists("testassets");

		Data.testCategoryNames();

		_categories = readCategories();

		for (catId in _categories.keys())
		{
			if (Data.getCategoryType(catId) == TOPIC && _categories.get(catId).length != 10)
			{
				_log.error(catId + " has " + _categories.get(catId).length + " questions. Should have 10.");
			}

			if (Data.getCategoryType(catId) == PROPERTY && _categories.get(catId).length != 50)
			{
				_log.error(catId + " has " + _categories.get(catId).length + " questions. Should have 50.");
			}

		}

		function sortLongest(a:String, b:String):Int
		{
			return (a.length < b.length) ? 1 : -1;
		}

		// Leave for testing.
		//Option.texts.sort(Option.sortLongest);
		//Option.texts = Option.texts.splice(0, 70);
		// for (i in 0...Option.texts.length)
		// {
		// 	trace(Option.texts[i]);
		// }
		// Question.texts.sort(sortLongest);
		// Question.texts = Question.texts.splice(0, 70);
		// for (i in 0...Question.texts.length)
		// {
		// 	trace(Question.texts[i]);
		// }

		var categories = Type.allEnums(CategoryId);
		var numCategories = 0;
		var rec:String = System.storage.get("score_record", "");

		//Make sure empty string doesn't split into array with one empty string.
		var arr:Array<String> = (rec.length == 0) ? [] : rec.split(",");

		var nPct:Float;
		var sPct:String;
		var id:String;
		var traitScore:TraitScore;
		var enums:Array<String> = Type.getEnumConstructs(CategoryId);

		for (scoreStr in arr)
		{
			id = scoreStr.substr(0, scoreStr.indexOf(":"));
			sPct = scoreStr.substr(scoreStr.indexOf(":") + 1);
			nPct = Std.parseFloat(sPct);

			if (enums.indexOf(id) != -1)
			{
				traitScore = {categoryId:Type.createEnum(CategoryId, id), percent:nPct, adjPct:-1};

				_sessionScoreRecord.push(traitScore);
			}
			else
			{
				trace("Unknown CategoryId: " + id);
			}

		}

		_sessionScoreRecordAdjusted = sortScoreRecord(_sessionScoreRecord);

		for (category in categories)
		{
			numCategories++;
			var type:String = (Data.getCategoryType(category) == QuizType.TOPIC) ? "t_" : "p_";
			_manifests.set(category, Manifest.fromAssets("assets_" + type + Std.string(category).toLowerCase()));
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Set categories into map for access. This will give lists of questions that we can modify, without
	* changing the set that was loaded in. Load questions from here 
	* 
	*/
	public function readCategories():Map<CategoryId, Array<Question>>
	{
		var retVal = new Map<CategoryId, Array<Question>>();

		//Opted out of using E4X, because for a noticable hang in Flash during filtering.
		var fDoc = new haxe.xml.Fast(_xDoc.firstChild());

		for( child in fDoc.elements )
		{
			var aCategory = new Array<Question>();
			var cat = Type.createEnum(CategoryId, child.att.id.toUpperCase());
			var oQuestion:Question;
			var i:Int = 0;

			for (xQuestion in child.elements)
			{
				oQuestion = new Question(xQuestion.x, cat, i);

				oQuestion.optionChanged.connect(onOptionChanged);

				aCategory.push(oQuestion);

				i++;

			}

			retVal.set(cat, aCategory);

		}

		for (cat in Type.allEnums(CategoryId))
		{
			if (!retVal.exists(cat) && cat != TEST1)
			{
				throw("Missing: " + cat);
			}

		}

		return retVal;

	}

	/* ---------------------------------------------------------------------------------------- */

	public function getAvailableAnimations():Array<AnimationIds>
	{
		var anims:Array<AnimationIds> = [];
		var anim:AnimationIds = null;

		for (traitScore in _sessionScoreRecord)
		{
			anim = Data.getAnimationId(traitScore.categoryId);

			if (anims.indexOf(anim) == -1)
			{
				anims.push(anim);
			}

		}

		return anims;

	}

	/* ---------------------------------------------------------------------------------------- */

	private function onOptionChanged()
	{
		optionChanged.emit();
	}

	/* ---------------------------------------------------------------------------------------- */

	public function getCategories():Map<CategoryId, Array<Question>>
	{
		var retval = new Map<CategoryId, Array<Question>>();

		for (catId in _categories.keys())
		{
			retval.set(catId, _categories.get(catId).concat([]));
		}

		return retval;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	*
	*/
	public function generateQuestions(categoryId:CategoryId):Void
	{
		questionIndex = -1;

		this.category = categoryId;

		_questions = _categories.get(categoryId).concat([]);

		if (quizType == PROPERTY)
		{
			_questions.sort(Utils.sortArrayRandom);
		}

		if (_questions == null)
		{
			throw("Category " + categoryId + " in not in questions.xml.");
		}

		for (question in _questions)
		{
			question.reset();
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	public function get_numCorrect():Int
	{
		var retVal:Int = 0;

		for (question in questions)
		{
			if (question.allCorrect())
			{
				retVal++;
			}

		}

		return retVal;

	}

	/* ---------------------------------------------------------------------------------------- */

	public function get_numStrikes():Int
	{
		var retVal:Int = 0;

		for (question in questions)
		{
			if (question.allAnswered && !question.allCorrect())
			{
				retVal++;
			}

		}

		return retVal;

	}

	/* ---------------------------------------------------------------------------------------- */

	public function get_numQuestions():Int
	{
		return _questions.length;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function nextQuestion():Question
	{
		questionIndex++;

		var retVal = _questions[questionIndex];
		progressed.emit();
		return retVal;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function get_questions():Array<Question>
	{
		return _questions.concat([]);
	}

	/* ---------------------------------------------------------------------------------------- */

	public function get_manifests():Map<CategoryId, Manifest>
	{
		return _manifests;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function reset():Void
	{
		category = null;
		quizType = null;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function finishQuiz():Void
	{
		//Only factors questions that have been answered.
		var percent = (numCorrect/(questionIndex + 1));
		if (isPersonalityQuiz()) percent *= 0.6;
		var fixedPct = Math.round(percent * 100)/100;
		var j = _sessionScoreRecord.length - 1;

		//Makes sure duplicates of new items get removed.
		for (i in 0..._sessionScoreRecord.length)
		{
			if (_sessionScoreRecord[j].categoryId == category)
			{
				_sessionScoreRecord.splice(j, 1);
			}

			j--;
		}

		_sessionScoreRecord.push({categoryId:category, percent:fixedPct, adjPct:-1});
		_sessionScoreRecordAdjusted = sortScoreRecord(_sessionScoreRecord);

		var str = "";

		for (score in _sessionScoreRecord)
		{
			str += "," + score.categoryId + ":" + score.percent;
		}

		str = str.substr(1);

		System.storage.set("score_record", str);
		System.storage.set(Std.string(category), str);

	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Takes the scores of the quizzes in the order of their last play,
	* and uses the order to apply an adjustment to their percent scored
	* and place more recently played quizzes nearer to the top in the brain.
	*/
	private static function sortScoreRecord(record:Array<TraitScore>)
	{
		var animationIds = Type.allEnums(AnimationIds);

		for (i in 0...record.length)
		{
			var fromTop:Int = animationIds.length - (record.length - (i + 1));
			var adjustment = (fromTop / animationIds.length) * 0.5 + 0.5;

			record[i].adjPct = adjustment * record[i].percent;
		}

		var adjustedRecord:Array<TraitScore> = record.concat([]);

		adjustedRecord.sort(sortScores);

		return adjustedRecord;

	}

	/* ---------------------------------------------------------------------------------------- */

	public static function sortScores(a:TraitScore, b:TraitScore):Int
	{
		return (a.adjPct < b.adjPct) ? 1 : -1;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function getTopPsychTraits():Array<TraitScore>
	{
		return _sessionScoreRecordAdjusted.concat([]);
	}

	/* ---------------------------------------------------------------------------------------- */

	public function setQuizType(quizType:QuizType, random:Bool):Void
	{
		this.quizType = quizType;
		this.randomQuizMode = random;
	}

	/* ---------------------------------------------------------------------------------------- */

	public function isPersonalityQuiz():Bool
	{
		if (category == RATHER || category == PERSONALITY)
		{
			return true;
		}
		else
		{
			return false;
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	public function get_failed():Bool
	{
		return numStrikes > 2 && quizType == PROPERTY;
	}

	/* ---------------------------------------------------------------------------------------- */

}






























