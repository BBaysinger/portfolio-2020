		var c_bar = new FillSprite(0x000000, 1366, 112);
		c_bar.y._ = 239;
		_bar.add(c_bar);
		_container.addChild(_bar);

		var c_hud = new Hud(pack);
		_hud.add(c_hud);
		_container.addChild(_hud);

		nextQuestion();

		onResize();

	}

	/* ---------------------------------------------------------------------------------------- */

	private function completeQuestion()
	{
		var gt = System.root.get(GameTracker);
		var c_questionDisplay = _questionDisplay.get(QuestionDisplay);

		if (c_questionDisplay != null) {
			c_questionDisplay.transitionOut();
		}

		if (gt.failed || gt.questionIndex >= gt.numQuestions - 1)
		{
			playStinger();
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	private function nextQuestion()
	{
		var gt = System.root.get(GameTracker);
		_question = gt.nextQuestion();

		if (_question != null)
		{
			var pack = _assets.get('question_scene');
			var globalPack = _assets.get('global');
			var questionPack = _assets.get(_quizPackId);
			var disposer = owner.get(Disposer);

			var c_questionDisplay = _questionDisplay.get(QuestionDisplay);

			disposer.connect0(_question.optionChanged, onOptionChange);

			if (_questionDisplay != null) _questionDisplay.dispose();
			_questionDisplay = new Entity();
			_container.addChild(_questionDisplay);

			c_questionDisplay = QuestionDisplay.getDisplay(pack, questionPack, globalPack, _question);

			disposer.connect1(c_questionDisplay.transitionedOut, onQuestionTranitionedOut);
			_questionDisplay.add(c_questionDisplay);

		}
		
	}

	/* ---------------------------------------------------------------------------------------- */

	private function onOptionChange()
	{
		var gt = System.root.get(GameTracker);

		if (_question.type == MATCH || _question.type == MATCH_IMAGE)
		{
			if (_question.allAnswered)
			{
				completeQuestion();
			}
		}
		else
		{
			completeQuestion();
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	private function onQuestionTranitionedOut(questionDisplay:QuestionDisplay)
	{
		var gt = System.root.get(GameTracker);
		questionDisplay.owner.dispose();

		if (gt.failed)
		{
			complete();
		}
		else if (gt.questionIndex < gt.numQuestions - 1)
		{
			nextQuestion();
		}
		else
		{
			complete();
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	private function complete()
	{
		var gt = System.root.get(GameTracker);

		gt.finishQuiz();
		_questionDisplay.dispose();

		Scenes.goto(ResultsScene);
	}

	/* ---------------------------------------------------------------------------------------- */

	private function playStinger()
	{
		var globalPack :AssetPack = _assets.get('global');

		MusicManager.stop();
		globalPack.getSound("sfx/utg_gameplay_quiz_music_endstingerv1").play();
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	override public function onResize()
	{
		super.onResize();
		
		if (_hud.get(Hud) != null)
		{
			_hud.get(Hud).onResize();
		}
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	override public function onRemoved()
	{
		_assets.unload(_quizPackId);
		_assets.unload("question_scene");

		super.onRemoved();

		//System.root.remove(System.root.get(Inactivity));
	}
	
}






























