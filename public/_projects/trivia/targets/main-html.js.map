package com.nick.ultimatetrivia;

import s2.util.IndexedItem;

class Option extends IndexedItem
{
	/**  */
	public static var texts:Array<String> = [];
	/**  */
	public var text(default, null):String;
	/**  */
	public var image(default, null):String;

	/* ---------------------------------------------------------------------------------------- */

	public function new(xNode:Xml, index:Int)
	{
		super(index);

		var xText:Xml = xNode.firstChild();
		text = (xText != null) ? StringTools.htmlUnescape(xText + "") : null;
		if (text == "") text = null;
		image = xNode.get("image");
		if (image == "") image = null;

		texts.push(text);
	}


}


























