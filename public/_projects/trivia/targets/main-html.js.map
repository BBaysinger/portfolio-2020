package s2.util;

import flambe.Component;

class IndexedItem extends Component
{
	/**  */
	public var index(default, null):Int;
	/**  */
	public var col(default, null):Int;
	/**  */
	public var row(default, null):Int;
	/**  */
	public var val(default, null):String;

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	@:keep function new(index:Int, col:Int = -1, row:Int = -1, val:String = null)
	{
		this.index = index;
		this.col = col;
		this.row = row;
		this.val = val;
	}

}