package com.nick.ultimatetrivia.components.question;

import flambe.Entity;
import flambe.asset.AssetPack;
import flambe.util.Signal1;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.display.TextSprite;
import flambe.display.Texture;
import flambe.sound.Sound;
import flambe.Disposer;
import flambe.util.Signal0;
import flambe.math.Point;
import flambe.script.Script;
import flambe.script.Sequence;
import flambe.script.AnimateTo;
import flambe.script.CallFunction;
import flambe.animation.Ease;

import s2.display.SpriteUser;
import s2.localization.Locale;
import s2.ui.TextButton;
import s2.util.TimeUtil;
import s2.scene.AutoFillScene;
import s2.util.Utils;

import com.nick.ultimatetrivia.Question;
import com.nick.ultimatetrivia.components.QuizButton;

/**
 * Controls how the questions are displayed.
 * ...
 * @author Seven2
 */
class QuestionDisplay extends SpriteUser
{
	/**  */
	private static inline var MIDDLE:Int = 510;
	/**  */
	private static inline var SPACING:Int = 68;

	//Composite data types.
	/**  */
	private var _oQuestion 		:Question;
	/**  */
	private var _text 			= new Entity();
	/**  */
	private var _feedback 		= new Entity();
	/**  */
	private var _image 			:Entity;
	/**  */
	private var _options 		= new Array<Entity>();
	/**  */
	private var _scenePack 		:AssetPack;
	/**  */
	private var _globalPack 	:AssetPack;
	/**  */
	private var _quizPack 		:AssetPack;
	/**  */
	private var _lightBurst 	= new Entity();
	/**  */
	public var transitionedOut(default, null) = new Signal1<QuestionDisplay>();
	/** (Initial) randomized placement */
	private var _order:Array<Int> = [0, 1, 2, 3];

	/* ---------------------------------------------------------------------------------------- */

	public static function getDisplay(scenePack:AssetPack, quizPack:AssetPack, globalPack:AssetPack, question:Question):QuestionDisplay
	{
		switch (question.type)
		{
			case CHOICE, BOOL, IMAGE, RATHER, PERSONALITY_CHOICE/*, PERSONALITY_IMAGE*/:

				return new QuestionDisplay(scenePack, quizPack, globalPack, question);

			case IMAGE_OPTION:

				return new ImageOptionQuestionDisplay(scenePack, quizPack, globalPack, question);

			case MATCH, MATCH_IMAGE:

				return new MatchingQuestionDisplay(scenePack, quizPack, globalPack, question);

			case AUDIO:

				return new AudioQuestionDisplay(scenePack, quizPack, globalPack, question);

		}
	}

	/* ---------------------------------------------------------------------------------------- */

	public function new(scenePack:AssetPack, quizPack:AssetPack, globalPack:AssetPack, question:Question)
	{
		super();

		_scenePack = scenePack;
		_globalPack = globalPack;
		_quizPack = quizPack;
		_oQuestion = question;

		_order = _order.slice(0, question.options.length);
		if (question.type != BOOL && question.type != RATHER) _order.sort(Utils.sortArrayRandom);
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		super.onAdded();

		var disposer = owner.get(Disposer);
        if (disposer == null) owner.add(disposer = new Disposer());

        var timeUtil = new TimeUtil();
        owner.add(timeUtil);

        var width = 800;
		var c_text = Locale.getField("question.questionText", width, Center);
		c_text.text = _oQuestion.text;
		_text.add(c_text);
		owner.addChild(_text);
		c_text.setXY((AutoFillScene.STANDARD_WIDTH-width)/2, 296 - Sprite.getBounds(_text).height/2);

		build();

	}

	/* ---------------------------------------------------------------------------------------- */

	private function build()
	{
		var disposer = owner.get(Disposer);

		if (_oQuestion.type == IMAGE || _oQuestion.type == AUDIO)
		{
			var c_lightBurst = new ImageSprite(_scenePack.getTexture("light_burst"));
			_lightBurst.add(c_lightBurst);
			c_lightBurst.setXY(332, 518);
			c_lightBurst.centerAnchor();
			owner.addChild(_lightBurst);

			var c_image:ImageSprite;

			if (_oQuestion.type == AUDIO)
			{
				if (_oQuestion.sound == null)
				{
					c_image = new ImageSprite(_scenePack.getTexture("missing_sound"));
				}
				else
				{
					c_image = new ImageSprite(_scenePack.getTexture("audio"));
				}
				
			}
			else if (_oQuestion.image == null)
			{
				c_image = new ImageSprite(_scenePack.getTexture("missing_image"));
			}
			else
			{
				c_image = new ImageSprite(_quizPack.getTexture(_oQuestion.image));
			}

			_image = new Entity();
			
			c_image.x._ = Math.round(c_lightBurst.x._ - c_image.getNaturalWidth()/2);
			c_image.y._ = Math.round(c_lightBurst.y._ - c_image.getNaturalHeight()/2);
			_image.add(c_image);
			owner.addChild(_image);
		}

		var c_option:QuizButton;
		var option:Entity;
		var i:Int = 0;

		var directory:String = "ui/btns_";
		var optionX:Float;
		var centerX:Float = AutoFillScene.STANDARD_WIDTH/2;

		var longest:Float = 0;
		var longestFieldIndex:Int = -1;
		var c_testField:TextSprite;
		var e_testField = new Entity();

		for (i in 0..._oQuestion.options.length)
		{
			c_testField = Locale.getField("question.option");
			c_testField.text = _oQuestion.options[i].text;
			e_testField.add(c_testField);
			var width = Sprite.getBounds(e_testField).width;
			if (longest < width) longestFieldIndex = i;
			longest = Math.max(longest, Sprite.getBounds(e_testField).width);
		}

		switch (_oQuestion.type)
		{
			case CHOICE, PERSONALITY_CHOICE, RATHER:
				optionX = centerX;
				//Switch to shorter button, if possible.
				directory += (longest <= 510) ? "short" : "choice";
			case BOOL:
				optionX = centerX;
				directory += Std.string(_oQuestion.type).toLowerCase();
			default://The rest should be image type.
				directory += "short";
				optionX = centerX + 104;
		}

		var scale:Float = 9999999;

		for (oOption in _oQuestion.options)
		{
			c_option = new QuizButton(_scenePack, directory + "/" + _order[i], "question.option");
			c_option.maxScale = 1.06;
			c_option.setText(oOption.text);

			var wye = SPACING * _order[i] + MIDDLE - SPACING * (_oQuestion.options.length - 1) / 2;

			c_option.setXY(optionX, wye);

			function ()
			{
				var num = i;
				var opt = c_option;
				disposer.connect1(c_option.engaged, function (_) {selectOption(num);});
			}();

			option = new Entity();
			option.add(c_option);

			_options.push(option);

			i++;
			
		}

		var longestField = _options[longestFieldIndex].get(TextButton).textSprite;

		while (Sprite.getBounds(longestField.owner).width > 720)
		{
			longestField.setScale(longestField.scaleX._ - 0.01);
		}

		var textSprite:TextSprite;

		//And elements from bottom top, according to color.
		for (i in 0..._oQuestion.options.length)
		{
			textSprite = _options[i].get(TextButton).textSprite;
			textSprite.setScale(longestField.scaleX._);

			textSprite.x._ = 2;
			textSprite.y._ = -Sprite.getBounds(textSprite.owner).height/2  - 18.5;

			//c_option.setS
			owner.addChild(_options[_order.indexOf(i)]);
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	private function selectOption(optionIndex:Int, queryIndex:Int = 0)
	{
		_oQuestion.queries[queryIndex].setSelected(_oQuestion.options[optionIndex]);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	public function transitionOut()
	{
		for (i in 0..._options.length)
		{
			_options[i].get(Sprite).disablePointer();
		}

		var c_feedback:ImageSprite;
		var c_text:TextSprite;
		var text = new Entity();
		var c_text = _text.get(TextSprite);

		c_text.x.animateTo(c_text.x._ + 300, 0.5);
		c_text.alpha.animateTo(0, 0.5);

		if (_oQuestion.type == RATHER || _oQuestion.type == PERSONALITY_CHOICE /*|| _oQuestion.type == PERSONALITY_IMAGE*/)
		{
			_scenePack.getSound("sfx/answer_alternate").play();
			c_text = Locale.getField("question.feedbackNeutral" + Math.ceil(Math.random() * 5), 0, Left);
			c_feedback = new ImageSprite(_scenePack.getTexture("mark_correct"));
		}
		else if (_oQuestion.allCorrect())
		{
			_scenePack.getSound("sfx/answer_correct").play();
			c_text = Locale.getField("question.feedbackCorrect", 0, Left);
			c_feedback = new ImageSprite(_scenePack.getTexture("mark_correct"));
		}
		else
		{
			_scenePack.getSound("sfx/answer_wrong").play();
			c_text = Locale.getField("question.feedbackIncorrect", 0, Left);
			c_feedback = new ImageSprite(_scenePack.getTexture("mark_incorrect"));
		}

		c_feedback.setXY(230, 264);
		c_feedback.alpha._ = 0;
		c_feedback.alpha.animateTo(1, 0.5);
		c_text.setXY(80, 0);
		text.add(c_text);
		_feedback.add(c_feedback);
		_feedback.addChild(text);

		c_feedback.x.animateTo(AutoFillScene.STANDARD_WIDTH/2 - Sprite.getBounds(_feedback).width/2, 0.5);

		owner.addChild(_feedback);

		animateOut();
	}

	/* ---------------------------------------------------------------------------------------- */

	public function animateOut()
	{
		var script = new Script();
		owner.add(script);

		var seq = new Sequence();
		var timeUtil = owner.get(TimeUtil);
		var emitTime:Float;

		var isPersonality = _oQuestion.type == RATHER || /*_oQuestion.type == PERSONALITY_IMAGE ||*/ _oQuestion.type == PERSONALITY_CHOICE;
		var id = (isPersonality) ? _oQuestion.queries[0].selectedOption.index : _oQuestion.queries[0].solution.index;

		function alphaOut()
		{
			owner.addChild(_options[_oQuestion.queries[0].solution.index]);
			
			for (i in 0..._options.length)
			{
				if (id != _oQuestion.options[i].index)
				{
					_options[i].get(Sprite).alpha.animateTo(0, 0.2);
				}

			}

		}

		emitTime = 1.0;

		if (!_oQuestion.allCorrect() && !isPersonality)
		{
			var ex = _options[_oQuestion.queries[0].selectedOption.index].get(Sprite).x._;

			for (i in 0...4)
			{
				seq.add(new AnimateTo(_options[_oQuestion.queries[0].selectedOption.index].get(Sprite).x, ex + i%2 * 25, 0.12));
			}

			emitTime = 1.8;
			seq.add(new AnimateTo(_options[_oQuestion.queries[0].selectedOption.index].get(Sprite).x, ex, 0.12));

		}
		
		seq.add(new CallFunction(alphaOut));
		seq.add(new AnimateTo(_options[id].get(Sprite).y, MIDDLE, 0.6, Ease.expoOut));
		script.run(seq);
		
		timeUtil.timeout(finishAnimateOut, emitTime);
	}

	/* ---------------------------------------------------------------------------------------- */

	function finishAnimateOut()
	{
		transitionedOut.emit(this);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function dispose()
	{
		super.dispose();
		
		_scenePack 		 = null;
		_globalPack 	 = null;
		_quizPack 		 = null;

		_oQuestion = null;
		_text = null;
		_feedback = null;
		_image = null;
		_options = null;
		_lightBurst = null;
		transitionedOut = null;
		_order = null;

	}

}























