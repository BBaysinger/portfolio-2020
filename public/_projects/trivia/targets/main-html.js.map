package s2.display;

import flambe.Entity;
import flambe.System;
import flambe.Disposer;
import flambe.Component;
import flambe.display.Sprite;
import flambe.input.MouseCursor;
import flambe.input.PointerEvent;
import flambe.util.Signal1;
import flambe.util.Value;
import flambe.util.Signal2;
import flambe.sound.Sound;

/**
 * Globally controls pointer mode, and dispatches the 'engaged' signal when pointerDown AND pointerUp have BOTH occurred
 * on the sprite held by owner. This gives better control to the user, and helps prevent unintended button
 * interactions.
 *
 * @author Bradley Baysinger / Seven2
 */
class ButtonMode extends Component
{
    /*  */
    private static var _defaultSound:Sound;
    /*  */
    private static var inited:Bool = false;
    /*  */
    private static var staticDisposer:Disposer;
    /*  */
    private static var currentTarget:Sprite;
    /*  */
    private static var staticChanged:Signal1<Sprite>;

    /**  */
    private var _isDown:Bool = false;
    /**  */
    private var _spriteConnectionDisposer:Disposer;

    /**  */
    public var playSound:Bool;
    /**  */
    public var index(default, null):Int = -1;
    /**  */
    public var engaged(default, null):Signal1<PointerEvent> = new Signal1<PointerEvent>();

    /* ---------------------------------------------------------------------------------------- */

    /*
    * class initializer
    */
    public static function initialize(defaultSound:Sound)
    {
        inited = true;

        _defaultSound = defaultSound;

        var root:Entity = System.root;
        var sRoot:Sprite;

        staticChanged = new Signal1<Sprite>();

        staticDisposer = new Disposer();

        if (root.get(Sprite) == null)
        {
            System.root.add(new Sprite());
        }

        sRoot = System.root.get(Sprite);

        staticDisposer.connect1(sRoot.pointerMove, onPointerMove);
        staticDisposer.connect1(staticChanged, staticOnChanged);

    }

    /* ---------------------------------------------------------------------------------------- */

    /*
    * 
    */
    private static function staticOnChanged(current:Sprite):Void
    {
        if (current.owner != null && current.owner.getFromParents(ButtonMode) != null)
        {
             System.mouse.cursor = MouseCursor.Button;
        }
        else
        {
             System.mouse.cursor = MouseCursor.Default;
        }
    }

    /* ---------------------------------------------------------------------------------------- */

    /*
    * 
    */
    static function onPointerMove(e:PointerEvent):Void
    {
        if (currentTarget != e.hit)
        {
            staticChanged.emit(e.hit);
        }

        currentTarget = e.hit;
    }

    /* ---------------------------------------------------------------------------------------- */

    /*
    * 
    */
    public function new(nIndex:Int = -1):Void
    {
        this.index = nIndex;

        if (!inited)
        {
            initialize(null);
        }

    }

    /* ---------------------------------------------------------------------------------------- */

    /*
    * 
    */
    override public function onAdded():Void
    {
        var disposer = owner.get(Disposer);
        if (disposer == null) owner.add(disposer = new Disposer());

        disposer.connect1(staticChanged, onChanged);
        disposer.connect1(System.pointer.up, onSystemPointerUp);

        updateSprite();
    }

    /* ---------------------------------------------------------------------------------------- */
    
    /**
     * 
     */
    public function updateSprite()
    {
        var disposer = owner.get(Disposer);
        var sprite = owner.get(Sprite);

        if (sprite == null)
        {
            throw("Add Sprite instance first.");
        }

        if (_spriteConnectionDisposer != null)
        {
            _spriteConnectionDisposer.dispose();
        }

        _spriteConnectionDisposer = new Disposer();
        disposer.add(_spriteConnectionDisposer);

        _spriteConnectionDisposer.connect1(sprite.pointerDown, onPointerDown);

    }

    /* ---------------------------------------------------------------------------------------- */
    
    /**
     * 
     */
    private function onSystemPointerUp(e:PointerEvent)
    {
        if (_isDown && e.hit != null && e.hit.owner.getFromParents(ButtonMode) == this)
        {
            if (_defaultSound != null && playSound)
            {
                _defaultSound.play();
            }

            engaged.emit(e);
        }

        this._isDown = false;
    }
    
    /* ---------------------------------------------------------------------------------------- */
    
    /**
     * 
     */
    private function onPointerDown(e:PointerEvent)
    {
        this._isDown = true;
    }


    /* ---------------------------------------------------------------------------------------- */

    /*
    * 
    */
    private function onChanged(current:Sprite):Void
    {
        if (owner == null)
        {
            throw("No owner. You possibly added to an entity that already had ButtonMode.");
        }
    }
    
    /* ---------------------------------------------------------------------------------------- */

    override public function dispose()
    {
        super.dispose();

        engaged = null;
        _spriteConnectionDisposer = null;
    }

}























