package s2.behavior;

import flambe.animation.Behavior;

class Damping implements Behavior
{
	/**  */
	private static var TIME_MULT 	:Float = 60;
	/**  */
	private var _nAccel 			:Float = 0;
	/**  */
	private var _nPos 				:Float = 0;
	/**  */
	public var velocity 			:Float = 0;
	/**  */
	public var nM 					:Float = 10;
	/**  */
	public var nK 					:Float = 0.2;
	/**  */
	public var nDecay 				:Float = 0.9;
	/**  */
	public var target 	 			:Float = 0;
	/**  */
	public var id 					:String;

	/* ---------------------------------------------------------------------------------------- */

	/*
	*
	*/
	public function new(nStart:Float, nTarget:Float)
	{
		target = nTarget;
		_nPos = nStart;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	*
	*/
	public function update(dt:Float)
	{
		_nAccel = -(nK / nM) * (_nPos - target);
		velocity *= nDecay;
		velocity += _nAccel;
		_nPos += velocity;

		return _nPos;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	*
	*/
    public function isComplete () :Bool
    {
        return false;
    }
    
}























