
package com.nick.ultimatetrivia.components;

import flambe.Component;
import flambe.Entity;
import flambe.Log;
import flambe.System;
import flambe.Disposer;
import flambe.display.ImageSprite;
import flambe.display.FillSprite;
import flambe.display.TextSprite;
import flambe.asset.AssetPack;

import s2.display.SpriteUser;
import s2.localization.Locale;
import s2.util.StringUtil;

using s2.display.LayoutUtil;

/**
 * 
 * 
 * @author Seven2
 */
class Hud extends Component
{
	/**  */
	//private var _progress 		= new Entity();
	/**  */
	//private var _xOfT 			= new Entity();
	/**  */
	private var _box0  			= new Entity();
	/**  */
	private var _box1  			= new Entity();
	/**  */
	private var _numCorrect  	= new Entity();
	/**  */
	private var _numStrikes  	= new Entity();
	/**  */
	private var _pack 			:AssetPack;

	/* ---------------------------------------------------------------------------------------- */

	public function new(pack:AssetPack)
	{
		 _pack = pack;
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		var disposer = new Disposer();
		owner.add(disposer);

		var gt = System.root.get(GameTracker);

		if (!gt.isPersonalityQuiz())
		//if (gt.category != RATHER && gt.category != PERSONALITY)
		{
			var c_box0 = new ImageSprite(_pack.getTexture("stat_box"));
			_box0.add(c_box0);
			c_box0.setScale(0.72);
			c_box0.setXY(1074, 210);
			owner.addChild(_box0);

			var c_numCorrectLabel = Locale.getField("question.numCorrectLabel", 0, Center);
			c_numCorrectLabel.setXY(86, 5);
			_box0.addChild(new Entity().add(c_numCorrectLabel));

			var c_numCorrect = Locale.getField("question.numCorrect", 0, Center);
			c_numCorrect.setXY(86, 32);
			_numCorrect.add(c_numCorrect);
			_box0.addChild(_numCorrect);
		}

		if (gt.quizType == PROPERTY)
		{
			var c_box1 = new ImageSprite(_pack.getTexture("stat_box"));
			_box1.add(c_box1);
			c_box1.setScale(0.72);
			c_box1.setXY(1074, 299);
			owner.addChild(_box1);

			var c_numStrikesLabel = Locale.getField("question.numStrikesLabel", 0, Center);
			c_numStrikesLabel.setXY(86, 5);
			_box1.addChild(new Entity().add(c_numStrikesLabel));

			var c_numStrikes = Locale.getField("question.numStrikes", 0, Center);
			c_numStrikes.setXY(86, 32);
			_numStrikes.add(c_numStrikes);
			_box1.addChild(_numStrikes);
		}

		updateFields();

		disposer.connect0(gt.optionChanged, onOptionChange);
		disposer.connect0(gt.progressed, onOptionChange);
	}

	/* ---------------------------------------------------------------------------------------- */

	private function updateFields()
	{
		var gt = System.root.get(GameTracker);

		if (_numCorrect.get(TextSprite) != null)
		{
			var c_numCorrect = _numCorrect.get(TextSprite);
			c_numCorrect.text = StringUtil.zeroPad(gt.numCorrect, 2);
		}

		if (_numStrikes.get(TextSprite) != null)
		{
			var c_numStrikes = _numStrikes.get(TextSprite);

			var exes = "";

			for (i in 0...gt.numStrikes)
			{
				exes += "X";
			}

			c_numStrikes.text = exes;
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	public function onProgressed():Void
	{
		updateFields();
	}

	/* ---------------------------------------------------------------------------------------- */

	public function onOptionChange():Void
	{
		updateFields();
	}

	/* ---------------------------------------------------------------------------------------- */

	public function onResize()
	{
		//_progress.right().top();
		//_xOfT.left().top();
	}

}






























