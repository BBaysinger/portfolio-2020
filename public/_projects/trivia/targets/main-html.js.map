
package com.nick.ultimatetrivia.components;

import flambe.Component;
import flambe.Entity;
import flambe.Log;
import flambe.System;
import flambe.Disposer;
import flambe.display.FillSprite;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.display.TextSprite;
import flambe.asset.AssetPack;

import s2.display.SpriteUser;
import s2.localization.Locale;

using s2.display.LayoutUtil;

/**
 * 
 * 
 * @author Seven2
 */
class Heading extends SpriteUser
{
	/**  */
	private var _globalPack:AssetPack;
	/**  */
	private var _banner = new Entity();
	/**  */
	private var _icon = new Entity();
	/**  */
	private var _text = new Entity();
	/**  */
	private var _locale:String;

	/* ---------------------------------------------------------------------------------------- */

	public function new(globalPack:AssetPack, locale:String)
	{
		 super();

		 _globalPack = globalPack;
		 _locale = locale;
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		var disposer = new Disposer();
		owner.add(disposer);

		var gt = System.root.get(GameTracker);

		sprite.disablePointer();

		var c_banner = new ImageSprite(_globalPack.getTexture("head_banner"));
		c_banner.setXY(183, 103);
		_banner.add(c_banner);
		owner.addChild(_banner);

		var c_icon:ImageSprite;

		if (gt.quizType == PROPERTY && gt.category != null)
		{
			c_icon = new ImageSprite(_globalPack.getTexture("icons/" + Std.string(gt.category).toLowerCase()));
			c_icon.setScale(0.75);
		}
		else
		{
			c_icon = new ImageSprite(_globalPack.getTexture("icons/brain_coin"));
		}

		c_icon.setXY(73, 0);
		_icon.add(c_icon);
		_banner.addChild(_icon);

		var c_text = Locale.getField("global.heading", 0, Center);

		if (Locale.hasField(_locale))
		{
			c_text.text = Locale.getFormat(_locale).text.toUpperCase();
		}

		c_text.x._ = 673;
		_text.add(c_text);

		while (Sprite.getBounds(_text).width > 500)
		{
			c_text.setScale(c_text.scaleX._ - 0.01);
		}

		c_text.y._ = 172 - Sprite.getBounds(_text).height/2;

		owner.addChild(_text);
	}

	/* ---------------------------------------------------------------------------------------- */

	public function onResize()
	{
		
		//_banner.removeChild
		//_banner.center(-80).top(20);
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onRemoved()
	{
		super.onRemoved();
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function dispose()
	{
		super.dispose();
	}

}






























