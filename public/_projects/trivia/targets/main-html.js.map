
package s2.scene;

import flambe.animation.Behavior;
import flambe.animation.Ease;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.display.SubTexture;
import flambe.display.Texture;
import flambe.Entity;
import flambe.scene.Director;
import flambe.scene.Transition;
import flambe.script.AnimateTo;
import flambe.script.CallFunction;
import flambe.script.Delay;
import flambe.script.Parallel;
import flambe.script.Script;
import flambe.script.Sequence;
import flambe.swf.MovieSprite;
import flambe.System;

class DropTransition extends Transition {

	/** comment */
	public var _time :Float;
	/** comment */
	private var _tilesHigh :Int;
	/** comment */
	private var _tilesWide :Int;
	/** comment */
	private var _elapsed :Float;
	/** The texture */
	private var _texture :Texture;
	/** comment */
	private var _parallel :Parallel;

	/**
	 * @param  movie        The movie to use as a transition.
	 * @param  obscuredTime The time in seconds when the screen is completely obscured.
	 */
	@:keep public function new(time :Float, tilesWide :Int, tilesHigh :Int)
	{
		_time = time; // The time of the transition.
		_tilesWide = tilesWide;
		_tilesHigh = tilesHigh;
        _holder = new Entity();

	}

    override public function init (director :Director, from :Entity, to :Entity)
    {
        super.init(director, from, to);
        _elapsed = 0;

        // Creates a flattened texture snapshot to manipulate.
        _texture = System.renderer.createTexture(System.stage.width, System.stage.height);
        Sprite.render( from, _texture.graphics );

        _parallel = new Parallel();

        var textures :Array<SubTexture> = _texture.split(_tilesWide, _tilesHigh);
        for (i in 0...textures.length) {
        	
        	var tex :SubTexture = textures[i];
        	var sprite :ImageSprite = new ImageSprite(tex);
        	var box :Entity = new Entity()
        		.add(sprite.centerAnchor().setXY(tex.x + tex.width * 0.5, tex.y + tex.height * 0.5));

            var time :Float = Math.random() * _time;
            _parallel.add(new Sequence([
                new Delay(Math.random() * _time * .25),
                new Parallel([
                    new AnimateTo(sprite.rotation, -360 + Math.random() * 720, time, Ease.quadIn),
                    new AnimateTo(sprite.y, System.stage.height + tex.height, time, Ease.quadIn),
                ]),
                new CallFunction(function(){
                    box.dispose();
                    tex.dispose();
                })
            ]));

        	_holder.addChild(box);
        }

        _holder.add(new Script()).get(Script).run(_parallel);

        director.owner.addChild(_holder);
    }

    

    override public function update (dt :Float) :Bool
    {
     	return _parallel.update(0, _holder) >= 0;
    }

    override public function complete ()
    {
        _holder.dispose();
        _texture.dispose();
    }

	/** Holds the transition clip. */
	private var _holder :Entity;

}

