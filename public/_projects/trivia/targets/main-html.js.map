package com.nick.ultimatetrivia.components;

import flambe.Disposer;
import flambe.Entity;
import flambe.display.Sprite;
import flambe.input.PointerEvent;
import flambe.System;

import s2.display.SpriteUser;

class Fling2 extends SpriteUser
{
	/**  */
	private var _vx:Float=0;
	/**  */
	private var _vy:Float=0;
	/**  */
	private var _bx:Float=0;
	/**  */
	private var _by:Float=0;
	/**  */
	private var _offsetX:Float=0;
	/**  */
	private var _offsetY:Float=0;
	/**  */
	private var _dragged:Bool=false;
	/**  */
	private var _moveDisposer = new Disposer();
	/**  */
	private var _start:Float;
	/**  */
	private var _target:Entity;
	/**  */
	public var dist(get_dist, null):Float;

	/* ---------------------------------------------------------------------------------------- */

	private function new(target:Entity)
	{
		super(false);

		//_propName = propName;
		_target = target;
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		super.onAdded();

		var disposer = owner.get(Disposer);
        if (disposer == null) owner.add(disposer = new Disposer());

		disposer.connect1(sprite.pointerDown, mDown);
		disposer.connect1(System.pointer.up, mUp);
	}

	/* ---------------------------------------------------------------------------------------- */

	private function mDown(e:PointerEvent):Void
	{
		_dragged=true;
		_start = _target.get(Sprite).x._;
		_moveDisposer.connect1(System.pointer.move, mMove);

		_offsetX=_target.get(Sprite).x._-e.viewX;
		_offsetY=_target.get(Sprite).y._-e.viewY;
	}

	/* ---------------------------------------------------------------------------------------- */

	private function mUp(e:PointerEvent):Void
	{
		_dragged=false;
		_moveDisposer.dispose();
	}

	/* ---------------------------------------------------------------------------------------- */

	private function mMove(e:PointerEvent):Void
	{
		_target.get(Sprite).x._=e.viewX+_offsetX;
		//_target.get(Sprite).y._=e.viewY+_offsetY;

		_vx=System.pointer.x-_bx;
		_vy=System.pointer.y-_by;
		_bx=System.pointer.x;
		_by=System.pointer.y;

	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onUpdate(dt:Float):Void
	{
		super.onUpdate(dt);

		if(!_dragged)
		{
			if (_vx != 0) _target.get(Sprite).x._+=_vx;
			//_target.get(Sprite).y._+=_vy;
			_vx*=0.94;
			_vy*=0.94;
		}

		//Keep all this because it show how to constrain to bounds.
		// if (sprite.x-sprite.width/2<0)
		// {
		// 	sprite.x=sprite.width/2; vx*=-1;
		// }
		
		// if (sprite.x+sprite.width/2>stage.stageWidth)
		// {
		// 	sprite.x=stage.stageWidth-sprite.width/2; vx*=-1;
		// }
		
		// if (sprite.y-sprite.height/2<0)
		// {
		// 	sprite.y=sprite.height/2; vy*=-1;
		// }
		
		// if (sprite.y+sprite.height/2>stage.stageHeight)
		// {
		// 	sprite.y=stage.stageHeight-sprite.height/2; vy*=-1;
		// }

	}

	/* ---------------------------------------------------------------------------------------- */

	private function get_dist():Float
	{
		return Math.abs(_start - _target.get(Sprite).x._);
	}

}	































	
	