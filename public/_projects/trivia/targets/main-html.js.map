package s2.display;

import flambe.display.Graphics;
import flambe.display.Sprite;
import flambe.display.Texture;
import flambe.math.FMath;

/**
 * A sprite with multiple parts. This is used to overcome the 1024x1024 texture limit, which can be limiting for background images.
 */
class MultiTextureSprite extends Sprite
{

    /**  */
    private var _aTextures:Array<Texture>;
    /**  */
    private var _nRows:Int;
    /**  */
    private var _nCols:Int;
    /** Allows overlaping texture edges so gaps don't show when scaled. */
    private var _nOverlap:Int;

    public function new(aTextures:Array<Texture>, nCols:Int = null, nOverlap:Int = 0):Void
    {
        super();

        _aTextures = aTextures;

        if (nCols == null)
        {
            nCols = _aTextures.length;
        }

        _nOverlap = nOverlap;

        _nCols = nCols;
        _nRows = Math.ceil(_aTextures.length/_nCols);
    }

    /**
     * 
     */
    override public function draw (g :Graphics)
    {
        var nRow:Int;
        var nCol:Int;

        var nRowY:Int = 0;
        var nColX:Int = 0;

        for (i in 0..._aTextures.length)
        {
            nCol = i%_nCols;
            nRow = Math.floor(i/_nCols);

            if (nCol == 0 && nRow > 0)
            {
                nRowY += _aTextures[_nCols*(nRow-1)].height - _nOverlap * nRow;
            }

            if (nCol == 0)
            {
                nColX = 0;
            }
            else
            {
               nColX += _aTextures[i-1].width - _nOverlap * nCol; 
            }

            g.drawTexture(_aTextures[i], nColX, nRowY);
        }

    }

    /**
     * The "natural" width of this sprite, without any transformations being applied. Used for hit
     * testing. This does not consider child sprites, use Sprite.getBounds for that.
     */
    override public function getNaturalWidth () :Float
    {
        var nWidth:Int = 0;

        for (i in 0..._nCols)
        {
            nWidth += _aTextures[i].width - _nOverlap * i;
        }

        return nWidth;
    }

    /**
     * The "natural" height of this sprite, without any transformations being applied. Used for hit
     * testing. This does not consider child sprites, use Sprite.getBounds for that.
     */
    override public function getNaturalHeight () :Float
    {
        var nHeight:Int = 0;

        for (i in 0..._nRows)
        {
            nHeight += _aTextures[i * _nCols].height - _nOverlap * i;
        }

        return nHeight;
    }


}























