package s2.scene;

import flambe.animation.AnimatedFloat;
import flambe.animation.Sine;
import flambe.asset.AssetPack;
import flambe.Component;
import flambe.display.FillSprite;
import flambe.display.ImageSprite;
import flambe.display.PatternSprite;
import flambe.display.Sprite;
import flambe.display.Texture;
import flambe.Entity;
import flambe.math.FMath;
import flambe.math.Rectangle;
import flambe.scene.Scene;
import flambe.System;
import flambe.util.Disposable;
import flambe.util.Signal1;
import flambe.swf.Library;

import s2.loading.Assets;

using s2.display.LayoutUtil;

/**
 * The main preloader scene for our game. Can be reusesd across projects with minor modification.
 * @author Seven2
 */
class PreloadScene extends SceneLoader
{
	/** The asset pack used to setup the preloader. */
	private var _pack 				:AssetPack;
	/**  */
	private var _progress			:Entity;
	/**  */
	private var _total	 			:Entity;
	/**  */
	private var _width 				:AnimatedFloat;
	/**  */
	private var _successHandle 		:Disposable;
	/**  */	
	private var _progressHandle 	:Disposable;
	/** Used to keep track of screen resizing. */
	private var _resizeHandle  		:Disposable;
	/**  */	
	//private var _lib 				:Library;
	/**  */
	private var _widthHandle 		:Disposable;
	/** comment */
	//private var _backing :Entity;
	/** comment */
	//private var _container :Entity;
	/** comment */
	//private var _holder :Entity;

	private var _loadingBar 		= new Entity();

	/* ---------------------------------------------------------------------------------------- */
	
	public function new(pack :AssetPack) 
	{
		super();

		_pack = pack;
		_width = new AnimatedFloat(0);
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	override public function assetsReady():Void 
	{
		super.assetsReady();

		// Sets up the background image.
		// _backing = new Entity()
		// 	.add(new PatternSprite(_pack.getTexture("bg"), 1366, 768));
		
		var cProgress :Sprite = new ImageSprite(_pack.getTexture("loader_bar/progress")).centerAnchor();

		_progress = new Entity()
			.add(cProgress);

		_total = new Entity()
			.add(new ImageSprite(_pack.getTexture("loader_bar/total")).centerAnchor());

		//var loadingBar :Entity = new Entity()
		_loadingBar
			.add( new Sprite().setXY(683, 384) )
			.addChild( _total )
			.addChild( _progress );

		_loadingBar.get(Sprite).alpha.behavior = new Sine(1, 0.6, 1);

		//_container = new Entity()
		_container
			//.add(new Sprite())
			//.addChild(_backing)
			.addChild(_loadingBar);

		_width._ = 0;
		
		var cWidth :Float = cProgress.getNaturalWidth();
		cProgress.scissor = new Rectangle(-cWidth, 0, cWidth, cProgress.getNaturalHeight());
		_widthHandle = _width.changed.connect(function(v,_) {
			cProgress.scissor.x = v - cWidth;
		});

		//owner.addChild(_container);
		// onProgress(100,100);
		//_resizeHandle = System.stage.resize.connect(onResize);

		onResize();

	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	override public function onResize()
	{
		super.onResize();
		
		_loadingBar.centerX().centerY();
		// var scale :Float = Math.max(System.stage.width / 1366, System.stage.height / 768);
		// var nWidth :Float = 1366 * scale;
		// var nHeight :Float = 768 * scale;

		// // Reposition the container. (centered)
		// _container.get(Sprite)
		// 	.setScale(scale)
		// 	.setXY( (System.stage.width - nWidth) * 0.5 , (System.stage.height - nHeight) * 0.5 );
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	override private function onProgress (bytesLoaded :Float, bytesTotal :Float) :Void {
		var nPercent:Float = FMath.clamp(bytesLoaded / bytesTotal,0,1);
		var progressSprite:Sprite = _progress.get(Sprite);
		var w:Float = progressSprite.getNaturalWidth() * (nPercent);
		_width.animateTo(w, .2);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function onRemoved()
	{
		super.onRemoved();
		_widthHandle.dispose();
		//_resizeHandle.dispose();
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Fired when the loaded bytes have been updated.
	 */
	override public function onUpdate(dt:Float) 
	{
		super.onUpdate(dt);
		_width.update(dt);
	}
}