package s2.ui;

import flambe.display.Sprite;
import flambe.display.FillSprite;
import flambe.display.ImageSprite;
import flambe.Entity;
import flambe.Disposer;
import flambe.asset.AssetPack;
import flambe.input.PointerEvent;
import flambe.animation.Ease;
import flambe.util.Signal1;
import flambe.display.Texture;
import s2.util.TimeUtil;

import s2.display.SpriteUser;
import s2.display.ButtonMode;

/**
 * A button class designed to be extensible for creation of consistent button subclasses.
 * 
 * @author Bradley Baysinger / Seven2
 */
class BasicButton extends SpriteUser
{
	/** Global default that can be set at runtime. */
	public static var staticOffsetX:Float = 1;
	/** Global default that can be set at runtime. */
	public static var staticOffsetY:Float = 1;
	/** Global default that can be set at runtime. */
	public static var staticMinScale:Float = 1.0;
	/** Global default that can be set at runtime. */
	public static var staticMaxScale:Float = 1.1;

	/** A place to add additional graphics or text (See TextButton as an example). */
	private var _overlay = new Entity();
	/** Required default state. */
	private var _imageOut:Entity;
	/**
	* Optional state, automatically populated if available.
	*
	* Note that there isn't really an 'over' state on mobile, since there isn't a mouse pointer.
	* Only 'out' and 'down' are shown.
	*/
	private var _imageOver:Entity;
	/** Optional state, automatically populated if available. */
	private var _imageDown:Entity;
	/** If you need to identify buttons in your callbacks. */
	private var _id:String;
	/** The asset pack to pull all the states from. */
	private var _pack:AssetPack;
	/** Add fields to this, after added. */
	private var _stateHolder = new Entity();
	/** How much your button jumps when it's hovered or pressed. */
	private var offsetX:Float = staticOffsetX;
	/** How much your button jumps when it's hovered or pressed. */
	private var offsetY:Float = staticOffsetY;
	/** Because 'out' dispatches before 'up' on mobile, which is out of logical order in Flambe,
	so we use this to track in/out, and determine correct state to go to on 'up'. */
	private var _pointerIn:Bool = false;

	/** A place to add additional graphics or text (See TextButton as an example). */
	public var overlay(get_overlay, null):Entity;
	/** A shortcut to the hitArea entity's ButtonMode instance. */
	public var engaged(get_engaged, null):Signal1<PointerEvent>;
	/** Controls pointer mode, and dispatches when pointerDown AND pointer up have both occurred. */
	public var buttonMode(get_buttonMode, null):ButtonMode;
	/** Set how big your button is when it's not hovered or pressed. */
	public var minScale:Float = staticMinScale;
	/** Set how big your button gets when it's hovered or pressed. */
	public var maxScale:Float = staticMaxScale;
	/** Events are registered to this. */
	public var hitArea(default, null) = new Entity();
	/**  */
	public var index(default, null):Int = -1;

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	public function new(pack:AssetPack, id:String, nIndex:Int = -1)
	{
		super();

		_pack = pack;
		_id = id;

		index = nIndex;

		var c_stateHolder = new Sprite();
		c_stateHolder.setScale(minScale);
		_stateHolder.add(c_stateHolder);

		createStates();
		createHitArea();

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	override public function onAdded()
	{
		super.onAdded();

		owner.addChild(_stateHolder);
		owner.addChild(hitArea);

    	var disposer:Disposer;
    	owner.add(disposer = new Disposer());

    	var c_hitArea = hitArea.get(Sprite);

		disposer.connect1(c_hitArea.pointerIn, onPointerIn);
		disposer.connect1(c_hitArea.pointerDown, onPointerDown);
		disposer.connect1(c_hitArea.pointerOut, onPointerOut);
		disposer.connect1(c_hitArea.pointerUp, onPointerUp);

		owner.add(new TimeUtil());
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * Override this to use different types for states. See TextFluidButton.hx as an example.
	 */
	private function createStates()
	{
		var outTexture = _pack.getTexture(_id, false);
		var downTexture = _pack.getTexture(_id + "_down", false);
		var overTexture = _pack.getTexture(_id + "_over", false);

		var outState:Sprite = null;
		var downState:Sprite = null;
		var overState:Sprite = null;

		if (outTexture != null)
		{
			outState = instanceState(outTexture);
			outState.disablePointer();
			outState.centerAnchor();
		}
		else
		{
			throw("'" + _id + "' not found.");
		}

		if (overTexture != null)
		{
			overState = instanceState(overTexture);
			overState.disablePointer();
			overState.centerAnchor();
			overState.visible = false;
		}

		if (downTexture != null)
		{
			downState = instanceState(downTexture);
			downState.disablePointer();
			downState.centerAnchor();
			downState.visible = false;
		}

		addStates(outState, overState, downState);

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function instanceState(texture:Texture):Sprite
	{
		return new ImageSprite(texture);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function addStates(c_imageOut:Sprite, c_imageOver:Sprite, c_imageDown:Sprite)
	{
		_imageOut = new Entity();
		_imageOut.add(c_imageOut);
		_stateHolder.addChild(_imageOut);

		if (c_imageOver != null)
		{
			_imageOver = new Entity();
			_imageOver.add(c_imageOver);
			_stateHolder.addChild(_imageOver);
		}

		if (c_imageDown != null)
		{
			_imageDown = new Entity();
			_imageDown.add(c_imageDown);
			_stateHolder.addChild(_imageDown);
		}

		_stateHolder.addChild(_overlay);

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function get_overlay():Entity
	{
		return _overlay;
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function createHitArea()
	{
		var buttonMode = hitArea.get(ButtonMode);
		var c_imageOut = _imageOut.get(Sprite);

		var c_hitArea = new FillSprite(0x005500, c_imageOut.getNaturalWidth(), c_imageOut.getNaturalHeight());
		c_hitArea.alpha._ = 0.0;
		c_hitArea.centerAnchor();
		hitArea.add(c_hitArea);

        if (buttonMode == null)
    	{
    		hitArea.add(buttonMode = new ButtonMode(index));
    	}
    	else
    	{
    		buttonMode.updateSprite();
    	}

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function onPointerIn(e:PointerEvent)
	{
		_pointerIn = true;

		var c_stateHolder = _stateHolder.get(Sprite);
		var c_imageOut = _imageOut.get(Sprite);

		if (_imageOver != null)
		{
			var c_imageOver = _imageOver.get(Sprite);

			c_imageOver.visible = true;
			c_imageOut.visible = false;
		}

		c_stateHolder.scaleX.animateTo(maxScale, .3, Ease.backOut);
		c_stateHolder.scaleY.animateTo(maxScale, .3, Ease.backOut);

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function onPointerDown(e:PointerEvent)
	{
		var c_stateHolder = _stateHolder.get(Sprite);
		var c_imageOut = _imageOut.get(Sprite);

		c_stateHolder.setXY(offsetX, offsetY);

		if (_imageDown != null)
		{
			var c_imageDown = _imageDown.get(Sprite);

			c_imageDown.visible = true;

			if (_imageOver != null)
			{
				var c_imageOver = _imageOver.get(Sprite);

				c_imageOver.visible = false;
			}
			else
			{
				c_imageOut.visible = false;
			}

		}

		c_stateHolder.scaleX.animateTo(maxScale, .3, Ease.backOut);
		c_stateHolder.scaleY.animateTo(maxScale, .3, Ease.backOut);

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function onPointerUp(e:PointerEvent)
	{
		//'pointerOut' emits immediatley before 'pointerUp' on touch release, which is out of logical order,
		//so we check to see if we are still hovered at this point before we try to go to 'over',
		//so it doesn't go to the wrong state after a touch release. A result is that the 'up' state is skipped
		//on touch events (there isn't a hover state anyways on mob).
		if (_pointerIn)
		{
			up();
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	private function up()
	{			
		var c_stateHolder = _stateHolder.get(Sprite);
		var c_imageOut = _imageOut.get(Sprite);

		c_stateHolder.setXY(0, 0);

		if (_imageDown != null)
		{
			var c_imageDown = _imageDown.get(Sprite);
			c_imageDown.visible = false;
		}

		if (_imageOver != null)
		{
			var c_imageOver = _imageOver.get(Sprite);
			c_imageOver.visible = true;
		}
		else
		{
			c_imageOut.visible = true;
		}

		c_stateHolder.scaleX.animateTo(maxScale, .3, Ease.backOut);
		c_stateHolder.scaleY.animateTo(maxScale, .3, Ease.backOut);

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function onPointerOut(e:PointerEvent)
	{
		var c_stateHolder = _stateHolder.get(Sprite);
		var c_imageOut = _imageOut.get(Sprite);

		c_stateHolder.setXY(0, 0);

		c_imageOut.visible = true;

		if (_imageOver != null)
		{
			_imageOver.get(Sprite).visible = false;
		}

		if (_imageDown != null)
		{
			_imageDown.get(Sprite).visible = false;
		}

		c_stateHolder.scaleX.animateTo(minScale, .3, Ease.backOut);
		c_stateHolder.scaleY.animateTo(minScale, .3, Ease.backOut);

		_pointerIn = false;

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	public function get_engaged():Signal1<PointerEvent>
	{
		return hitArea.get(ButtonMode).engaged;
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	public function get_buttonMode():ButtonMode
	{
		return hitArea.get(ButtonMode);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	override public function dispose()
	{
		super.dispose();

		hitArea = null;
		_stateHolder = null;

		_imageOut = null;
		_imageOver = null;
		_imageDown = null;
		_overlay = null;
		_pack = null;

	}

}
























