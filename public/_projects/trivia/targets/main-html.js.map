package s2.scene;

import flambe.animation.Ease;
import flambe.asset.AssetPack;
import flambe.asset.Manifest;
import flambe.Component;
import flambe.Entity;
import flambe.scene.Director;
import flambe.scene.Scene;
import flambe.scene.Transition;
import flambe.System;
import flambe.util.Assert;
import flambe.util.Signal0;
import flambe.util.SignalConnection;
import s2.loading.Assets;
import s2.scene.*;

/**
 * ...
 * @author Kipp Ashford
 */
class Scenes 
{
	/**  */
	private static var _defaultTransition 			:Transition;
	// private static var _DefaultTransition 			:Class<Transition>;
	// private static var _DefaultTransitionParams 	:Array<Dynamic>;

	public static var director(default, null)		:Director;
	/** The scene to use for preloading */
	public static var preloadScene (default, null) :SceneLoader;
	/** Fires when we have successfully gone to a scene and it is fully visible. */
	public static var shown (default, null) :Signal0;

	private static var _shownBind :SignalConnection;

	/* ---------------------------------------------------------------------------------------- */
	
	public static function init(?preloadScene :SceneLoader)
	{
		director = new Director();
		shown = new Signal0();
		System.root.addChild(new Entity().add(director),false); // Adds the director to the root entity.

		setPreloadScene( preloadScene != null ? preloadScene : new SceneLoader() );
	}

	/* ---------------------------------------------------------------------------------------- */
	
	public static function setPreloadScene(preloadScene :SceneLoader)
	{
		Scenes.preloadScene = preloadScene;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Goes to a section.
	 * 
	 * @param	SceneClass		Pass in the scene class you would like to go to. If the scene is already in the stack, will go back to that scene instead.
	 * @param	?transition		Overrides the default transition used for the game.
	 */
	public static function goto(SceneClass:Class<Scene>, ?transition :Transition, ?force :Bool):Void
	{
		if (transition == null) {
			transition = getTransition();
		}

		var className:String = Type.getClassName(SceneClass);

		if (!force) {		
			for (item in director.scenes) 
			{
				var c:Component = item.firstComponent;
				while (c != null)
				{
					if ( Std.is(c, SceneClass) && (Type.getClassName(Type.getClass(c)) == className) )
					{
						director.unwindToScene(item, transition);
						return; // Stops executing the function.
					}	
					c = c.next;
				}
			}
		}

		var scene :Entity = checkForPreload(Type.createInstance(SceneClass, []), true, transition);

		// Unwind and only use the transition if it's a scene loader.
		director.unwindToScene(scene, transition);
		// director.unwindToScene(scene, scene.get(SceneLoader) != null ? null : transition);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Checks for preloading and returns either the scene to go to or the preloader
	 * @param  scene :Scene        [description]
	 * @return       [description]
	 */
	private static function checkForPreload(scene :Scene, ?unwind :Bool = true, ?transition :Transition) :Entity
	{
		if (_shownBind != null) {
			_shownBind.dispose();			
		}

		_shownBind = scene.shown.connect(function() {
			shown.emit();
		});
		_shownBind.once();

		if (Std.is(scene, BaseScene)) {
			var packs :Array<String> = cast(scene, BaseScene).requiredPacks;

			for (pack in packs) {

				if (Assets.getCached(pack) == null) {
					// We need to preload.
					preloadScene.setNextScene(cast(scene, BaseScene), unwind, transition);
					preloadScene.load();
					return new Entity().add(preloadScene);
				}

			}

			var manifests:Map<String, Manifest> = cast(scene, BaseScene).dynamicManifests;

			for (manifestId in manifests.keys()) {

				if (Assets.getCached(manifestId) == null) {
					// We need to preload.
					preloadScene.setNextScene(cast(scene, BaseScene), unwind, transition);
					preloadScene.load();
					return new Entity().add(preloadScene);
				}

			}

			var assets :Assets = new Assets(packs, manifests);
			assets.load();
			cast(scene, BaseScene).injectAssets(assets); // Already cached, just simulate loading real quick.
		}


		return new Entity().add(scene);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Pushes a scene on top of the stack. Useful for pause dialogs, etc.
	 * 
	 * @param	SceneClass
	 * @param	?transition
	 */
	public static function push(SceneClass:Class<Scene>, ?transition:Transition = null) :Void 
	{
		transition = transition != null ? transition : getTransition();
		var scene :Entity = checkForPreload(Type.createInstance(SceneClass, []), false, transition);
		// var load :SceneLoader = scene.get(SceneLoader);

		// if (load != null && Std.is(load, SceneLoader)) {
			// only use the transition if it's a scene loader.
				
		// }
		// Unwind and only use the transition if it's a scene loader.
		director.pushScene(scene, transition);
		// director.pushScene(scene, scene.get(SceneLoader) != null ? null : transition);
	}

	/**
	 * Like push, however uses a popup scene which injects the assets from the scene below
	 * (we won't use a preloader)
	 * 
	 * @param  scene :Popup        [description]
	 * @return       [description]
	 */
	public static function popup(SceneClass :Class<Popup>, ?transition :Transition = null) :Popup
	{
		transition = transition != null ? transition : getTransition();
		var topScene = director.topScene.get(BaseScene);
		var scene :Popup = Type.createInstance(SceneClass, []);
		Assert.that(topScene != null, "The topmost scene is not a BaseScene.", [SceneClass]);
	    scene.injectAssets(topScene._assets);
	    Scenes.director.pushScene(new Entity().add(scene));
	    return scene;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Sets the default transition to use for scenes.
	 * @param  newDefault<Dynamic> =             null [description]
	 * @param  params<Dynamic>     =             null [description]
	 * @return                     [description]
	 */
	public static function defaultTransition(newDefault :Transition = null) :Void
	{
		_defaultTransition = newDefault;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	public static function getTransition() :Transition 
	{
		// if (_DefaultTransition != null) {
		// 	return Type.createInstance(_DefaultTransition, _DefaultTransitionParams);
		// }
		return _defaultTransition;
	}

	
}