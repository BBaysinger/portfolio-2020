package s2.localization;

import s2.localization.Locale;
import flambe.asset.AssetPack;
import flambe.asset.Manifest;
import flambe.display.Font;
import haxe.xml.Fast;

using Lambda;
using Std;

class DParser implements LocaleParser {

	/* ---------------------------------------------------------------------------------------- */

	public function new()
	{

	}

	/* ---------------------------------------------------------------------------------------- */

	public function parseFonts(data:Dynamic):Manifest
	{
		var fontManifest:Manifest = new Manifest();

		var fonts:Array<String> = [];

		if(data.is(Xml))
		{
			var x:Xml = data;

			// The level of the document we're currently searching.
			var section:Iterator<Xml> = x.firstElement().elements();

			for(node in section)
			{
				var sectionStrings:Iterator<Xml> = node.elements();

				for(node in sectionStrings)
				{
					var fontName:String = node.get('font');

					if(fonts.indexOf(fontName) == -1 && fontName != null)
					{
						fontManifest.add(fontName + ".fnt", fontName + ".fnt");
						fonts.push(fontName);
					}
				}
			}
		}

		return fontManifest;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Parses the font definitions to determine the atlases to load.
	 * 
	 * @param  pack :AssetPack    [description]
	 * @return      [description]
	 */
	public function parseDefinitions(definitionPack :AssetPack) :Manifest
	{
		var fontManifest :Manifest = new Manifest();
		for (entry in definitionPack.manifest) {
			fontManifest.add(entry.url, entry.name); // Re-add because of how font formats work.
			
			var file = definitionPack.getFile(entry.name).toString();
			var lastID = 0;

			do {
				var prev = lastID;
				var startID = file.indexOf("file=\"", prev);
				var endID = -1;

				if (startID > -1) {
					startID += 6; // The number of characters in 'file="';
					endID = file.indexOf("\"", startID);
 					var filename = file.substring(startID, endID);
 					fontManifest.add(filename.split(".")[0], filename); // Add the image file.
				}

				lastID = endID;

			} while (lastID > -1);

			definitionPack.getFile(entry.name).dispose(); // Dispose the font definition (will be re-loaded)
		}

		return fontManifest;
	}
	
	/* ---------------------------------------------------------------------------------------- */

	public function parseStrings(data:Dynamic, pack:AssetPack):Map<String, StringFormat>
	{
		var formats:Map<String, StringFormat> = new Map();
		var fonts:Map<String, Font> = new Map(); // We don't want to create a bunch of font instances over and over.

		if(data.is(Xml))
		{
			var x:Xml = data;
			var section:Iterator<Xml> = x.firstElement().elements();

			for (node in section) 
			{
				var sectionStrings:Iterator<Xml> = node.elements();

				// prepended to the id to allow nested selection, example:"store.plate".
				var parentNodeName:String = node.nodeName;

				for(node in sectionStrings)
				{
					var fontName :String = node.get("font");
					var font :Font = null;
					var nScale :Float = node.get("fontScale") == null ? 1 : Std.parseFloat(node.get("fontScale"));
					var format:StringFormat = null;

					if (fontName != null)
					{
						font = fonts.exists(fontName) ? fonts.get(fontName) : new Font( pack, fontName).disposeFiles();
						fonts.set(fontName, font);
					}

					format = {
						id : parentNodeName + '.' + node.nodeName,
						font : font,
						lineHeight : Std.parseFloat(node.get("lineHeight")),
						scale : nScale,
						text : (node.firstChild() == null) ? "" : node.firstChild().nodeValue,//Accomodate empties.
						offsetX : node.get("offsetX") == null ? 0 : Std.parseFloat(node.get("offsetX")),
						offsetY : node.get("offsetY") == null ? 0 : Std.parseFloat(node.get("offsetY")),
					};

					formats.set(format.id, format);					
				}

			}		
				
		}

		return formats;

	}

}




























