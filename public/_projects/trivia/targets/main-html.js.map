package s2.scene;

import flambe.animation.Ease;
import flambe.display.FillSprite;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.Disposer;
import flambe.Entity;
import flambe.math.FMath;
import flambe.math.Matrix;
import flambe.math.Point;
import flambe.math.Rectangle;
import flambe.script.AnimateTo;
import flambe.script.CallFunction;
import flambe.script.Delay;
import flambe.script.Parallel;
import flambe.script.Script;
import flambe.script.Sequence;
import flambe.System;
import s2.localization.Locale;
import s2.scene.AutoFillScene;
import s2.scene.Scenes;
import s2.util.MatrixUtil;
import s2.util.Positioning;

using s2.display.LayoutUtil;

enum Position
{
	topRight(vertical :Float, horizontal :Float, ?units :Units);
	topLeft(vertical :Float, horizontal :Float, ?units :Units);
	topCenter(vertical :Float, horizontal :Float, ?units :Units);
	bottomRight(vertical :Float, horizontal :Float, ?units :Units);
	bottomCenter(vertical :Float, horizontal :Float, ?units :Units);
	bottomLeft(vertical :Float, horizontal :Float, ?units :Units);
	centerRight(vertical :Float, horizontal :Float, ?units :Units);
	centerCenter(vertical :Float, horizontal :Float, ?units :Units);
	centerLeft(vertical :Float, horizontal :Float, ?units :Units);
}

/**
 * Base class to create popups. Typically for in-game tutorials.
 */
class Popup extends AutoFillScene
{
	/** comment */
	private var _frame :Entity;

	/** The items to highlight. */
	private var _highlights :Array<Entity>;
	/** The copies we made. */
	private var _copies :Array<Entity>;
	/** comment */
	private var _visible :Bool = false;
	/** If autoHide set, hide in that number of seconds. */
	private var _autoHide :Float = -1;
	/** comment */
	private var _elapsed :Float = 0;
	/** comment */
	private var _dialog :Entity;
	/** comment */
	private var _positioned :Bool = false;
	/** comment */
	private var _position :Position;

	/* ---------------------------------------------------------------------------------------- */
	
	@:keep public function new() :Void
	{
	    super();
	    this.opaque = false;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	public function highlight(items :Array<Entity>) :Popup
	{
		_highlights = items;
		// _highlights = [];
		_copies = [];

		var scratch :Rectangle = new Rectangle();
		var xy :Point = new Point();
		for (i in 0...items.length) {
			scratch = Sprite.getBounds(items[i], scratch);

			// Bounds in global coordinates.
			xy = Positioning.localToGlobal(items[i].parent, scratch.x, scratch.y, xy);
			xy = Positioning.globalToLocal(_container, xy.x, xy.y, xy);

			var wm = items[i].get(Sprite).getViewMatrix(); // Get the global matrix and calculate scale based on that.
			var scaleX = MatrixUtil.getScaleX(wm); // The global world scale of the item.
			var scaleY = MatrixUtil.getScaleY(wm); // The global world scale of the item.
			// var rotation = MatrixUtil.getRotation(wm); // The global rotation of the item.
			// var rotation = MatrixUtil.getRotation(items[i].parent.getFromParents(Sprite).getViewMatrix()); // The global rotation of the item.
			// trace( MatrixUtil.getRotation(items[i].get(Sprite).getLocalMatrix()) - rotation);
			var texture = System.renderer.createTexture(Math.ceil(scratch.width * scaleX), Math.ceil(scratch.height * scaleY));
			texture.graphics.scale(scaleX, scaleY);
			// texture.graphics.rotate(rotation + MatrixUtil.getRotation(items[i].get(Sprite).getViewMatrix()) );
			// texture.graphics.rotate(-rotation);
			// texture.graphics.rotate(rotation);
			texture.graphics.translate(-scratch.x, -scratch.y);
			Sprite.render(items[i], texture.graphics); // Draw a snapshot to the graphics.

			var itemCopy = new Entity().add(new ImageSprite(texture)
				.setXY(xy.x, xy.y));
			_copies.push(itemCopy);
			_container.addChild(itemCopy);
		}

	    return this;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Makes the popup hide after a given number of seconds.
	 * @param seconds :Float [description]
	 */
	public function setAutoHide(seconds :Float) :Popup
	{
		_autoHide = seconds;
	    return this;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Makes the popup hide after a given number of seconds.
	 * @param seconds :Float [description]
	 */
	public function clickToDismiss() :Popup
	{
		owner.get(Disposer).connect1(_container.get(Sprite).pointerUp, function(e){
			if (_visible) {
				hide();
			}
		});
	    return this;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function onUpdate(dt :Float) :Void
	{
	    if (_visible) {
	    	_elapsed += dt;
	    	if (_autoHide > 0 && _elapsed >= _autoHide) {
	    		hide();
	    	}

	    }
	}

	/* ---------------------------------------------------------------------------------------- */
	
	public function addDialog(localizationID :String, position :Position) :Popup
	{
		if (_dialog != null) {
			_dialog.dispose();
		}

	    _dialog = new Entity()
	    	.add(Locale.getField(localizationID).centerAnchor());

	    _container.addChild(_dialog);
	    switch (position) {
			case topRight(vertical, horizontal, units):
				_dialog.top(vertical, units).right(horizontal, units);

			case topLeft(vertical, horizontal, units):
				_dialog.top(vertical, units).left(horizontal, units);

			case topCenter(vertical, horizontal, units):
				_dialog.top(vertical, units).centerX(horizontal, units);

			case bottomRight(vertical, horizontal, units):
				_dialog.bottom(vertical, units).left(horizontal, units);

			case bottomCenter(vertical, horizontal, units):
				_dialog.bottom(vertical, units).centerX(horizontal, units);

			case bottomLeft(vertical, horizontal, units):
				_dialog.bottom(vertical, units).left(horizontal, units);

			case centerRight(vertical, horizontal, units):
				_dialog.centerY(vertical, units).right(horizontal, units);

			case centerCenter(vertical, horizontal, units):
				_dialog.centerY(vertical, units).centerX(horizontal, units);

			case centerLeft(vertical, horizontal, units):
				_dialog.centerY(vertical, units).left(horizontal, units);

	    }
	    var prevScale = _dialog.get(Sprite).scaleX._;
	    _dialog.get(Sprite).setScale(0.2);
	    _dialog.get(Sprite).setAlpha(0);
	    _dialog.add(new Script()).get(Script).run(new Sequence([
	    	new Delay(0.1),
	    	new Parallel([
	    		new AnimateTo(_dialog.get(Sprite).alpha, 1, 0.2),
	    		new AnimateTo(_dialog.get(Sprite).scaleX, prevScale, 0.8, Ease.backOut),
	    		new AnimateTo(_dialog.get(Sprite).scaleY, prevScale, 0.8, Ease.backOut)
	    	])
	    ]));
	    return this;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Hides the scene.
	 * @return [description]
	 */
	public function hide():Void
	{
   		_visible = false;
		owner.add(new Script()).get(Script).run(new Sequence([
			new AnimateTo(_backing.get(Sprite).alpha, 0, 0.2, Ease.quadOut),
			new CallFunction(function(){
				if (_copies != null) {
					var ii:Int = _copies.length;
					while(ii-->0) {
						var tex = _copies[ii].get(ImageSprite).texture;
						_copies[ii].dispose();
						tex.dispose();
					}
				}
				Scenes.director.popScene();
			})
		]));

		if (_dialog != null) {
		    _dialog.add(new Script()).get(Script).run(new Parallel([
	    		new AnimateTo(_dialog.get(Sprite).scaleX, 0.01, 0.3, Ease.quadIn),
	    		new AnimateTo(_dialog.get(Sprite).scaleY, 0.01, 0.3, Ease.quadIn)
		    ]));

		}
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function assetsReady():Void
	{
		super.assetsReady();
		
	    this.setBackground(new FillSprite(0,__.standardWidth, __.standardHeight).setAlpha(0));
	    _frame = new Entity()
	    	.add(new Sprite());
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function onShown() :Void
	{
		owner.add(new Script()).get(Script).run(new Sequence([
			new AnimateTo(_backing.get(Sprite).alpha, 0.8, 0.2, Ease.quadOut),
			new CallFunction(function(){
				_visible = true;
			})
		]));
	}

}