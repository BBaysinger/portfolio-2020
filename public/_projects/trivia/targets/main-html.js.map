	/**  */
	private var _questionDisplay 		= new Entity();
	/**  */
	private var _question 				:Question;
	/**  */
	private var _bar 					= new Entity();
	/**  */
	private var _quizPackId				:String;
	
	/* ---------------------------------------------------------------------------------------- */

	@:keep public function new()
	{
		super();

		var gt = System.root.get(GameTracker);

		_headLocale = "categoryNames." + Std.string(gt.category).toLowerCase();

		requiredPacks.push('question_scene');

		_quizPackId = "assets_";
		_quizPackId += (gt.quizType == PROPERTY) ? "p_" : (gt.quizType == TOPIC) ? "t_" : "oops_";
		_quizPackId += Std.string(gt.category).toLowerCase();

		requiredPacks.push(_quizPackId);
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function assetsReady():Void
	{
		super.assetsReady();

		var disposer = owner.get(Disposer);
		var pack :AssetPack = _assets.get('question_scene');
		var globalPack :AssetPack = _assets.get('global');
		var questionPack :AssetPack = _assets.get(_quizPackId);
		var gt = System.root.get(GameTracker);

		MusicManager.loopSoundStandard(globalPack, "sfx/utg_gameplay_quiz_musicloopv1", 1);

		var questions = gt.questions;
		
