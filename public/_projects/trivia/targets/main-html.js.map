package s2.util;

import flambe.Component;
import flambe.script.Script;
import flambe.script.Sequence;
import flambe.script.Repeat;
import flambe.script.Delay;
import flambe.script.CallFunction;

/*
* Provides the ability to make timeouts with the same syntax as native JS/AS.
* Add an instance to an entity, and call setTimeout() (milliseconds) or just timeout() if you prefer seconds.
* Then you don't have to import a bunch of crap just to do a quick timeout.
* Call clear() with the ID of your timeout or interval to clear it.
*/
class TimeUtil extends Component
{
	/*  */
	private var _curr:Int = 0;
	/*  */
	private var _seqs:Array<Sequence>;
	
	/* ---------------------------------------------------------------------------------------- */

	public function new()
	{
		_seqs = [];
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Emulates as/js setTimeout, respects milliseconds.
	*/
	public function setTimeout(fn:Void -> Void, milliseconds:Int, ?params:Array<Dynamic> = null):Int
	{
		return timeout(fn, milliseconds/1000, params);
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Emulates as/js setTimeout, but respects seconds, not milliseconds.
	*/
	public function timeout(fn:Dynamic, seconds:Float, ?params:Array<Dynamic> = null):Int
	{
		_curr++;

		var script = owner.get(Script);

		if (script == null)
		{
			script = new Script();
			owner.add(script);
		}

		function call()
		{
			Reflect.callMethod(null, fn, params);
		}

		var seq = new Sequence();
		seq.add(new Delay(seconds));
		seq.add(new CallFunction(call));

		_seqs[_curr] = seq;

		script.run(seq);

		return _curr;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Emulates as/js setInterval, respects milliseconds.
	*/
	public function setInterval(fn:Void -> Void, milliseconds:Int, ?params:Array<Dynamic> = null):Int
	{
		return interval(fn, milliseconds/1000, params);
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Emulates as/js setInterval, but respects seconds, not milliseconds.
	*/
	public function interval(fn:Dynamic, seconds:Float, ?params:Array<Dynamic> = null):Int
	{
		_curr++;

		var script = owner.get(Script);

		if (script == null)
		{
			script = new Script();
			owner.add(script);
		}

		function call()
		{
			Reflect.callMethod(null, fn, params);
		}

		var seq = new Sequence();

		var repeatSeq = new Sequence();
		repeatSeq.add(new Delay(seconds));
		repeatSeq.add(new CallFunction(call));

		var repeat = new Repeat(repeatSeq, -1);

		seq.add(repeat);

		_seqs[_curr] = seq;

		script.run(seq);

		return _curr;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Clears sequences created by any of the timing utils.
	*/
	public function clear(id:Int, ?bark:Bool = true):Void
	{
		var seq = _seqs[id];

		if (seq == null)
		{
			if (bark)
			{
				throw("No timer or interval by id: " + id);
			}
		}
		else
		{
			seq.removeAll();
			_seqs[id] = null;
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	public function clearAll():Void
	{
		for (i in 0..._seqs.length)
		{
			if (_seqs[i] != null)
			{
				_seqs[i].removeAll();
				_seqs[i] = null;
			}

		}

	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	override public function dispose():Void
	{
		super.dispose();
		for (i in 0..._seqs.length)
		{
			if (_seqs[i] != null) clear(i);
		}

		_seqs = [];

	}

}

























