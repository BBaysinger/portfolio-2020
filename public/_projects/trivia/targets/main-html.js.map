package s2.util;

import flambe.asset.Manifest;

using StringTools;

/**
 * @author Seven2
 */
class PathUtil
{

	public static function absoluteToRelative(startPath :String, otherPath :String) :Null<String>
	{
		#if html
		untyped console.log("Start Path: " + startPath + " - end path: " + otherPath);
		#end
		if (sameDomain(startPath, otherPath)) {
			var path1 :Array<String> = startPath.replace("http://","").replace("https://","").split("/");
			var path2 :Array<String> = otherPath.replace("http://","").replace("https://","").split("/");
			var host1 :String = path1.shift();
			var host2 :String = path2.shift();

			if ( path1[path1.length - 1] == "" )
			{
				path1.pop();
			}

			// Trims off all the same paths.
			var i :Int = 0;
			var end :Int = Math.floor(Math.min(path1.length, path2.length));
			while (i++ < end) {
				if (path1[0] == path2[0]) {
					path1.splice(0,1);
					path2.splice(0,1);
				} else {
					i = end+1;
				}
			}

			var sRelative :String = "";
			i = path1.length;
			trace("Path1 length: " + i);
			while (i-->0) {
				sRelative += "../";
			}

		#if html
		untyped console.log("Relative path: " + sRelative + path2.join("/"));
		#end

			return sRelative + path2.join("/");
		}

        return null;
	}


    /**
     * Check to see if data is in the same domain or not.
     * @param  unrestricted :String       The unrestricted domain. This could be from the same domain or a different domain.
     * @param  restricted   :String       The restricted domain. This is the safe relative path domain.
     * 
     * @return The unrestricted domain if the fully qualified domain matches the current browser's domain
     *             or the restricted domain if they do not match.
     */
    public static function sameDomain(path1 :String, path2 :String) :Bool
    {
		var host1 = getHost(path1);    	
		var host2 = getHost(path2);    	
		if (host1 != null && host2 != null && host1 == host2) {
			return true;
		}
    	return false;
    }

    /* ---------------------------------------------------------------------------------------- */
    
    public static function getHost(path :String) :Null<String> {
    	if (path.startsWith("http://") || path.startsWith("https://")) {
    		return path.replace("http://","").replace("https://","").split("/")[0];
    	}
    	return null;
    }

}