package com.nick.ultimatetrivia.scenes;

import com.nick.ultimatetrivia.components.GameTracker;

import flambe.asset.AssetPack;
import flambe.display.Font;
import flambe.display.ImageSprite;
import flambe.display.FillSprite;
import flambe.display.Sprite;
import flambe.Disposer;
import flambe.Entity;
import flambe.input.PointerEvent;
import flambe.math.Rectangle;
import flambe.System;
import flambe.display.Texture;
import flambe.script.Script;
import flambe.script.AnimateBy;
import flambe.script.Repeat;

import flambe.util.SignalConnection;
import s2.client.Config;
import s2.display.ButtonMode;
import s2.display.MultiTextureSprite;
import s2.ui.TextFluidButton;
import s2.ui.BasicButton;
import s2.scene.AutoFillScene;
import s2.scene.Scenes;
import s2.sound.MusicManager;
import s2.util.Utils;
import s2.localization.Locale;
import s2.util.TimeUtil;
import s2.ui.TextButton;

using s2.display.LayoutUtil;
using s2.display.SizeSprite;

import com.nick.ultimatetrivia.components.ConfettiLayer;

/**
 * Title screen entry point.
 * @author Seven2
 */
class TitleScene extends AutoFillScene
{
	/* The property logo. */
	private var _logo 	 				= new Entity();
	/* The game title */
	private var _title 					= new Entity();
	/* The game title */
	private var _shards1				= new Entity();
	/* The game title */
	private var _head 					= new Entity();
	/** Click/tap to play message. */
	private var _play 					= new Entity();
	/**  */
	private var _btnMute				= new Entity();
	/**  */
	private var _btnPlayUpConnection 	:SignalConnection;
	/**  */
	private var _lines 					= new Array<Entity>();
	/**  */
	private var _linesHolder 			= new Entity();


	/* ---------------------------------------------------------------------------------------- */

	@:keep public function new()
	{
		super();
		requiredPacks.push('title_scene');
		requiredPacks.push('global');

		var gt:GameTracker = System.root.get(GameTracker);

		if (!gt.inited)
		{
			//Loading here so it can be factored into preloader progress. The concequence is questions
			//aren't ready until after assets are loaded for title screen. File is 270kb at Beta, and may be expanded later.
			requiredPacks.push('data');
		}
		
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * Triggered when all assets have been loaded and are available.
	 */
	override public function assetsReady():Void
	{		
		var disposer = owner.get(Disposer);
        if (disposer == null) owner.add(disposer = new Disposer());
		var timeUtil = owner.get(TimeUtil);
        if (timeUtil == null) owner.add(timeUtil = new TimeUtil());

		var pack :AssetPack = _assets.get('title_scene');
		var globalPack :AssetPack = _assets.get('global');
		var dataPack :AssetPack;

		MusicManager.loopSoundStandard(globalPack, "sfx/utg_gameplay_quiz_musicloopv1", 1);

		var gt:GameTracker = System.root.get(GameTracker);

		if (!gt.inited)
		{
			dataPack = _assets.get('data');
			gt.init(dataPack.getFile("questions.xml"));
		}

		ButtonMode.initialize(globalPack.getSound("sfx/answer_button_click"));

		// Set the background image.
		setBackground(new SizeSprite(1366, 768));

		var textures:Array<Texture> = [];

		for (i in 0...12)
		{
			textures.push(globalPack.getTexture("fill_bg"));
		}

		var c_lineHolder = new Sprite().setXY(990, 470);
		c_lineHolder.disablePointer();
		_linesHolder.add(c_lineHolder);
		_container.addChild(_linesHolder);

		var c_line:Sprite;

		for (i in 0...120)
		{
			_lines[i] = new Entity();
			c_line = new FillSprite(0xc9eb1e, ((i % 2 == 0) ? 300 : 200), 1);
			c_line.rotation._ = i / 120 * 360;
			_lines[i].add(c_line);
			_linesHolder.addChild(_lines[i]);
		}

		owner.add(new Script());
		var by = new AnimateBy(c_lineHolder.rotation, 360, 40);
		var repeat = new Repeat(by);
		owner.get(Script).run(repeat);

		var c_fill = new MultiTextureSprite(textures, 6);
		_backing.addChild(new Entity().add(c_fill));

		var c_vignette = new MultiTextureSprite([globalPack.getTexture("vignette_01"), globalPack.getTexture("vignette_02")]);
		_backing.addChild(new Entity().add(c_vignette));

		var e_confettiLayer = new Entity();
		var c_confettiLayer = new ConfettiLayer(globalPack);
		e_confettiLayer.add(c_confettiLayer);
		_backing.addChild(e_confettiLayer);

		function onMuteEngaged(e:PointerEvent):Void
		{
			System.volume._ = System.volume._ == 0 ? 1 : 0;
		}

		var c_btnMute = new BasicButton(globalPack, "ui/mute_btn");
		_btnMute.add(c_btnMute);
		disposer.connect1(c_btnMute.engaged, onMuteEngaged);
		_container.addChild(_btnMute);

		function addBtnIcon()
		{
			var id:String = System.volume._ == 0 ? "ui/sound_off" : "ui/sound_on";
			c_btnMute.overlay.add(new ImageSprite(globalPack.getTexture(id)).centerAnchor().setXY(5, -5));
		}

		addBtnIcon();

		disposer.connect2( System.volume.changed, function(to:Float, _) {
			addBtnIcon();
		});

		//Not necessary to re-align elements to left/top on resize.
		_logo.add(new ImageSprite(pack.getTexture("logo")).disablePointer());
		_title.add( new ImageSprite(pack.getTexture("title")).centerAnchor().disablePointer());
		_head.add( new ImageSprite(pack.getTexture("head")).centerAnchor().disablePointer());
		_shards1.add( new ImageSprite(pack.getTexture("shards")).disablePointer());

		_backing.add(new ButtonMode(Math.round(Math.random() * 200)));

		_play
			.add(new TextButton(pack, "start_btn", "title.play"))
		;
		_play.get(TextButton).textSprite.y._ = -35;

		// Add our additional items to the container.
		_container
			.addChild(_logo)
			.addChild(_head)
			.addChild(_title)
			.addChild(_shards1)
			.addChild(_play);

		// Connect to signals
		//Using ButtonMode.engaged ensures pointerDown AND pointerUp both occured on this button.
		disposer.connect1(_backing.get(ButtonMode).engaged, onNextClick);
		disposer.connect1(_play.get(TextButton).engaged, onNextClick);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * All positioning code goes here. It will be triggered each time the screen is rotated or the dimensions change.
	 * 
	 * @return [description]
	 */
	override function onResize()
	{
		super.onResize();

		// Title & Logo
		_logo.get(Sprite).setXY(347, 143);
		_title.get(Sprite).setXY(496, 390);

		// Play button
		_play.get(Sprite).setXY(531, 606);

		// Head
		_head.get(Sprite).x._ = 990;
		_head.get(Sprite).y._ = 460;

		_btnMute.right(25).top(25);

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	override public function onUpdate(dt:Float)
	{
		super.onUpdate(dt);

		var c_line:Sprite;

		for (i in 0..._lines.length)
		{
			c_line = _lines[i].get(Sprite);

			if ((c_line.rotation._ + _linesHolder.get(Sprite).rotation._ - 7) % 360 > 180)
			{
				if (c_line.alpha._ == 0)
				{
					c_line.alpha.animateTo(1, 0.5);
				}

			}
			else
			{
				if (c_line.alpha._ == 1)
				{
					c_line.alpha.animateTo(0, 0.5);
				}

			}

		}

	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Handles the next button being clicked.
	*/
	private function onNextClick(e:PointerEvent):Void
	{
		// Canada Tracking. Can be turned on and off through config.xml. Will not break if tracking javascript does not exist.
		Config.track(['play']);
		Scenes.goto(BrainHubScene);
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onRemoved()
	{
		_assets.unload('title_scene');
		_assets.unload('data', false);
	}

}


























