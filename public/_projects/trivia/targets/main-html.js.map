import s2.ui.TextFluidButton;
import s2.ui.BasicButton;
import s2.localization.Locale;
import s2.scene.*;
import s2.scene.Popup;
import s2.util.Utils;
//import s2.util.Inactivity;
import s2.display.SpriteUser;
import s2.behavior.Damping;
import s2.display.SizeSprite;

import com.nick.ultimatetrivia.components.GameTracker;
import com.nick.ultimatetrivia.components.Hud;
import com.nick.ultimatetrivia.components.question.QuestionDisplay;
import com.nick.ultimatetrivia.components.Heading;
import com.nick.ultimatetrivia.components.ConfettiLayer;

using s2.util.Positioning;
using s2.display.LayoutUtil;
using Lambda;

/**
 * ...
 * @author Seven2
 */
class InGameScene extends AutoFillScene
{	
	/**  */
	private var _hud					= new Entity();
	/**  */
	private var _head 					= new Entity();
	/** Button to pause the game. */
	private var _btnPause 				= new Entity();
	/**  */
	private var _headLocale				:String;
	/**  */
	private var _confetti 				= new Entity();
	
	/* ---------------------------------------------------------------------------------------- */

	@:keep public function new()
	{
		super();

		requiredPacks.push('global');
		requiredPacks.push('pause_scene');//So it doesn't show a preloader when going to pause.
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function assetsReady():Void
	{
		super.assetsReady();

		var disposer = owner.get(Disposer);
		var globalPack :AssetPack = _assets.get('global');
		var gt = System.root.get(GameTracker);

		setBackground(new SizeSprite(1366, 768));

		var textures:Array<Texture> = [];

		for (i in 0...12)
		{
			textures.push(globalPack.getTexture("fill_bg"));
		}

		var c_fill = new MultiTextureSprite(textures, 6);
		_backing.addChild(new Entity().add(c_fill));

		var c_vignette = new MultiTextureSprite([globalPack.getTexture("vignette_01"), globalPack.getTexture("vignette_02")]);
		_backing.addChild(new Entity().add(c_vignette));

		var c_confetti = new ConfettiLayer(globalPack);
		_confetti.add(c_confetti);
		_backing.addChild(_confetti);

		var c_head = new Heading(globalPack, _headLocale);
		_head.add(c_head);
		_container.addChild(_head);

		var btnPause = new BasicButton(globalPack, "ui/pause_btn");
		btnPause.engaged.connect(onPauseButtonClick);
		_btnPause.add(btnPause);

		_container.addChild(_btnPause);

		// Connect to signals
		
		onResize();
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onResize()
	{
		super.onResize();
		
		// if (_head.get(Head) != null)
		// {
		// 	throw("Pssst. You may need to pkill haxe.");
		// }

		if (_head.get(Heading) != null)
		{
			_head.get(Heading).onResize();
		}

		_btnPause.right(25).top(25);

		if (_hud.get(Hud) != null)
		{
			_hud.get(Hud).onResize();
		}
		
	}

	/* ---------------------------------------------------------------------------------------- */

	private function onPauseButtonClick(e :PointerEvent) :Void
	{
		Scenes.push(PauseScene, new FadeTransition(0.2));
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onRemoved()
	{
		super.onRemoved();

		//System.root.remove(System.root.get(Inactivity));
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function dispose()
	{
		super.dispose();
	}
	
}






























