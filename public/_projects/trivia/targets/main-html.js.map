package s2.util;

import flambe.sound.Sound;
import flambe.asset.Manifest;
import flambe.util.Disposable;
import flambe.util.Value;
import flambe.System;

import s2.client.Config;

#if js
import js.Browser;
#end

#if flash
import flash.external.ExternalInterface;
#end

using flambe.util.Arrays;
using StringTools;

/**
 * Miscellaneous, frequently needed items. Relocate items as there comes to be enough to categorize to other
 * static classes.
 *
 * @author Seven2
 */

class Utils
{
	/** */
	public var sndClick:Sound;
	/** */
	public static inline var baseWidth:Float = 1366;
	/** */
	public static inline var baseHeight:Float = 768;
	/** Tracks if the game is muted or not. */
	public static var muted(default, null):Value<Bool> = new Value<Bool>(false);

	/* ---------------------------------------------------------------------------------------- */

	/*
	*
	*/
	public static function sortArrayRandom(a:Dynamic, b:Dynamic):Int
	{
	    return (Math.random() < .5) ? 1 : -1;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* https://groups.google.com/forum/#!topic/haxelang/N03kf5WSrTU
	*/
	static public function createGUID():String {

		var CHARS : Array<String> = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz".split("");

		var chars = CHARS, uuid = new Array<String>(), rnd = 0, r;

		for (i in 0...36) {
			if (i==8 || i==13 ||  i==18 || i==23) {
				uuid[i] = "-";
			} else if (i==14) {
				uuid[i] = "4";
			} else {
				if (rnd <= 0x02) rnd = 0x2000000 + Std.parseInt( Std.string(Math.random() * Std.parseFloat(Std.string(0x1000000)))) | 0;
				r = rnd & 0xf;
				rnd = rnd >> 4;
				uuid[i] = chars[(i == 19) ? (r & 0x3) | 0x8 : r];
			}
		}

		return uuid.join("");
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Wanted this to work like trace, which allows method overloading, which isn't supported in Haxe.
	* Settled for a signature that allows up to ten string parameters.
	* 
	* Also consider using haxe.Log.trace;
	*/
	public static function alert(
		p0:Dynamic = "",
		p1:Dynamic = "",
		p2:Dynamic = "",
		p3:Dynamic = "",
		p4:Dynamic = "",
		p5:Dynamic = "",
		p6:Dynamic = "",
		p7:Dynamic = "",
		p8:Dynamic = "",
		p9:Dynamic = "")
	{
		var str = p0;

		str += (p1 != null) ? " " + p1 : "";
		str += (p2 != null) ? " " + p2 : "";
		str += (p3 != null) ? " " + p3 : "";
		str += (p4 != null) ? " " + p4 : "";
		str += (p5 != null) ? " " + p5 : "";
		str += (p6 != null) ? " " + p6 : "";
		str += (p7 != null) ? " " + p7 : "";
		str += (p8 != null) ? " " + p8 : "";
		str += (p9 != null) ? " " + p9 : "";

		if (System.external.supported)
		{
			System.external.call("alert", [str + ""]);
		}
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Gets map of url queries.
	*/
	public static function urlQuery():Map<String, String>
	{
		return s2.util.URLParser.fromBrowser().query;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Gets a date from config file.
	*/
	public static function getConfigDate(id:String):Date
	{
		//Format: LOCAL:2015-07-17 00:00:00
		var sDate = Config.options.get(id);
		return Date.fromString(sDate.substr(sDate.indexOf(":") + 1));
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Gets actual date or one passed via query string.
	*/
	public static function getDate():Date
	{
		var date:String;

		if (urlQuery().exists("date"))
		{
			return Date.fromString(urlQuery().get("date").replace("_", " "));
		}
		else
		{
			return Date.now();
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Test if a variable is existent in js wrapper.
	*/
    public static function jsPropertyExists(propertyName:String):Bool
    {
        return runJSStatement(propertyName + "!= null");
    }

	/* ---------------------------------------------------------------------------------------- */

	/*
	* System.external.call expects a function, but if you're just checking a value or running a statement,
	* you have to wrap it in a function, which was not as straightforward as expected
	* to work in JavaScript, so included this shortcut here.
	*/
    public static function runJSStatement(statement:String):Dynamic
    {
    	return System.external.call("eval", ["(function () {return " + statement + ";})()"]);
    }

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Easy utility to dispose a disposable only if it is not null.
	 * 
	 * @param  disposable :Disposable   [description]
	 */
	public static inline function safeDispose(disposable :Disposable) :Void
	{
		if (disposable != null) {
			disposable.dispose();
		}
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Quick way to dispose a bunch of objects in an array, then clear the array.
	 * 
	 * @param  array :Array<Disposable> [description]
	 */
	public static inline function disposeAll<T:Array<Disposable>>(array :T) :Void
	{
		var ii :Int = array.length;
		while (ii-->0) {
			array[ii].dispose();
		}
		array.resize(0); // Clear out the elements.
	}

	/* ---------------------------------------------------------------------------------------- */

	public static inline function randomInt(max:Int):Int
	{
		return Math.floor(Math.random() * max);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	* A wrapper function for BaseUtil.setupManifest. This makes it so we can still dev without
	* switching removing a call to this function.
	* Note that if you use dynamic manfests without either setupManifest call, it will break when it goes live.
	*/
	public static function setupManifest(manifest:Manifest)
	{
		var nickDomains:Array<String> = ["nick-q.mtvi.com", "nick.com"];
		var sUrl:String = URLParser.fromBrowser().url;
		var bIsNickelodeon:Bool = false;

		for (domain in nickDomains)
		{
			if (sUrl.indexOf(domain) != -1)
			{
				bIsNickelodeon = false;
				break;
			}
		}

		if (bIsNickelodeon)
		{
			flambesdk.BaseUtils.setupManifest(manifest);
		}
		else
		{
			manifest.localBase = "assets/";
		}

	}

}






























