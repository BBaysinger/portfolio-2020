package s2.scene;

import flambe.animation.AnimatedFloat;
import flambe.animation.Sine;
import flambe.script.Script;
import flambe.script.Sequence;
import flambe.script.AnimateTo;
import flambe.script.Parallel;
import flambe.script.Repeat;
import flambe.script.CallFunction;
import flambe.asset.AssetPack;
import flambe.Component;
import flambe.display.FillSprite;
import flambe.display.ImageSprite;
import flambe.display.PatternSprite;
import flambe.display.Sprite;
import flambe.display.Texture;
import flambe.display.TextSprite;
import flambe.Disposer;
import flambe.Entity;
import flambe.math.FMath;
import flambe.math.Rectangle;
import flambe.scene.Scene;
import flambe.System;
import flambe.util.Disposable;
import flambe.util.Signal1;

import s2.display.SizeSprite;
import s2.loading.Assets;
import s2.display.MultiTextureSprite;
import s2.localization.Locale;

using s2.display.LayoutUtil;

/**
 * The main preloader scene for our game. Can be reusesd across projects with minor modification.
 * @author Seven2
 */
class CustomPreloadScene extends SceneLoader
{
	/**  */	
	private static inline var WAVES_START_Y:Int = 144;
	/**  */
	private var _percent			= new Entity();
	/** Used to keep track of screen resizing. */
	private var _resizeHandle  		:Disposable;
	/**  */	
	private var _pack				:AssetPack;
	/**  */	
	private var _waves = new Array<Entity>();
	/**  */	
	private var _waveHolder = new Entity();
	/**  */	
	private var _brainRect = new Rectangle(50, 18, 208, 148);

	/* ---------------------------------------------------------------------------------------- */
	
	public function new(pack :AssetPack) 
	{
		super();
		this.opaque = false;
		_pack = pack;
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	override public function onAdded():Void 
	{
		super.onAdded();

		setBackground(new SizeSprite(1366, 768));

		var textures:Array<Texture> = [];

		for (i in 0...12)
		{
			textures.push(_pack.getTexture("fill_bg"));
		}

		var c_fill = new MultiTextureSprite(textures, 6);
		_backing.addChild(new Entity().add(c_fill));

		var headHolder = new Entity();
		var c_headHolder = new Sprite();
		c_headHolder.setXY(653, 249);
		headHolder.add(c_headHolder);
		_backing.addChild(headHolder);

		var c_waveHolderHolder = new FillSprite(0x484848, _brainRect.width, _brainRect.height);
		c_waveHolderHolder.setXY(_brainRect.x, _brainRect.y);
		c_waveHolderHolder.scissor = new Rectangle(0, 0, _brainRect.width, _brainRect.height);
		var e_waveHolderHolder = new Entity().add(c_waveHolderHolder);
		headHolder.addChild(e_waveHolderHolder);

		var c_waveHolder = new Sprite();
		c_waveHolder.y._ = WAVES_START_Y;
		_waveHolder.add(c_waveHolder);
		e_waveHolderHolder.addChild(_waveHolder);

		owner.add(new Script());

		var c_wave:ImageSprite;

		for (i in 0...2)
		{
			c_wave = new ImageSprite(_pack.getTexture("wave"));
			c_wave.x._ = c_wave.getNaturalWidth() * i;
			_waves[i] = new Entity().add(c_wave);
			_waveHolder.addChild(_waves[i]);
		}

		animateWaves();

		var c_head = new ImageSprite(_pack.getTexture("head"));
		var head = new Entity().add(c_head);
		headHolder.addChild(head);

		var c_vignette = new MultiTextureSprite([_pack.getTexture("vignette_01"), _pack.getTexture("vignette_02")]);
		_backing.addChild(new Entity().add(c_vignette));

		var c_bubble = new ImageSprite(_pack.getTexture("bubble"));
		c_bubble.setXY(-266, 34);
		var e_bubble = new Entity();
		headHolder.addChild(e_bubble.add(c_bubble));

		var c_arrows = new ImageSprite(_pack.getTexture("arrows"));
		c_arrows.setXY(-28, -88);
		headHolder.addChild(new Entity().add(c_arrows));

		var c_loading = Locale.getField("loading.loading", 0, Center);
		c_loading.setXY(132, 36);
		var loading = new Entity().add(c_loading);
		e_bubble.addChild(loading);

		var c_percent = Locale.getField("loading.percent", 0, Center);
		c_percent.setXY(132, 76);
		_percent.add(c_percent);
		e_bubble.addChild(_percent);

		_resizeHandle = System.stage.resize.connect(onResize);

		onResize();
	}

	/* ---------------------------------------------------------------------------------------- */

	private	function animateWaves()
	{
		var c_waveSprite:ImageSprite;
		var par1 = new Parallel();
		var par2 = new Parallel();
		var seq = new Sequence();
		var animateTo:AnimateTo;

		for (i in 0..._waves.length)
		{
			c_waveSprite = _waves[i].get(ImageSprite);

			if (c_waveSprite.x._ <= -c_waveSprite.getNaturalWidth())
			{
				c_waveSprite.x._ = c_waveSprite.getNaturalWidth();
			}

			par1.add(new AnimateTo(c_waveSprite.x, c_waveSprite.x._ - c_waveSprite.getNaturalWidth(), 0.8));
			par2.add(new AnimateTo(c_waveSprite.x, c_waveSprite.x._, 0.0));
		}

		seq.add(par1);
		seq.add(par2);

		var rep = new Repeat(seq);

		owner.get(Script).run(rep);

	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	override private function onProgress(bytesLoaded:Float, bytesTotal:Float):Void
	{
		var c_waveHolder = _waveHolder.get(Sprite);

		var progress:Float = Math.min(bytesLoaded / bytesTotal, 1);
		var pct = Math.round(Math.min(1, progress) * 100);
		
		//Exceeds 100%, presumably because file sizes are estimated before they start...?
		//if (pct > 1) trace("bytesLoaded: " + Std.string(bytesLoaded), "bytesTotal: " + Std.string(bytesTotal));

		c_waveHolder.y._ = WAVES_START_Y - (WAVES_START_Y + 25) * progress;
		_percent.get(TextSprite).text = pct + "%";
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function onRemoved()
	{
		super.onRemoved();
		_resizeHandle.dispose();
	}

}





























