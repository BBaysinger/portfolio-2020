package s2.scene;

import flambe.asset.AssetPack;
import flambe.display.FillSprite;
import flambe.Entity;
import flambe.scene.Scene;
import flambe.scene.Transition;
import flambe.System;
import flambe.util.SignalConnection;
import s2.loading.Assets;
import s2.scene.AutoFillScene;
import s2.scene.BaseScene;
import s2.scene.Scenes;

/**
 * Class for loading in scenes.
 */
class SceneLoader extends AutoFillScene
{
	/** comment */
	public var waitForTransitions :Bool;
	/** The scene we should be loading on up */
	private var nextScene :BaseScene;
	/** The asset pack to load up. */
	private var _loadingAssets :Assets;
	/** If we should unwind or push. */
	private var _unwind :Bool;
	/** The transition to use. */
	private var _transition :Transition;
	/** comment */
	private var _progressBind :SignalConnection;
	/** comment */
	private var _loadCompleteBind :SignalConnection;
	private var _wait :Bool = false;

	/**
	 * The constructor for the preloader.
	 * @param  ?pack :AssetPack    [description]
	 * @return       [description]
	 */
	public function new(?waitForTransitions :Bool = true)
	{
		super();
		this.waitForTransitions = waitForTransitions;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	@:allow(s2.scene.Scenes) function load() :Void {
		_wait = false;
		_loadingAssets.load();
	}

	/* ---------------------------------------------------------------------------------------- */
	
	public function setNextScene(nextScene :BaseScene, ?unwind :Bool = true, ?transition :Transition = null) :SceneLoader
	{
		if (_progressBind != null) {
			_progressBind.dispose();
			_loadCompleteBind.dispose();
		}

		this.nextScene = nextScene;
		_unwind = unwind;
		_loadingAssets = new Assets(nextScene.requiredPacks, nextScene.dynamicManifests);
		_transition = transition == null ? Scenes.getTransition() : transition;

		_progressBind = _loadingAssets.progressed.connect(onProgress);
		_loadCompleteBind = _loadingAssets.success.connect(onLoadSuccess);
		return this;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Override this is your subclasses.
	 * @param  nBytes :Float        [description]
	 * @param  nTotal :Float        [description]
	 * @return        [description]
	 */
	private function onProgress(nBytes :Float, nTotal :Float)
	{
		var nPercent :Float = nBytes / nTotal;
		owner.add(new FillSprite(0xCC0000,System.stage.width, System.stage.height));
		if (owner.firstChild != null) {
			owner.firstChild.dispose();
		}
		owner.addChild(new Entity().add(new FillSprite(0xFFFFFF,nPercent * System.stage.width, System.stage.height)));
	}

	/* ---------------------------------------------------------------------------------------- */
	
	private function onLoadSuccess()
	{
		_progressBind.dispose();
		_loadCompleteBind.dispose();
		
		nextScene.injectAssets(_loadingAssets);
		_loadingAssets = null;

		if (Scenes.director.transitioning && waitForTransitions) {
			// Let's wait till it's done.
			_wait = true;
		} else {
			progressToNextScene();
		}

	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function onUpdate(dt :Float)
	{
		if (_wait && !Scenes.director.transitioning) {
			progressToNextScene();
		}
	}

	/* ---------------------------------------------------------------------------------------- */
	
	private function progressToNextScene()
	{
		if (_unwind) {
			Scenes.director.unwindToScene(new Entity().add(nextScene), _transition);
		} else {
			Scenes.director.popScene(); // Removes this scene
			Scenes.director.pushScene(new Entity().add(nextScene), _transition);
		}
		_transition = null;
		_wait = false;
	}

}