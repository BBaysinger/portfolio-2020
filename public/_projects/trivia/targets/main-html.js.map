package s2.localization;

import flambe.asset.AssetPack;
import flambe.asset.File;
import flambe.asset.Manifest;
import flambe.display.Font;
import flambe.display.TextSprite;
import flambe.System;

import s2.util.Sniffer;

using Lambda;
using Std;

typedef StringFormat = {
	var id :String;
	var font :Font;
	var lineHeight :Float;
	var text :String;
	var scale :Float;
	var offsetX :Float;
	var offsetY :Float;
}

class Locale 
{
	/** Relative base path to use with loading assets. */
	public static var relativeBase:String;
	/** External base path to use with loading assets. */
	public static var externalBase:String;

	private static var _parser:LocaleParser;

	private static var _formats:Map<String, StringFormat>;
	private static var _x:Xml;
	private static var _xmlPath:String;
	private static var _fontDirectory:String;
	private static var _onReady:Void->Void;

	public static var loading(default,null):Bool = true;

	/**
	 * Initializes the Locale class.
	 */
	public static function init(onReady:Void->Void, parser:LocaleParser, xmlPath:String = "xml/translation.xml", fontDirectory:String = "assets/fonts")
	{
		_formats = new Map();
		_xmlPath = xmlPath;
		_fontDirectory = fontDirectory;
		_onReady = onReady;
		_parser = parser;

		// Begin loading XML.
		var manifest:Manifest = new Manifest();

		var sPath :String = xmlPath;
		if ( Locale.externalBase != null ) {
			sPath = Locale.externalBase + _xmlPath;
		}
		else if ( Locale.relativeBase != null ) {
			sPath = Locale.relativeBase + _xmlPath;
		}

		manifest.add(xmlPath, sPath);
		var loader = System.loadAssetPack(manifest);
		loader.get(onXmlSuccess);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Gets a TextArea component filled with the translated text and font.
	 */
	public static function getField(id :String, ?width :Float = 0, ?alignment :TextAlign = null) :TextSprite 
	{
		if (Sniffer.mobile && _formats.exists(id + "_mob")) id = id + "_mob";

		if(_formats.exists(id)) {
			var format:StringFormat = _formats.get(id);

			var sprite:TextSprite = new TextSprite(format.font, format.text);
			sprite.wrapWidth._ = width / format.scale;
			sprite.align = alignment;
			sprite.setScale(format.scale);
			sprite.anchorX._ = -format.offsetX;
			sprite.anchorY._ = -format.offsetY;
			sprite.pixelSnapping = false;
			return sprite;
		} else {
			throw "No string id : '" + id + "' exists.";
		}
	}


	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Tracks if the localization field exists or not.
	 * @param  id :String       [description]
	 * @return    [description]
	 */
	public static function hasField(id :String) :Bool
	{
		return _formats.exists(id);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Gets the definition and all metadata for a particular string ID
	 */
	public static function getFormat(id :String):StringFormat
	{
		if(_formats.exists(id)) {
			return _formats.get(id);
		} else {
			throw "No string id : '" + id + "' exists.";
		}
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/** 
	 * Triggered when the translation XML has finished loading.
	 */
	private static function onXmlSuccess(pack :AssetPack) 
	{
		var rawFile :File = pack.getFile( _xmlPath );
		_x = Xml.parse( rawFile.toString() );
		rawFile.dispose();

		var fontManifest :Manifest = prepManifest( _parser.parseFonts(_x) );
		var loader = System.loadAssetPack( fontManifest );
		loader.get(onDefinitionLoadSuccess);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	private static function onDefinitionLoadSuccess(pack :AssetPack) :Void
	{
		var fontAtlas :Manifest = prepManifest( _parser.parseDefinitions(pack) );
		var loader = System.loadAssetPack( fontAtlas );
		loader.get(onAtlasLoadSuccess);
	}


	/* ---------------------------------------------------------------------------------------- */
	
	private static function prepManifest(manifest :Manifest) :Manifest
	{
		if ( Locale.externalBase != null ) 
		{
			manifest.remoteBase = Locale.externalBase + _fontDirectory;
		}
		else if ( Locale.relativeBase != null ) 
		{
			manifest.localBase = Locale.relativeBase + _fontDirectory;
		}
		else {
			manifest.localBase = _fontDirectory;
		}

		return manifest;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/** 
	 * Triggered when the font definitions have finished loading.
	 * Need to load the atlas files next.
	 */
	private static function onAtlasLoadSuccess(pack :AssetPack) 
	{
		_formats = _parser.parseStrings(_x, pack);

		for (format in _formats) {
			var text :String = StringTools.replace(format.text, "<br>", "\n");
			if (text != format.text) {
				format.text = text;
			}
		}

		// Finish up the process.
		loading = false;

		if(_onReady != null) {
			Reflect.callMethod(null,_onReady, []);
		}
		_onReady = null;
	}

}


interface LocaleParser 
{
	/**
	 * Parses the XML to create a manifest of font definition files.
	 * 
	 * @param  data 	The data (can be XML, JSON, whatever)
	 * @return      	The manifest of font files that should be loaded.
	 */
	function parseFonts(data :Dynamic) :Manifest;

	function parseDefinitions(data :Dynamic) :Manifest;

	/**
	 * Parses all the string formats once all appropriate fonts have been loaded.
	 * @param  data The data ( could be XML, JSON, anything)
	 * @param  pack The asset pack that contains all the loaded fonts.
	 * @return      The hash of the parsed StringFormat objects.
	 */
	function parseStrings(data :Dynamic, pack :AssetPack) :Map<String, StringFormat>;
}