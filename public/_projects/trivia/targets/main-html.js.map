package s2.animation;

import flambe.Entity;
import flambe.Component;
import flambe.System;
import flambe.Disposer;
import flambe.display.Sprite;
import flambe.math.Point;
import flambe.input.PointerEvent;
import flambe.math.Rectangle;
import flambe.util.Signal1;
import flambe.animation.Ease;

using s2.util.Positioning;


class Draggable2 extends Component
{	

	/*  */
	public static var dragging(default, null) 	:Draggable2;
	/*  */
	public static var staticPick(default, null):Signal1<Draggable2>;
	/*  */
	public static var staticDrop(default, null):Signal1<Draggable2>;
	/*  */
	public static var staticDrag(default, null):Signal1<Draggable2>;
	/*  */
	private var _mouseStart:Point;
	/*  */
	private var _spriteStart:Point;
	/*  */
	private var _factor:Float = 1;
	/*  */
	private var _bounds:Rectangle;
	/*  */
	private var _easeTime:Float;
	/*  */
	private var _ease:EaseFunction;
	/*  */
	public var targX(default, null):Float;
	/*  */
	public var targY(default, null):Float;
	/*  */
	public var pick(default, null):Signal1<Draggable2>;
	/*  */
	public var drop(default, null):Signal1<Draggable2>;
	/*  */
	public var drag(default, null):Signal1<Draggable2>;
	/* Dispatched when movement occurs. */
	public var change(default, null):Point;

	/* ---------------------------------------------------------------------------------------- */

	/*
	* class initializer
	*/
  	static function __init__()
    {
		staticDrag = new Signal1();
		staticPick = new Signal1();
		staticDrop = new Signal1();
    }

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * ?offset not implemented, but later can be used to lock to position or to center.
	 */
	public function new(?offset:Point, ?bounds:Rectangle, ?factor:Float, ?easeTime:Float = -1, ?ease:EaseFunction = null)
	{
		_bounds = bounds;

		_easeTime = easeTime;
		_ease = ease;

		change = new Point(0,0);

		drag = new Signal1();
		pick = new Signal1();
		drop = new Signal1();

		_factor = (factor != null) ? factor : _factor;
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	override public function onAdded():Void
	{
		if (owner.get(Disposer) == null)
		{
			owner.add(new Disposer());
		}

		if (System.root.get(Sprite) == null)
		{
			System.root.add(new Sprite());
		}

		var disposer:Disposer = owner.get(Disposer);

		disposer.connect1(owner.get(Sprite).pointerDown, onPointerDn);
		disposer.connect1(System.pointer.up, onSystemPointerUp);

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function onPointerDn(e:PointerEvent):Void
	{
		startDrag();
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	public function startDrag():Void
	{
		_mouseStart = new Point(System.pointer.x, System.pointer.y);
		var sprite = owner.get(Sprite);
		_spriteStart = new Point(sprite.x._, sprite.y._);

		dragging = this;

		pick.emit(this);
		staticPick.emit(this);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	public function stopDrag(?emit:Bool = true):Void
	{
		if (emit)
		{
			drop.emit(this);
			staticDrop.emit(this);
		}

		change = new Point(0,0);
		dragging = null;
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function onSystemPointerUp(e:PointerEvent):Void
	{
		if (dragging == this)
		{
			stopDrag();
		}
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	override public function onUpdate(dt:Float):Void
	{
		if (dragging == this)
		{
			var scale:Float = 1;
			var ancestor:Entity = owner;
			var cAncestor:Sprite;

			while (ancestor != null)
			{
				cAncestor = ancestor.get(Sprite);

				if (cAncestor != null)
				{
					//assuming scaleX and scaleY are the same.
					scale = scale * cAncestor.scaleX._;
				}

				ancestor = ancestor.parent;
			}

			change = new Point(System.pointer.x - _mouseStart.x, System.pointer.y - _mouseStart.y);

			targX = _spriteStart.x + Math.round((change.x/scale) * _factor);
			targY = _spriteStart.y + Math.round((change.y/scale) * _factor);

			// var x:Float = targX;
			// var y:Float = targY;

			if (_bounds != null)
			{
				targX = Math.min(Math.max(targX, _bounds.x), _bounds.x + _bounds.width);
				targY = Math.min(Math.max(targY, _bounds.y), _bounds.y + _bounds.height);
			}

			var sprite:Sprite = owner.get(Sprite);

			var changed:Bool = sprite.x._ != targX || sprite.y._ != targY;

			if (!(_easeTime > 0))
			{
				owner.get(Sprite).x._ = targX;
				owner.get(Sprite).y._ = targY;
			}
			else
			{
				owner.get(Sprite).x.animateTo(targX, _easeTime, _ease);
				owner.get(Sprite).y.animateTo(targY, _easeTime, _ease);
			}

			if (changed)
			{
				drag.emit(this);
				staticDrag.emit(this);
			}

		}

	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	override public function dispose()
	{
		if (dragging == this)
		{
			dragging = null;
		}

		super.dispose();
		
	}
	
}




















