
package com.nick.ultimatetrivia.components;

import flambe.Disposer;
import flambe.Entity;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.Component;
import flambe.asset.AssetPack;
import flambe.script.Script;
import flambe.script.Repeat;
import flambe.script.Sequence;
import flambe.script.AnimateTo;
import flambe.script.Parallel;
import flambe.script.CallFunction;
import flambe.animation.Ease;

import s2.util.TimeUtil;
import s2.display.SpriteUser;
import s2.scene.AutoFillScene;

/**
 * 
 * 
 * @author Seven2
 */
class Confetti extends SpriteUser
{
	/**  */
	private var _globalPack			:AssetPack;
	/**  */
	private var _confetti 			= new Array<Entity>();
	/**  */
	private var _targX 				:Float;
	/**  */
	private var _targRot 			:Float;

	/* ---------------------------------------------------------------------------------------- */

	public function new(globalPack:AssetPack)
	{
		super();

		 _globalPack = globalPack;
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		super.onAdded();

		sprite.disablePointer();

		var disposer = new Disposer();
		owner.add(disposer);

		var c_confetti:ImageSprite;
		var seq = new Sequence();

		_targRot = Math.random() * 360;
		_targX = Math.random() * AutoFillScene.STANDARD_WIDTH;
		sprite.rotation._ = _targRot;
		x._ = _targX + Math.random() * 20 - 10;
		y._ = Math.random() * AutoFillScene.STANDARD_HEIGHT;

		sprite.rotation._ = _targRot + Math.random() * 20 + 10;

		owner.add(new Script());

		var timeUtil = new TimeUtil();
		owner.add(timeUtil);

		var seq = new Sequence();
		seq.add(new AnimateTo(x, _targX + Math.random() * 20, Math.random() * 3));
		seq.add(new CallFunction(ltRt));

		owner.get(Script).run(seq);

		animateDown();
	}

	/* ---------------------------------------------------------------------------------------- */

	private function ltRt()
	{
		var seq = new Sequence();
		seq.add(new AnimateTo(x, _targX - 20, 2.0, Ease.sineInOut));
		seq.add(new AnimateTo(x, _targX + 20, 2.0, Ease.sineInOut));
		var repeat = new Repeat(seq);

		owner.get(Script).run(repeat);

		var seq = new Sequence();
		seq.add(new AnimateTo(sprite.rotation, _targRot - 20, 2.0, Ease.sineInOut));
		seq.add(new AnimateTo(sprite.rotation, _targRot + 20, 2.0, Ease.sineInOut));
		var repeat = new Repeat(seq);

		owner.get(Script).run(repeat);
	}

	/* ---------------------------------------------------------------------------------------- */

	private function animateDown()
	{
		function reset()
		{
			y._ = 0;
			animateDown();
		}

		var seq = new Sequence();
		var time = (AutoFillScene.STANDARD_HEIGHT - y._) * 0.01 * (Math.random() * 0.75 + 0.5);

		seq.add(new AnimateTo(y, AutoFillScene.STANDARD_HEIGHT, time));
		seq.add(new CallFunction(reset));

		owner.get(Script).run(seq);
	}

	/* ---------------------------------------------------------------------------------------- */

	override private function createSprite():Sprite
	{
		var sprite = new ImageSprite(_globalPack.getTexture("confetti/confetti_" + Math.floor(Math.random() * 5)));
		sprite.centerAnchor();
		return sprite;
	}

}






























