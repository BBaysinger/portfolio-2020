package s2.util;

import flambe.display.ImageSprite;
import flambe.Entity;
import flambe.sound.Sound;
import flambe.util.Disposable;
import flambe.util.Value;
import flambe.System;
import flambe.math.Rectangle;
import flambe.System;

using flambe.util.Arrays;

#if flash
import flash.external.ExternalInterface;
#end

/**
 * Unifies access device detection based on user agent strings, which is NOT preferrable over feature detection,
 * but necessary in many scenarios, such as when features can not be detected.
 *
 * @author Bradley Baysinger, Seven2 Interactive
 */

class Sniffer
{
	/**  */
	public static var desktop(get_desktop, null):Bool;
	/**  */
	public static var nickApp(get_nickApp, null):Bool;
	/**  */
	public static var iOS(get_iOS, null):Bool;
	/** iPod, iPad */
	public static var iOSPocket(get_iOSPocket, null):Bool;
	/** iPad, iPad mini */
	public static var iOSTablet(get_iOSTablet, null):Bool;
	/** Chrome browser on iOS */
	public static var iOSChrome(get_iOSChrome, null):Bool;
	/** Kindle Fire Browser */
	public static var silk(get_silk, null):Bool;
	/** Kindle Fire Reader/Tablet */
	public static var kindle(get_kindle, null):Bool;
	/** Tablet or phone. */
	public static var mobile(get_mobile, null):Bool;
	/** Older devices that may need lower-res assets to conserve memory. */
	public static var lowMemory(get_lowMemory, null):Bool;
	/**  */
	public static var devicePixelRatio(get_devicePixelRatio, null):Float;
	/**  */
	public static var userAgent(get_userAgent, null):String;
	/**  */
	public static var tablet(get_tablet, null):Bool;
	/**  */
	public static var android(get_android, null):Bool;

	private static var _uaLower:String;
	private static var _desktop:Bool;
	private static var _nickApp:Bool;
	private static var _userAgent:String;
	private static var _tablet:Bool;
	private static var _iOS:Bool;
	private static var _iOSPocket:Bool;
	private static var _iOSTablet:Bool;
	private static var _android:Bool;
	private static var _androidPocket:Bool;
	private static var _androidTablet:Bool;
	private static var _iOSChrome:Bool;
	private static var _kindle:Bool;
	private static var _silk:Bool;
	private static var _mobile:Bool = false;
	private static var _lowMemory:Bool;
	private static var _devicePixelRatio:Float = 1;//Default 1 for platforms that do not support window.devicePixelRatio.
	private static var _inited:Bool = false;

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Run once, retain values.
	*/
	private static function init():Void
	{
		#if js
		_userAgent = js.Browser.window.navigator.userAgent;
		_devicePixelRatio = js.Browser.window.devicePixelRatio;
		#end

		#if flash
		_userAgent = cast(System.external.call("function(){return navigator.userAgent;}"), String);
		var pxRatio = System.external.call("function(){return window.devicePixelRatio;}");

		if (Type.typeof(pxRatio) != TNull)
		{
			_devicePixelRatio = cast(pxRatio, Float);
		}
		#end

		var ua = _userAgent;
		_uaLower = ua.toLowerCase();

		var query = URLParser.fromBrowser().query;

		_nickApp = query.exists("apiKey");
		_iOSTablet = test("iPad");
		_iOSPocket = test("iPod") || test("iPhone");
		_iOSChrome = test("CriOS");
		_iOS = _iOSPocket || _iOSTablet;
		_silk = test("Silk");
		_kindle = test("Silk") || query.get("partner") == "amazon";
		
		//For Nick app, this may be the only way to distiguish Kindle from Android.
		//if (!_kindle) URLParser.fromBrowser().query.get("partner") == "amazon";

		//Items that may yeild more matches if they are NOT case sensitive. 
		var caseInsensitive = ["Mini", "Mobile", "Phone", "Tablet"];
		//Items that MUST be case insensitive (for user agent strings within Nick App).
		caseInsensitive.concat(["Android", "iOS"]);

		for (match in caseInsensitive)
		{
			if (test(match.toLowerCase(), false))
			{
				_mobile = true;
				break;
			}

		}

		// #if js
		// 	//For Nick app. //No, because that's either going to be IOS or Android.
		// 	_mobile = (untyped navigator.isCocoonJS == true) ? true : _mobile;
		// #end

		//Items that should be case matched.
		//ARM must be case matched.
		var caseSensitive = ["ARM", "BlackBerry", "Palm", "webOS"];

		for (match in caseSensitive)
		{
			if (test(match))
			{
				_mobile = true;
				break;
			}

		}

		_android = test("Android", false);//'Android' in Nick app is all lower-case.
		_androidTablet = _android && !test("Mobile", false);//Not accurate in Nick app.
		_androidPocket = _android && test("Mobile", false);//Not accurate in Nick app.

		_tablet = _androidTablet || _iOSTablet || _kindle || test("ARM");

		var totalPixels :Float = System.stage.width * System.stage.height;
		_lowMemory = (totalPixels <= 706560 || (_iOSTablet || _iOSPocket) && _devicePixelRatio < 2) && _mobile;

		_desktop = test("Macintosh") || test("Linux") || test("Windows") && !_mobile;

		_inited = true;
	}

	/* ---------------------------------------------------------------------------------------- */

	private static function get_nickApp():Bool
	{
		assureInited();

		return _nickApp;
	}

	/* ---------------------------------------------------------------------------------------- */

	private static function get_desktop():Bool
	{
		assureInited();

		return _desktop;
	}

	/* ---------------------------------------------------------------------------------------- */

	public static function get_userAgent():String
	{
		assureInited();

		return _userAgent;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private static function get_mobile():Bool
	{
		assureInited();

		return _mobile;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	public static function get_iOS():Bool
	{
		assureInited();

		return _iOS;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private static function get_iOSChrome():Bool
	{
		assureInited();

		return _iOSChrome;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private static function get_iOSPocket():Bool
	{
		assureInited();

		return _iOSPocket;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private static function get_iOSTablet():Bool
	{
		assureInited();

		return _iOSTablet;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private static function get_silk():Bool
	{
		assureInited();

		return _silk;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private static function get_kindle():Bool
	{
		assureInited();

		return _silk;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private static function get_lowMemory():Bool
	{
		assureInited();

		return _lowMemory;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private static function get_devicePixelRatio():Float
	{
		assureInited();

		return _devicePixelRatio;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private static function get_tablet():Bool
	{
		assureInited();

		return _tablet;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* 
	*/
	private static function get_android():Bool
	{
		assureInited();

		return _android;
	}

	/* ---------------------------------------------------------------------------------------- */

	/*
	* Ensures Sniffer is inited before returning values.
	*/
	private static function assureInited()
	{
		if (!_inited)
		{
			init();
		}
	}

    /* ---------------------------------------------------------------------------------------- */

    public static function test(str:String, caseSensitive:Bool = true):Bool
    {
        if (caseSensitive)
        {
        	return _userAgent.indexOf(str) >= 0;
        }
        else
        {
            return _uaLower.indexOf(str.toLowerCase()) >= 0;
        }

    }

}



























