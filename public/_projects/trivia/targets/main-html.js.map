package com.nick.ultimatetrivia.components;

import flambe.Component;
import flambe.Disposer;
import flambe.Entity;
import flambe.System;
import flambe.display.Sprite;
import flambe.display.ImageSprite;
import flambe.display.Texture;
import flambe.asset.AssetPack;
import flambe.swf.MovieSprite;
import flambe.swf.Library;
import flambe.swf.MoviePlayer;
import flambe.display.BlendMode;
import flambe.animation.Sine;
import flambe.animation.AnimatedFloat;
import flambe.math.Point;
import flambe.util.Signal2;

import s2.scene.AutoFillScene;
import s2.util.TimeUtil;
import s2.display.ButtonMode;
import s2.localization.Locale;

import com.nick.ultimatetrivia.Data;
import com.nick.ultimatetrivia.components.GameTracker.TraitScore;

class Brain extends Component
{

	/* ---------------------------------------------------------------------------------------- */

	/**
	* This generates assets ids in advance of being needed, so BrainHubScene can add them to a dynamic manifest,
	* that way we don't load them all at once (which crashes lowMem devices).
	*/
	public static function generateAssetIds()
	{
		var gt = System.root.get(GameTracker);

		layoutId = Math.floor(Math.random() * 3);

		assetIds = ["empty" => [], "fills" => [], "lines" => []];

		for (i in 0...7)
		{
			assetIds.get("empty").push("brain/" + (layoutId + 1) + "/empty" + i);
			assetIds.get("lines").push("brain/" + (layoutId + 1) + "/lines" + i);
		}

		var traits = gt.getTopPsychTraits();

		//TODO: Check order.
		trace(traits);

		var catId:CategoryId;

		if (gt.testAssets)
		{
			var ids = Type.allEnums(CategoryId);

			for (i in 0...ids.length)
			{
				catId = ids[i];
				assetIds.get("fills").push("fills/" + Std.string(catId));
			}

		}
		else
		{
			for (i in 0...traits.length)
			{
				catId = traits[i].categoryId;
				assetIds.get("fills").push("fills/" + Std.string(catId));
			}
		}
	} 

	/**  */
	private static var _brainXY 				:Point = new Point(606, 141);
	/**  */
	private var _scenePack 						:AssetPack;
	/**  */
	private var _brainPack 						:AssetPack;
	/** From biggest to smallest. */
	private static var _sizeOrder 				:Array<Array<Int>> = [[5, 3, 4, 1, 2, 0, 6], [5, 0, 6, 3, 2, 4, 1], [6, 2, 3, 4, 0, 5, 1]];
	//private static var _sizeOrder 			:Array<Array<Int>> = [[5, 3, 4, 1, 2, 0, 6], [1, 6, 4, 5, 3, 0, 2], [4, 1, 6, 5, 2, 3, 0]];
	/**  */
	public static var layoutId(default, null)	:Int;
	/**  */
	public static var assetIds(default, null)	:Map<String, Array<String>> = ["lines" => null, "fills" => null, "empty" => null];
	/**  */
	private var _brainChunks 					= new Array<Entity>();
	/**  */
	private var _chunkContainer					= new Entity();
	/**  */
	private var _hitAreas 						= new Entity();
	/**  */
	public var message(default, null)			= new Signal2<String, Point>();

	/* ---------------------------------------------------------------------------------------- */

	public function new(scenePack:AssetPack, brainPack:AssetPack)
	{
		_scenePack = scenePack;
		_brainPack = brainPack;
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		super.onAdded();

		var disposer = owner.get(Disposer);
        if (disposer == null) owner.add(disposer = new Disposer());

		var timeUtil = owner.get(TimeUtil);
        if (timeUtil == null) owner.add(timeUtil = new TimeUtil());

        var hubAnimationIds = Data.getHubAnimationsIds();
		var gt = System.root.get(GameTracker);
		var catIds = Type.allEnums(CategoryId);

		//TODO: Needs to load them all first.
		if (gt.testAssets)
		{
			for (i in 0...catIds.length)
			{
				_brainPack.getTexture("fills/" + Std.string(catIds[i]));
			}
		}

		for (i in 0...catIds.length)
		{
			Locale.getFormat("brainHub.trait_" + Std.string(catIds[i]).toLowerCase());
		}

		var animationsIds = Type.allEnums(AnimationIds);
		animationsIds.splice(animationsIds.indexOf(Head_Idle), 1);

		var c_chunkContainer = new Sprite();
		c_chunkContainer.setXY(_brainXY.x, _brainXY.y);

		_chunkContainer = new Entity().add(c_chunkContainer);
		owner.addChild(_chunkContainer);

		var c_chunk:ImageSprite;

		var posesX = new Array<Array<Int>>();
		var posesY = new Array<Array<Int>>();

		posesX[0] = [238,157,52,141,-12,74,-52];
		posesY[0] = [77,105,117,6,34,-51,-40];

		posesX[1] = [254,109,87,189,132,16,-29];
		posesY[1] = [72,98,19,-22,-60,-56,-4];

		posesX[2] = [249,168,197,-52,68,127,-19];
		posesY[2] = [77,101,-17,32,51,-83,-64];

		var c_lines:ImageSprite;		

		for (i in 0...7)
		{
			c_chunk = new ImageSprite(_brainPack.getTexture(assetIds.get("empty")[i]));
			c_chunk.setXY(posesX[layoutId][i], posesY[layoutId][i]);
			_brainChunks[i] = new Entity().add(c_chunk);
			_chunkContainer.addChild(_brainChunks[i]);

			c_lines = new ImageSprite(_brainPack.getTexture(assetIds.get("lines")[i]));
			_brainChunks[i].addChild(new Entity().add(c_lines));
		}

		var traits = gt.getTopPsychTraits();
		var derp:Float = 0.6;

		var arr:Array<Int> = [5, 3, 4, 1, 2, 0, 6];

		// for (i in 0...arr.length)//This is a trip.
		// {
		// 	trace(arr.indexOf(i), arr[i]);
		// }

		for (i in 0...traits.length)
		{
			if (i >= _brainChunks.length) break;

			var str = Std.string(traits[i].categoryId);
			var mask = _brainPack.getTexture(assetIds.get("empty")[_sizeOrder[layoutId].indexOf(i)]);
			var texture = _brainPack.getTexture("fills/" + str);
			var masked = getMaskedTexture(texture, mask, 0, 0);
			var c_masked = new ImageSprite(masked);

			c_masked.pixelSnapping = false;
			c_masked.setXY(posesX[layoutId][_sizeOrder[layoutId].indexOf(i)], posesY[layoutId][_sizeOrder[layoutId].indexOf(i)]);
			c_masked.x.behavior = new Sine(c_masked.x._ - derp, c_masked.x._ + derp, Math.random() * 0.2 + 0.6);
			c_masked.y.behavior = new Sine(c_masked.y._ - derp, c_masked.y._ + derp, Math.random() * 0.2 + 0.6);
			_brainChunks[_sizeOrder[layoutId].indexOf(i)].add(c_masked);
		}

		var lib = new Library(_scenePack, "lib");
		var id = "HitAreas" + (layoutId+1);
		var c_hitAreas = lib.createMovie("HitAreas" + (layoutId+1));
		c_hitAreas.alpha._ = 0.0;
		c_hitAreas.setXY(_brainXY.x, _brainXY.y);
		_hitAreas.add(c_hitAreas);

		var buttonMode:ButtonMode;

		for (i in 0...7)
		{
			function ()
			{
				var index = i;
				var layId = layoutId;

				buttonMode = new ButtonMode();
				c_hitAreas.getLayer("hitArea" + i).add(buttonMode);

				disposer.connect1(buttonMode.engaged, function(_)
				{
					onChunkClicked(_sizeOrder[layId][index], index);
				});

			}();

		}

		owner.addChild(_hitAreas);

	}

	/* ---------------------------------------------------------------------------------------- */

	public function onChunkClicked(index:Int, order:Int)
	{
		var gt = System.root.get(GameTracker);
		var traits = gt.getTopPsychTraits();
		var traitScore:TraitScore = traits[index];
		var categoryId:CategoryId = null;
		var locId:String;

		var hitArea = _hitAreas.get(MovieSprite).getLayer("hitArea" + order);
		var hitBounds = Sprite.getBounds(hitArea);

		var pX = Math.round(hitBounds.x + hitBounds.width/2) + _hitAreas.get(Sprite).x._;
		var pY = Math.round(hitBounds.y + hitBounds.height/2) + _hitAreas.get(Sprite).y._;

		if (traitScore != null)
		{
			categoryId = traitScore.categoryId;
		}

		if (categoryId != null)
		{
			locId = "brainHub.trait_" + Std.string(categoryId).toLowerCase();
		}
		else
		{
			locId = "brainHub.emptyBrainSection_" + index;
		}

		message.emit(locId, new Point(pX, pY));
	}

	/* ---------------------------------------------------------------------------------------- */

	public static function getMaskedTexture(image:Texture, mask:Texture, destX:Float = 0, destY:Float = 0):Texture
	{
	    var texture:Texture = System.renderer.createTexture(image.width, image.height); 
	    var graphics = texture.graphics;

	    graphics.save();
	    graphics.drawTexture(image, 0, 0);
	    graphics.setBlendMode(BlendMode.Mask);
	    graphics.drawTexture(mask, destX, destY);
	    graphics.restore();

	    return texture;
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function dispose()
	{
		super.dispose();

		_brainPack = null;
		_scenePack = null;
	}

}






























