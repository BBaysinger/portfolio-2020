package s2.util;

import flambe.display.Sprite;

/**
 * Utility class to translate coordinates from one space to another.
 */
class Coords
{	
	/** The width of the standard resolution. */
	public var standardWidth (default, null): Float;
	/** The height of the standard resolution */
	public var standardHeight (default, null) :Float;
	/** The width of the standard resolution. */
	public var newWidth (default, null): Float;
	/** The height of the standard resolution */
	public var newHeight (default, null) :Float;
	/** comment */
	public var scaleX (default, null) :Float;
	/** comment */
	public var scaleY (default, null) :Float;
	/** The smallest of the scaleX and scaleY properties. */
	public var minScale (default, null) :Float;
	/** The largest of the scaleX and scaleY properties. */
	public var maxScale (default, null) :Float;

	/* ---------------------------------------------------------------------------------------- */
	
	public function new(standardWidth :Float, standardHeight :Float, newWidth :Float, newHeight :Float)
	{
		this.standardWidth = standardWidth;
		this.standardHeight = standardHeight;
		this.newWidth = newWidth;
		this.newHeight = newHeight;
		scaleX = newWidth / standardWidth;
		scaleY = newHeight / standardHeight;
		minScale = Math.min(scaleX, scaleY);
		maxScale = Math.max(scaleX, scaleY);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	public inline function x(value :Float) :Float
	{
		return value * scaleX;
	}

	/* ---------------------------------------------------------------------------------------- */
	

	public inline function y(value :Float) :Float
	{
		return value * scaleY;
	}


	/* ---------------------------------------------------------------------------------------- */
	
	public static inline function translate(s :Sprite, coords :Coords, valX :Float, valY :Float) :Sprite
	{
		return s.setXY(coords.x(valX), coords.y(valY));
	}
}