package s2.display;

import flambe.animation.AnimatedFloat;
import flambe.display.Graphics;
import flambe.display.Sprite;
import flambe.display.Texture;
import flambe.math.FMath;
import flambe.util.Assert;

class SwapSprite extends Sprite
{

	/** The texture which sits in front (fully visible when progress._ == 1) */
	public var textureFront (default, null) :Texture;
	/** The texture which sits in the back (fully visible when progress._ == 0) */
	public var textureBack (default, null) :Texture;	
	/** The percentage revealed. */
	public var progress (default, null) :AnimatedFloat;
	/** The current position of the transition. Relative to the sprite. Can be x or y depending on the swap direction. */
	public var position (default, null) :Float;
	/** comment */
	private var _drawFunction :Graphics->Float->Void;

	/* ---------------------------------------------------------------------------------------- */
	
	public function new(textureFront :Texture, textureBack :Texture, ?direction :SwapDirection) :Void
	{
		super();

		this.progress = new AnimatedFloat(0);
		Assert.that(textureFront.width == textureBack.width && textureFront.height == textureBack.height, "Texture widths must match.");
		this.position = 0;
		this.textureFront = textureFront;
		this.textureBack = textureBack;

		if (direction == null) direction = SwapDirection.Left;
		switch (direction) {
			case SwapDirection.Left:
				_drawFunction = left;
			case SwapDirection.Right:
				_drawFunction = right;
			case SwapDirection.Top:
				_drawFunction = top;
			case SwapDirection.Bottom:
				_drawFunction = bottom;
			default:
				_drawFunction = left;
		}
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Sets the current position of progress
	 * @param value :Float [description]
	 */
	public function setProgress(value :Float) :SwapSprite
	{
		this.progress._ = value;
		return this;
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function onUpdate(dt :Float) :Void
	{
		this.progress.update(dt);
		super.onUpdate(dt);
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function draw(g :Graphics):Void
	{
		_drawFunction(g, FMath.clamp(progress._, 0, 1));
	}
	
	/* ---------------------------------------------------------------------------------------- */
		
	private function left(g :Graphics, percent :Float) :Void
	{
		position = textureFront.width * percent;

		// This method seems to fix iOS issues
		g.drawTexture(textureBack, 0, 0);
		g.save();
		g.applyScissor(0, 0, position, textureFront.height);
		g.drawTexture(textureFront, 0, 0);
		g.restore();
	}

	/* ---------------------------------------------------------------------------------------- */
		
	private function right(g :Graphics, percent :Float) :Void
	{
		position = textureFront.width * (1 - percent);

		// This method seems to fix iOS issues
		g.drawTexture(textureFront, 0, 0);
		g.save();
		g.applyScissor(0, 0, position, textureFront.height);
		g.drawTexture(textureBack, 0, 0);
		g.restore();
	}

	/* ---------------------------------------------------------------------------------------- */
		
	private function top(g :Graphics, percent :Float) :Void
	{
		position = textureFront.height * percent;
		g.drawSubTexture(textureFront, 0, 0, 0, 0, textureFront.width, position);
		g.drawSubTexture(textureBack, 0, position, 0, position, textureFront.width, textureFront.height - position);
	}

	/* ---------------------------------------------------------------------------------------- */
		
	private function bottom(g :Graphics, percent :Float) :Void
	{
		position = textureFront.height * (1 - percent);
		
		// g.drawSubTexture(textureBack, 0, 0, 0, 0, textureFront.width, position);
		// g.drawSubTexture(textureFront, 0, position, 0, position, textureFront.width, textureFront.height - position);

		// This method seems to fix iOS issues
		g.drawTexture(textureFront, 0, 0);
		g.save();
		g.applyScissor(0, 0, textureFront.width, position);
		g.drawTexture(textureBack, 0, 0);
		g.restore();
	}

	/* ---------------------------------------------------------------------------------------- */
	
	override public function getNaturalWidth():Int
	{
		return textureFront.width;
	}
	/* ---------------------------------------------------------------------------------------- */
	
	override public function getNaturalHeight():Int
	{
		return textureFront.height;
	}


}

enum SwapDirection
{
	Left; Right; Top; Bottom;
}
