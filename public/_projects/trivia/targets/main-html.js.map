
package s2.client;


import flambe.System;
import flambe.util.Assert;
import flambe.util.Signal0;
import s2.client.Config;
import s2.loading.Assets;
//import s2.util.Utils;
import s2.util.Sniffer;

#if debug
import s2.util.URLParser;
#end

class CommonBootstrap 
	implements ClientBootstrap
{
	/** The completed signal. */
	public var complete :Signal0;
	/** comment */
	private var _options :Map<String, Dynamic>;

	public function new() :Void
	{
		this.complete = new Signal0();
		_options = new Map<String, Dynamic>();

		// Determines if we should load in mobile versions of asset packs or not.
        //var totalPixels :Float = System.stage.width * System.stage.height;

        // iPhone 4S resolution and lower. (960x736)
        if (Sniffer.lowMemory) {
            Assets.suffix = "mob"; // Set for mobile asset loading.
        }
	}

	/* ---------------------------------------------------------------------------------------- */

	public function start() :Void
	{
		Assert.fail("Must subclass and override CommonBootsrap.start().");
	}

	/* ---------------------------------------------------------------------------------------- */
	
	public function getOptions() :Map<String, Dynamic>
	{
		return _options;
	}

	public function track(?params :Array<Dynamic>) :Void
	{}
}