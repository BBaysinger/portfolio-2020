package flambesdk;
import flambe.asset.Manifest;

import nicksdk.jsembed.JSEmbedProxy;

/**
 * ...
 * @author Ang Li
 */
class BaseUtils
{
	/**
	 * Relative path to assets on domain
	 */
	public static var BASE_URL : String = "";
	public function new() 
	{
		
	}
	
	/**
	 * setup the given manifest with the correct relative path. 
	 * WARNING: this will erase any existing paths in "remoteBase" or "localBase"
	 * @param	manifest
	 * manifest to configure
	 * @return
	 * returns input manifest
	 */
	public static function setupManifest(manifest : Manifest):Manifest {
		if ( BASE_URL != "" ) {
			if (JSEmbedProxy.isCrossdomain)
			{
				manifest.remoteBase = BASE_URL;
			} else {
				manifest.localBase = BASE_URL;
			}
		}
		return manifest;
	}
	/**
	 * must be called at some point during initialization
	 * Determines and caches base url for later use.
	 */
	public static function setupBaseURL() {
		#if js 
		if (JSEmbedProxy.exists) 
		{ 
			// Set crossdomain base URL. 
			if (JSEmbedProxy.isCrossdomain) { 
				BASE_URL = appendAssetsToUrl(JSEmbedProxy.base); 
			} else { 
				BASE_URL = trimUrl(JSEmbedProxy.base); 
			} 
		} else { 
			BASE_URL = ""; 
		} 
		#else 
			BASE_URL = ""; 
		#end
	}
	
	// Trim the domain off of the supplied url
    private static function trimUrl( url:String ) : String
    {
        if(url==""){return "";}
        if(url.indexOf("http")<0)
        {
            if(url.charAt(0)=="/")
            {
                url = url.substr(1, url.length-1);
            }
            return url;
        }
        var tStartIndex = url.indexOf("http://");
        if(tStartIndex<0)
        {
            tStartIndex = url.indexOf("https://");
            if(tStartIndex<0)
            {
                // This should be impossible. 
                tStartIndex=0;
            } else {
                tStartIndex += 8;
            }
        } else {
            tStartIndex += 7;
        }
        
        var tEndIndex = url.indexOf("/", tStartIndex);      
        
        var result = url.substr(tEndIndex, url.length - tEndIndex);
                
        result = appendAssetsToUrl(result);     
                                                    
        return result;
        
    }
    // Append the "assets" tag to the url
    private static function appendAssetsToUrl( url:String) : String
    {       
        //if(url.length==0){return url;}
        if(url.charAt(url.length-1)!="/")
        {
            url = url + "/";
        }
        url = url + "assets/";
        return url;
    }
}