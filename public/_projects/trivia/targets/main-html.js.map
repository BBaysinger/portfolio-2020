package s2.scene;

import flambe.asset.Manifest;
import flambe.Disposer;
import flambe.Entity;
import flambe.scene.Scene;
import flambe.System;
import flambe.util.Disposable;

import s2.loading.Assets;
import s2.scene.Scenes;

/**
 * Base class for scenes. 
 * @author Kipp Ashford
 */
class BaseScene extends Scene
{
	/** The hidden signal binding. */
	private var _hiddenBind :Disposable;
	/** Assets to be injected by the SceneLoader. */
	@:allow(s2.scene) var _assets :Assets;
	/** Tracks if we have initialized the scene or not yet. */
	private var _intialized :Bool = false;
	/** The packs which are required before transitioning to this scene */
	@:keep public var requiredPacks (default, null) :Array<String>;
	/** The packs which are required before transitioning to this scene */
	@:keep public var dynamicManifests (default, null) = new Map<String, Manifest>();

	/* ---------------------------------------------------------------------------------------- */
	
	@:keep public function new() 
	{
		super();
		requiredPacks = [];
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	override public function onAdded() 
	{
		var disposer :Disposer = owner.get(Disposer);
		if (disposer == null) {
			owner.add(disposer = new Disposer());
		}

		var topScene :Entity = Scenes.director.topScene;
		var scene :Scene = topScene != null ? topScene.get(Scene) : null;

		var shown :Disposable = null;
		if(scene != null) {
			shown = scene.hidden.connect(onShown).once();
		} else {
			shown = this.shown.connect(onShown).once();
		}

		// var shown:Disposable = this.shown.connect(internal_onShown).once();
		disposer.add(shown); // Automatic cleanup.
		_hiddenBind = hidden.connect(onHidden).once();
		disposer.add(_hiddenBind);
		disposer.connect0(System.stage.resize, onResize);

		if (!_intialized) {
			assetsReady();
			_intialized = true;
			onResize();
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * Used for initialization of a scene, will probably be depreciated in a later version of the base class.
	 * @return [description]
	 */
	public function assetsReady()
	{
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Triggered when the assets needed by this section have loaded.
	 */
	@:allow(s2.scene) function injectAssets(assets :Assets) :Void
	{
		_assets = assets;
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Triggered when the assets are both ready and the transition to this scene is complete.
	 * @return [description]
	 */
	private function onShown() 
	{
	}

	/* ---------------------------------------------------------------------------------------- */
	
	private function onHidden()
	{
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * Called when the stage size changes.
	 */
	public function onResize():Void
	{
		// Put your resize code here.
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	override public function onRemoved():Void
	{
		super.onRemoved();

		//Ideally, should nullify references to composite data types stored in instance variables,
		//in overrides to this function.
		_assets = null;
	}
	
}
























