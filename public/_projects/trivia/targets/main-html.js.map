package com.nick.ultimatetrivia;

import flambe.util.Signal0;
import flambe.System;
import flambe.Component;
import flambe.Disposer;
import flambe.util.Logger;

import s2.util.Utils;
import s2.localization.Locale;

import com.nick.ultimatetrivia.components.GameTracker;
import com.nick.ultimatetrivia.Data;

enum QuestionType 
{
	CHOICE;
	BOOL;
	MATCH;
	MATCH_IMAGE;
	IMAGE;
	IMAGE_OPTION;
	AUDIO;
	RATHER;
	PERSONALITY_CHOICE;
	//PERSONALITY_IMAGE;
}

/**
 * Holds data for each question.
 * ...
 * @author Seven2
 */
class Question
{
	/**  */
	public static inline var DO_LOGGING:Bool = true;
	/**  */
	public static var texts:Array<String> = [];

	/**  */
	public var type(default, null):QuestionType;
	/**  */
	public var category(default, null):CategoryId;
	/**  */
	public var text(default, null):String;
	/**  */
	public var queries(default, null) = new Array<Query>();
	/**  */
	public var options(default, null) = new Array<Option>();
	/**  */
	public var image(default, null):String;
	/**  */
	public var sound(default, null):String;
	/**  */
	private var _xNode:Xml;
	/**  */
	public var responsePoints(default, null):Int;
	/*  */
	public var optionChanged(default, null) = new Signal0();
	/*  */
	public var index(default, null):Int;
	/*  */
	private var _log = System.createLogger("");

    /* ---------------------------------------------------------------------------------------- */

	public function new(xNode:Xml, category:CategoryId, index:Int)
	{
		this.index = index;

		_xNode = xNode;
		this.category = category;

		if (_xNode.elementsNamed("text").next() == null)
		{
			throw("Missing text node. Category: " + category + ", Node: \n\t" + _xNode);
		}

		this.text = StringTools.htmlUnescape(_xNode.elementsNamed("text").next().firstChild() + "");

		if (_xNode.get("type") == null)
		{
			throw("Invalid type. Category: " + category + ", Node: \n\t" + _xNode);
		}

		try {
			Type.createEnum(QuestionType, _xNode.get("type").toUpperCase());
		}
		catch (msg : String)
		{
			throw("Invalid type. Category: " + category + ", Node: \n\t" + _xNode);
		}

		this.type = Type.createEnum(QuestionType, _xNode.get("type").toUpperCase());
		
		this.image = _xNode.get("image");
		this.sound = _xNode.get("sound");

		this.image = (this.image == "") ? null : this.image;
		this.sound = (this.sound == "") ? null : this.sound;

		texts.push(this.text);

		var xOptions:Iterator<Xml> = _xNode.elementsNamed("option");
		var xQueries:Iterator<Xml> = _xNode.elementsNamed("query");

		if (!xOptions.hasNext())
		{
			if (!permitOmittedOptions())
			{
				logError("Omitted options.");

				var node1 = Xml.parse("<option>[MISSING OPTION] 1</option>").firstChild();
				options.push(new Option(node1, 0));

				var node2 = Xml.parse("<option>[MISSING OPTION] 2</option>").firstChild();
				options.push(new Option(node2, 1));
			}
			else
			{
				var nodeTrue = Xml.parse("<option>" + Locale.getFormat("question.true").text + "</option>").firstChild();
				options.push(new Option(nodeTrue, 0));

				var nodeFalse = Xml.parse("<option>" + Locale.getFormat("question.false").text + "</option>").firstChild();
				options.push(new Option(nodeFalse, 1));
			}
			
		}
		else
		{
			var i:Int = 0;
			var option:Option;

			for (xOption in xOptions)
			{
				option = new Option(xOption, i);
				options.push(option);

				if (type == IMAGE_OPTION || type == MATCH_IMAGE)
				{
					if (option.image == null)
					{
						logError("'image' attribute required on option node: " + xOption);
					}
				}
				else
				{
					if (option.text == null)
					{
						throwError("Text required on option node: " + xOption);
					}

				}

				if (i > 3) 
				{
					throwError("Too many options.");
				}

				i++;
			}

		}
		
		var queriesBySolutionIndex = new Array<Query>();
		var index:Int = 0;

		for (xQuery in xQueries)
		{
			var solutionAttr = xQuery.get("solution");

			if (solutionAttr == null && !permitOmittedSolutionArribute())
			{
				throwError("Ommitted solution ID not permitted." + text);
			}

			//ONE based (number 1 is the origin in the XML), converted to zero-based here to be consistent with array keys.
			var solution:Int = (solutionAttr == null) ? index : Std.parseInt(solutionAttr) - 1;
			var query = new Query(xQuery, options[solution], type, index);
			queries.push(query);

			if (type == MATCH_IMAGE && query.image == null)
			{
				logError("'image' attribute required on query node: " + xQuery);
			}

			if (queriesBySolutionIndex[solution] != null)
			{
				throwError("Duplicate.");
			}
			else
			{
				queriesBySolutionIndex[solution] = query;
			}

			index++;
			
		}

		if (queriesBySolutionIndex.length > options.length)
		{
			throwError("Solution index out of bounds (1 based).");
		}

		if (queries.length == 0)
		{
			queries.push(new Query(Xml.parse("<query></query>").firstChild(), options[0], type, 0));
		}

		for (query in queries)
		{
			query.optionChanged.connect(onQueryOptionChanged);
		}

		if (this.type == MATCH)
		{
			if (queries.length < 3)
			{
				throwError("Insufficient number of queries.");
			}
			if (options.length < 2)
			{
				throwError("Insufficient number of options.");
			}
		}
		else
		{
			if (options.length < 2)
			{
				logError("Insufficient number of options.");
			}
		}

		if (this.type == AUDIO && sound == null)
		{
			logError("'sound' attribute missing.");
		}

		if (this.type == IMAGE && image == null)
		{
			logError("'image' attribute missing.");
		}

	}

    /* ---------------------------------------------------------------------------------------- */

	private function logError(str:String)
	{
		//#if flash //Slows things down in HTML?
		if (DO_LOGGING) _log.error(category + " ▩ " + type + " ▩ " + text + " ► " + str);
		//#end
	}

    /* ---------------------------------------------------------------------------------------- */

	private function throwError(str:String)
	{
		//#if flash
		throw(category + " ▩ " + type + " ▩ " + text + " ► " + str);
		//#end
	}

    /* ---------------------------------------------------------------------------------------- */

	private function onQueryOptionChanged()
	{
		optionChanged.emit();
	}

    /* ---------------------------------------------------------------------------------------- */

	public function reset()
	{
		for (query in queries)
		{
			query.reset();
		}

	}

    /* ---------------------------------------------------------------------------------------- */

	public function permitOmittedOptions():Bool
	{
		switch (type)
		{
			case BOOL: return true;
			default: return false;
		}

	}

    /* ---------------------------------------------------------------------------------------- */

	public function permitOmittedSolutionArribute():Bool
	{
		switch (type)
		{
			case CHOICE, IMAGE, AUDIO, RATHER, MATCH, MATCH_IMAGE, IMAGE_OPTION, PERSONALITY_CHOICE /*, PERSONALITY_IMAGE*/: return true;
			default: return false;
		}

	}

    /* ---------------------------------------------------------------------------------------- */

    public var allAnswered(get_allAnswered, null):Bool;
	public function get_allAnswered():Bool
	{

		for (query in queries)
		{
			if (!query.hasSelectedOption)
			{
				return false;
			}

		}

		return true;

	}

    /* ---------------------------------------------------------------------------------------- */

	public function allCorrect()
	{
		for (query in queries)
		{
			if (!query.isCorrect)
			{
				return false;
			}

		}

		return true;

	}

    /* ---------------------------------------------------------------------------------------- */

	public function hasSelectedOption()
	{
		for (query in queries)
		{
			if (query.hasSelectedOption)
			{
				return true;
			}

		}

		return false;

	}

}




























