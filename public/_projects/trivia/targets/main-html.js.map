package s2.scene;

import flambe.display.FillSprite;
import flambe.display.Sprite;
import flambe.Entity;
import flambe.System;

import s2.scene.BaseScene;
import s2.scene.Scenes;
import s2.util.Coords;
import s2.display.SizeSprite;

/**
 * The base game scene to use for all the mini-games. 
 * @author Seven2
 */
@:keepSub
class AutoFillScene extends BaseScene
{
	/**  */
	public static inline var STANDARD_WIDTH:Int = 1366;
	/**  */
	public static inline var STANDARD_HEIGHT:Int = 768;

	/** The normal un-resized image. We will use this as a reference for loading in scaled assets. */
	public var standardWidth :Int = STANDARD_WIDTH;
	/** The normal un-resized image. We will use this as a reference for loading in scaled assets. */
	public var standardHeight :Int = STANDARD_HEIGHT;
	/**  */
	public var scale(default, null):Float;

	/** Contains the background */
	private var _backing 	:Entity;
	/** Container that holds all of our content. */
	private var _container 	:Entity;
	/** Used to position elements on the screen in a resolution independant way. */
	private var __ :Coords;

	/* ---------------------------------------------------------------------------------------- */

	@:keep public function new()
	{
		super();
	}
	
	/* ---------------------------------------------------------------------------------------- */
	
	public function setBackground(background :Sprite) :Void
	{
		__ = new Coords( standardWidth, standardHeight, background.getNaturalWidth(), background.getNaturalHeight());
		(_backing == null ? _backing = new Entity() : _backing).add(background);
		
		if (owner != null && owner.parent != null) {
			onResize(); // Make sure we're sized properly with the new background.
		} 
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded():Void
	{
		//this.setBackground(new FillSprite(0xFF0000, standardWidth, standardHeight)); // Sets up the background with a default fill sprite.
		this.setBackground(new SizeSprite(standardWidth, standardHeight)); // Sets up the background with a default fill sprite.
		
		// Add all our objects to the container.
		_container = new Entity()
			.add(new Sprite())
			.addChild(_backing);

		owner.addChild(_container);
		
		super.onAdded();
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onResize()
	{
		var safeWidth :Float = 1024; // The designed (unscaled) safe area.
		var safeHeight :Float = 600; // The designed (unscaled) safe area.

		scale = Math.min(System.stage.width / __.x(safeWidth), System.stage.height / __.y(safeHeight));
		var nWidth :Float = __.newWidth * scale;
		var nHeight :Float = __.newHeight * scale;

		// Reposition the container. (centered)
		_container.get(Sprite)
			.setScale(scale)
			.setXY( (System.stage.width - nWidth) * 0.5 , (System.stage.height - nHeight) * 0.5 );
	}

	/* ---------------------------------------------------------------------------------------- */
	
	/**
	 * 
	 */
	override public function onRemoved():Void
	{
		super.onRemoved();
		
		_backing = null;
		_container = null;
		__ = null;

	}

}



















