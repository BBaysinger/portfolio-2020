package s2.ui;

import flambe.display.Sprite;
import flambe.Entity;
import flambe.asset.AssetPack;
import flambe.input.PointerEvent;
import flambe.animation.Ease;
import flambe.util.Signal1;
import flambe.display.Texture;
import flambe.display.FillSprite;
import flambe.display.TextSprite;
import flambe.math.Point;

import s2.localization.Locale;
import s2.display.FluidSprite;

/**
 * BasicButton with localized TextSprite. Use this if you do NOT want the button to scale for text.
 * 
 * @author Bradley Baysinger / Seven2
 */
class TextButton extends BasicButton
{
	/** So it can be set globally. */
	public static var OFFSET_XY = new Point(-2, 0);//-2 adjusts for alignment quirk.;

	/** For overriding. */
	private var _offsetXY = new Point(OFFSET_XY.x, OFFSET_XY.y);
	/**  */
	private var _loc:String;
	/**  */
	private var _textSprite:TextSprite;
	/**  */
	public var textSprite(get_textSprite, null):TextSprite;
	/**  */
	public var text(get_text, null):String;

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	public function new(pack:AssetPack, id:String, loc:String)
	{
		_loc = loc;

		//States may be created based on size of text, so need to instance it before everything else.
		//Also, _overlay does not exist yet, so need to store reference to the text Sprite.
		_textSprite = createField();

		super(pack, id);

		_overlay.add(_textSprite);

		setText(text);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	override public function onAdded()
	{
		super.onAdded();

		_stateHolder.addChild(_overlay);
		
		//var test = new FillSprite(0x003223, 10, 10);
		//owner.addChild(new Entity().add(test));

	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * So can be overridden.
	 */
	public function createField():TextSprite
	{
		return Locale.getField(_loc, 0);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	* If you don't do this after you update the text, it wont be centered.
	*
	* Would be nicer if you could just use align = Center, but then Sprite.getBounds doesn't work.
	*/
	public function setText(val:String, offset:Point = null):String
	{
		_offsetXY = (offset == null) ? new Point(_offsetXY.x, _offsetXY.y) : new Point(offset.x, offset.y);

		var c_textSprite = _overlay.get(TextSprite);

		if (val != null)
		{
			c_textSprite.text = val;
		}

		var textXY = new Point(
			(-c_textSprite.getNaturalWidth() * c_textSprite.scaleX._)/2,
			(-c_textSprite.getNaturalHeight() * c_textSprite.scaleY._)/2
		);

		c_textSprite.x._ = textXY.x + _offsetXY.x;
		c_textSprite.y._ = textXY.y + _offsetXY.y;

		return val;
		
	}
	
	/* ---------------------------------------------------------------------------------------- */

	public function get_text():String
	{
		return _overlay.get(TextSprite).text;
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	private function get_textSprite():TextSprite
	{
		return _overlay.get(TextSprite);
	}

	/* ---------------------------------------------------------------------------------------- */

	/**
	 * 
	 */
	override public function dispose()
	{
		super.dispose();

		_textSprite = null;
		_overlay = null;
	}

}
























