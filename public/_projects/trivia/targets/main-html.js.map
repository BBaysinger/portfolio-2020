package com.nick.ultimatetrivia.components;

import flambe.Entity;
import flambe.Disposer;
import flambe.asset.AssetPack;
import flambe.input.PointerEvent;
import flambe.display.FillSprite;
import flambe.display.ImageSprite;
import flambe.display.Sprite;
import flambe.display.TextSprite;
import flambe.math.Point;
import flambe.util.Signal0;
import flambe.animation.Ease;

import s2.display.SpriteUser;
import s2.scene.AutoFillScene;
import s2.localization.Locale;

class BrainChunkCallout extends SpriteUser
{
	/**  */
	private var _pack 					:AssetPack;
	/**  */
	private var _panelLt 				= new Entity();
	/**  */
	private var _panelRt 				= new Entity();
	/**  */
	private var _messageOverlay:Entity 	= new Entity();
	/**  */
	private var _message:Entity 		= new Entity();
	/**  */
	private var _panelHolder:Entity  	= new Entity();
	/**  */
	public var hide(default, null)		= new Signal0();

	/* ---------------------------------------------------------------------------------------- */

	public function new(pack:AssetPack)
	{
		super();

		_pack = pack;
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onAdded()
	{
		var disposer = owner.get(Disposer);
        if (disposer == null) owner.add(disposer = new Disposer());

		var c_messageOverlay = new FillSprite(0x990000, AutoFillScene.STANDARD_WIDTH, AutoFillScene.STANDARD_HEIGHT);

		c_messageOverlay.alpha._ = 0.0;
		_messageOverlay.add(c_messageOverlay);
		owner.addChild(_messageOverlay);

		var c_panelLt = new ImageSprite(_pack.getTexture("chunk_callout"));
		c_panelLt.scaleX._ = -1;
		c_panelLt.disablePointer();
		c_panelLt.setAnchor(40, 10);
		_panelLt.add(c_panelLt);
		_panelHolder.addChild(_panelLt);

		var c_panelRt = new ImageSprite(_pack.getTexture("chunk_callout"));
		c_panelRt.disablePointer();
		c_panelRt.setAnchor(40, 10);
		_panelRt.add(c_panelRt);
		_panelHolder.addChild(_panelRt);

		var c_panelHolder = new Sprite();
		_panelHolder.add(c_panelHolder);
		owner.addChild(_panelHolder);

		var c_message = Locale.getField("brainHub.brainSectionCallout", 350, Center);
		c_message.lineSpacing._ = -1;
		_message.add(c_message);
		c_message.disablePointer();
		_panelHolder.addChild(_message);

		sprite.alpha._ = 0;
		sprite.pointerEnabled = false;

		disposer.connect1(sprite.pointerDown, onPointerDown);
	}

	/* ---------------------------------------------------------------------------------------- */

	public function show(messageLoc:String, p:Point)
	{
		_pack.getSound("sfx/brain_pop_up").play();

		var c_message = _message.get(TextSprite);
		c_message.text = Locale.getFormat(messageLoc).text;

		var lrCuttoff:Int = 750;
		var isLeft = p.x > lrCuttoff;

		_panelLt.get(Sprite).alpha._ = (isLeft) ? 1 : 0;
		_panelRt.get(Sprite).alpha._ = (isLeft) ? 0 : 1;

		c_message.x._ = (isLeft) ? -428 : 80;
		c_message.y._ = 112 - Sprite.getBounds(_message).height/2;

		var c_panelHolder = _panelHolder.get(Sprite);
		c_panelHolder.setXY(p.x, p.y);
		c_panelHolder.scaleY._ = 0.5;
		c_panelHolder.scaleX._ = 0.5;
		c_panelHolder.scaleX.animateTo(1, 0.5, Ease.bounceOut);
		c_panelHolder.scaleY.animateTo(1, 0.5, Ease.bounceOut);

		sprite.pointerEnabled = true;
		sprite.alpha.animateTo(1, 0.0);
	}

	/* ---------------------------------------------------------------------------------------- */

	private function onPointerDown(e:PointerEvent)
	{
		sprite.alpha.animateTo(0, 0);
		sprite.disablePointer();

		hide.emit();
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function onRemoved()
	{
		_panelLt = null;
		_panelRt = null;
		_panelHolder = null;
		_messageOverlay = null;
		_message = null;
		_pack = null;

		super.onRemoved();
	}

}





























