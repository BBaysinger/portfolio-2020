package com.nick.ultimatetrivia.components.question;

import flambe.Entity;
import flambe.asset.AssetPack;
import flambe.sound.Playback;
import flambe.sound.Sound;
import flambe.Disposer;
import flambe.input.PointerEvent;
import flambe.display.Sprite;
import s2.sound.MusicManager;

import s2.ui.BasicButton;


/**
 * Controls how the questions are displayed.
 * ...
 * @author Seven2
 */
class AudioQuestionDisplay extends QuestionDisplay
{
	/**  */
	var _playBtn = new Entity();
	/**  */
	var _sound:Sound;
	/**  */
	var _playback:Playback;

	/* ---------------------------------------------------------------------------------------- */

	public function new(scenePack:AssetPack, quizPack:AssetPack, globalPack:AssetPack, question:Question)
	{
		super(scenePack, quizPack, globalPack, question);
	}

	/* ---------------------------------------------------------------------------------------- */

	override private function build()
	{
		super.build();

		var c_playBtn = new BasicButton(_scenePack, "ui/play_btn");
		c_playBtn.setXY(335, 646);
		owner.get(Disposer).connect1(c_playBtn.engaged, onPlayBtnEngaged);
		_playBtn.add(c_playBtn);
		owner.addChild(_playBtn);
		_playBtn.get(Sprite).visible = false;

		if (_oQuestion.sound != null)
		{
			_sound = _quizPack.getSound(_oQuestion.sound);

			playSound();
		}

	}

	/* ---------------------------------------------------------------------------------------- */

	private function playSound()
	{
		MusicManager.volume = 0;
		_playBtn.get(Sprite).visible = false;

		_playback = _sound.play();

		owner.get(Disposer).connect2(_playback.complete.changed, onPlaybackCompleteChanged);

	}

	/* ---------------------------------------------------------------------------------------- */

	private function onPlaybackCompleteChanged(val1, val2)
	{
		MusicManager.volume = 1;

		_playBtn.get(Sprite).visible = true;
	}

	/* ---------------------------------------------------------------------------------------- */

	private function onPlayBtnEngaged(e:PointerEvent)
	{
		playSound();
	}

	/* ---------------------------------------------------------------------------------------- */

	override public function dispose()
	{
		super.dispose();

		if (_playback != null) _playback.dispose();
		_sound = null;
	}

}























